HomeAssistant__BaseUrl=http://homeassistant.local:8123
HomeAssistant__EntityId=climate.dining_room
HomeAssistant__WeatherEntityId=
HomeAssistant__OutdoorTemperatureEntityId=
HomeAssistant__UsagePowerEntityId=sensor.alectra_hui_current_power
HomeAssistant__UsageEnergyEntityId=sensor.alectra_hui_energy_today
HomeAssistant__UsageCostEntityId=sensor.alectra_hui_cost_today
HomeAssistant__AccessToken=replace-with-home-assistant-long-lived-token
HomeAssistant__Username=replace-with-home-assistant-username
HomeAssistant__Password=replace-with-home-assistant-password
Defender__PollIntervalSeconds=5
Defender__CommandGraceSeconds=120
