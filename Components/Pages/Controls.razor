@page "/controls"
@implements IDisposable
@inject DefenderStateProvider State
@inject DefenderStateStore StateStore
@inject AcDefenderService Defender
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Direct Controls — SCP AC Defender</PageTitle>

<div class="ops-dash-stack">

    @* ── containment master switch ── *@
    <button class="@DefenderSwitchClass" @onclick="ToggleDefender" aria-pressed="@(DefenderIsEnabled ? "true" : "false")">
        <span class="ops-defender-switch__glyph" aria-hidden="true">⏻</span>
        <span class="ops-defender-switch__body">
            <span class="ops-defender-switch__label">CONTAINMENT MASTER</span>
            <span class="ops-defender-switch__state">@(DefenderIsEnabled ? "ON DUTY" : "STOOD DOWN")</span>
            <span class="ops-defender-switch__hint">@(DefenderIsEnabled ? "Tap to stand containment down · syncs to every page" : "Tap to wake the containment shift")</span>
        </span>
        <span class="ops-defender-switch__pill" aria-hidden="true"><span class="ops-defender-switch__knob"></span></span>
    </button>

    <div class="ops-controls-grid">

        @* ── A · temp I want ── *@
        <div class="ops-ctl-card ops-ctl-card--accent">
            <h2 class="ops-ctl-label" style="color: var(--accent);">⌖ TEMP I WANT — O5 DIRECTIVE</h2>
            <div class="ops-stepper">
                <button class="ops-stepper__btn" @onclick="TargetDown" aria-label="Lower">−</button>
                <div class="ops-stepper__value">@TargetShort</div>
                <button class="ops-stepper__btn" @onclick="TargetUp" aria-label="Raise">+</button>
            </div>
            <button class="ops-apply-btn" @onclick="ApplyTarget">⌖ APPLY MY TEMP</button>
            <div class="ops-ctl-quick">
                <button class="ops-btn ops-btn--outline" @onclick="GenerateTarget">✦ GENERATE</button>
                <button class="ops-btn" @onclick="ForceBoost">❆ FORCE COOL</button>
                <button class="ops-btn ops-btn--danger" @onclick="TurnOffFromControls">⏻ OFF</button>
            </div>
            <div class="ops-ctl-note">Files the directive with the defender state, then the worker walks the wall unit there politely. Never a rude direct thermostat command.</div>
        </div>

        @* ── B · fan mode ── *@
        <div class="ops-ctl-card">
            <h2 class="ops-ctl-label">FAN MODE</h2>
            <div class="ops-fan-list">
                @if (FanModes.Count == 0)
                {
                    <button class="ops-fan-btn" disabled aria-live="polite">WAITING FOR HOME ASSISTANT MODES</button>
                }
                else
                {
                    @foreach (var mode in FanModes)
                    {
                        <button class="@(IsCurrentFan(mode) ? "ops-fan-btn ops-fan-btn--active" : "ops-fan-btn")"
                                @onclick="@(() => ApplyFanModeTo(mode))" aria-pressed="@(IsCurrentFan(mode) ? "true" : "false")">@mode.ToUpperInvariant()</button>
                    }
                }
            </div>
            <div class="ops-ctl-note">Only modes advertised by the real Home Assistant climate entity are actionable.</div>
        </div>

        @* ── C · real thermostat actions ── *@
        <div class="ops-ctl-card">
            <h2 class="ops-ctl-label">REAL THERMOSTAT ACTIONS</h2>
            <div class="ops-act-list">
                <button class="ops-order-btn" @onclick="RefreshReal">
                    <span aria-hidden="true">⟳</span>
                    <span class="ops-order-btn__label">REFRESH</span>
                    <span class="ops-order-btn__hint">ask HA for the newest reading</span>
                </button>
                <button class="ops-order-btn" @onclick="ForceTarget">
                    <span aria-hidden="true">⌖</span>
                    <span class="ops-order-btn__label">FORCE TARGET</span>
                    <span class="ops-order-btn__hint">exact directive, now</span>
                </button>
                <button class="ops-order-btn ops-order-btn--solid" @onclick="ForceBoost">
                    <span aria-hidden="true">❆</span>
                    <span class="ops-order-btn__label">FORCE COOLING</span>
                    <span class="ops-order-btn__hint">room − @BoostOffsetText, no waiting</span>
                </button>
            </div>
            <div class="ops-ctl-note">These send real Home Assistant service calls now. The website debounce blocks repeat taps for two minutes.</div>
        </div>

        @* ── D · emergency ── *@
        <div class="ops-ctl-card ops-ctl-card--bad">
            <h2 class="ops-ctl-label" style="color: var(--bad);">⚠ EMERGENCY PROTOCOLS — BYPASS THE WEBSITE LOCK</h2>
            <div class="ops-emg-list">
                @foreach (var option in EmergencyProtocols)
                {
                    <button class="@(_emergencyProtocol == option.Value ? "ops-emg-btn ops-emg-btn--active" : "ops-emg-btn")"
                            @onclick="@(() => _emergencyProtocol = option.Value)" aria-pressed="@(_emergencyProtocol == option.Value ? "true" : "false")">
                        <span class="ops-emg-btn__label">@option.Label</span>
                        <span class="ops-emg-btn__help">@option.Help</span>
                    </button>
                }
            </div>
            <div style="margin-top: 10px;">
                <SlideToConfirm Label="@($"SLIDE TO RUN {SelectedEmergencyName.ToUpperInvariant()}")" ConfirmedLabel="EMERGENCY RUNNING" Glyph="⚠" OnConfirmed="RunEmergencyProtocol" />
            </div>
            @if (Snapshot?.Emergency.Active == true)
            {
                <div class="ops-alert-row ops-alert-row--warn" style="margin-top: 10px;">
                    <span class="ops-alert-row__tag">ACTIVE</span>
                    <span class="ops-alert-row__text">@Snapshot.Emergency.Status</span>
                </div>
            }
        </div>

        @* ── E · mess hall (siesta) ── *@
        <div class="ops-ctl-card ops-ctl-card--info">
            <h2 class="ops-ctl-label" style="color: var(--info);">☾ MESS HALL (SIESTA)</h2>
            @if (Snapshot?.Siesta is { Active: true } activeNap)
            {
                <div class="ops-siesta-active">
                    <span aria-hidden="true" class="ops-alert-row__glyph--bob">☾</span>
                    GUARDS ASLEEP — wake @(activeNap.Until?.ToLocalTime().ToString("HH:mm") ?? "soon")
                    (@(activeNap.SecondsRemaining / 60) min left) · rations this nap $@activeNap.FoodEarnedThisSiestaCad.ToString("0.00")
                </div>
                <button class="ops-btn ops-btn--outline" style="width: 100%; margin-top: 8px;" @onclick="CancelSiesta">⏰ WAKE THE GUARDS NOW</button>
            }
            else
            {
                <div class="ops-ctl-note" style="margin-top: 0; margin-bottom: 8px;">Send the whole guard force to the mess hall. The AC eases off and every quiet minute banks food rations.</div>
                <div class="ops-siesta-btns">
                    <button class="ops-btn" @onclick="@(() => StartSiesta(60))">☾ 1 HOUR</button>
                    <button class="ops-btn" @onclick="@(() => StartSiesta(120))">☾ 2 HOURS</button>
                    <button class="ops-btn" @onclick="@(() => StartSiesta(240))">☾ 4 HOURS</button>
                </div>
            }
            @if (Snapshot?.FoodRations is { } pantry)
            {
                <div class="ops-ctl-note" style="margin-bottom: 0;">Pantry <strong style="color: var(--warn);">$@pantry.BalanceCad.ToString("0.00")</strong> / $@pantry.BalanceMaxCad.ToString("0.00") · earned today <strong style="color: var(--accent);">$@pantry.EarnedTodayCad.ToString("0.00")</strong></div>
            }
        </div>

        @* ── F · learning ── *@
        <div class="ops-ctl-card">
            <h2 class="ops-ctl-label">LEARNING — THE ANGER MODEL</h2>
            <button class="ops-btn ops-btn--outline" style="width: 100%;" @onclick="LearnFromHistory" disabled="@_learningHistory">
                @(_learningHistory ? "✦ RETRAINING…" : "✦ RETRAIN FROM HISTORY NOW")
            </button>
            <p class="ops-learn-p">@LearningParagraph</p>
        </div>
    </div>
</div>

@code {
    private double _targetInput = 22.0;
    private bool _targetDirty;
    private string _emergencyProtocol = "suspicion";

    private static readonly (string Value, string Label, string Name, string Help)[] EmergencyProtocols =
    [
        ("too-cold", "❄ TOO COLD", "too cold", "Pauses the defender and turns the real thermostat off (30 min)."),
        ("someone-upset", "😠 SOMEONE UPSET", "someone upset", "Observe-only mode so wall changes are not fought (45 min)."),
        ("suspicion", "👀 SUSPICION QUIET", "suspicion quiet", "Longer quiet window; readings continue, corrections stand down (90 min)."),
        ("brother-mad", "🚨 BROTHER MAD", "brother mad", "Full apology: +1.0 °C peace gesture, all corrections stopped 2 h, anger model updated.")
    ];

    private DefenderSnapshot? Snapshot => State.Snapshot;
    private string SelectedEmergencyName => EmergencyProtocols.FirstOrDefault(o => o.Value == _emergencyProtocol).Name ?? "emergency";

    private bool DefenderIsEnabled => Snapshot?.DefenderEnabled == true;
    private string DefenderSwitchClass => DefenderIsEnabled ? "ops-defender-switch ops-defender-switch--on" : "ops-defender-switch ops-defender-switch--off";

    private string TargetShort => $"{_targetInput:0.0}°";
    private string BoostOffsetText => $"{Snapshot?.BoostOffsetCelsius ?? 1.0:0.0} °C";

    private bool IsCurrentFan(string mode) => string.Equals(mode, Snapshot?.HomeAssistantThermostat?.FanMode, StringComparison.OrdinalIgnoreCase);

    private bool HomeAssistantOnline =>
        string.Equals(Snapshot?.ConnectionState, "home-assistant", StringComparison.OrdinalIgnoreCase)
        && Snapshot?.HomeAssistantThermostat is not null;

    private IReadOnlyList<string> FanModes => HomeAssistantOnline
        ? Snapshot?.HomeAssistantThermostat?.AvailableFanModes?
            .Where(mode => !string.IsNullOrWhiteSpace(mode))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray()
            ?? Array.Empty<string>()
        : Array.Empty<string>();

    private string LearningParagraph
    {
        get
        {
            var model = Snapshot?.LearningModel;
            var anger = model is null
                ? "gathering data"
                : model.AngerModelTrained
                    ? $"trained on {model.AngerPositiveSamples + model.AngerNegativeSamples} labelled moments ({model.AngerPositiveSamples} upset)"
                    : "gathering data";
            var comfort = model is null
                ? "gathering data"
                : model.ComfortModelTrained
                    ? $"{model.ComfortSamples} samples, RMSE {model.ComfortRmse:0.0} °C"
                    : "gathering data";

            var grace = Snapshot?.AngerLearning is { CurrentHourSensitivity: > 0 } al
                ? $" This hour is {(int)Math.Round(al.CurrentHourSensitivity * 100)}% sensitive, adding {al.ExtraGraceMinutes} min of hands-off grace."
                : string.Empty;

            return $"Anger model: {anger}. Comfort model: {comfort}.{grace}";
        }
    }

    protected override void OnInitialized()
    {
        _targetInput = Snapshot?.TargetTemperatureCelsius ?? 22.0;
        State.Changed += OnStateChanged;
    }

    private void OnStateChanged()
    {
        if (!_targetDirty && Snapshot is not null)
        {
            _targetInput = Snapshot.TargetTemperatureCelsius;
        }

        InvokeAsync(StateHasChanged);
    }

    private void TargetUp()
    {
        _targetInput = Math.Min(35, _targetInput + 0.5);
        _targetDirty = true;
    }

    private void TargetDown()
    {
        _targetInput = Math.Max(10, _targetInput - 0.5);
        _targetDirty = true;
    }

    private async Task GenerateTarget()
    {
        if (!TryBeginWebsiteCommand("generate target", bypassDebounce: true))
        {
            return;
        }

        var snapshot = await Defender.GenerateTargetAsync(CancellationToken.None);
        State.Refresh();
        _targetInput = snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
        Snackbar.Add("Generated a new target.", Severity.Success);
    }

    private async Task ApplyTarget()
    {
        if (!TryBeginWebsiteCommand("set target", bypassDebounce: true))
        {
            return;
        }

        var snapshot = await Defender.SetTargetAsync(_targetInput, CancellationToken.None);
        State.Refresh();
        _targetInput = snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
        Snackbar.Add("Directive filed with the guards.", Severity.Success);
    }

    private Task ToggleDefender() => SetDefenderEnabled(!DefenderIsEnabled);

    private async Task SetDefenderEnabled(bool enabled)
    {
        if (!TryBeginWebsiteCommand(enabled ? "turn defender on" : "pause defender", bypassDebounce: true))
        {
            return;
        }

        try
        {
            await Defender.SetDefenderEnabledAsync(enabled, CancellationToken.None);
        }
        catch (ThermostatOperationSupersededException)
        {
            State.Refresh();
            Snackbar.Add("A newer defender switch action won; refreshed the live state.", Severity.Info);
            return;
        }
        State.Refresh();
        Snackbar.Add(enabled ? "Defender turned on." : "Defender paused.", Severity.Info);

        if (enabled)
        {
            return;
        }

        var turnOff = await DialogService.ShowMessageBoxAsync(
            "Turn off the real thermostat too?",
            "The defender is paused now. Turn the thermostat fully off, or leave it on parked at the stand-down setpoint so it barely runs?",
            yesText: "Turn thermostat off",
            cancelText: "Leave on (parked)");

        if (turnOff == true)
        {
            await TurnThermostatOffAfterGate();
            return;
        }

        try
        {
            if (await Defender.ParkThermostatForStandDownAsync(CancellationToken.None) is { } parked)
            {
                State.Refresh();
                Snackbar.Add(parked, Severity.Info);
            }
        }
        catch
        {
            // Parking is best-effort; a Home Assistant hiccup must not block standing down.
        }
    }

    private async Task StartSiesta(int minutes)
    {
        if (!TryBeginWebsiteCommand("start siesta"))
        {
            return;
        }

        (bool Started, string Message) start;
        try
        {
            start = await Defender.StartSiestaAsync(minutes, "manual", CancellationToken.None);
        }
        catch (ThermostatOperationSupersededException)
        {
            State.Refresh();
            Snackbar.Add("A newer siesta action won; refreshed the live state.", Severity.Info);
            return;
        }
        if (!start.Started)
        {
            Snackbar.Add(start.Message, Severity.Warning);
            State.Refresh();
            return;
        }

        State.Refresh();
        Snackbar.Add(start.Message, Severity.Success);
    }

    private async Task CancelSiesta()
    {
        if (!TryBeginWebsiteCommand("cancel siesta", bypassDebounce: true))
        {
            return;
        }

        (bool Cancelled, string Message) cancel;
        try
        {
            cancel = await Defender.CancelSiestaAsync("website", CancellationToken.None);
        }
        catch (ThermostatOperationSupersededException)
        {
            State.Refresh();
            Snackbar.Add("A newer siesta action won; refreshed the live state.", Severity.Info);
            return;
        }
        State.Refresh();
        Snackbar.Add(cancel.Message, cancel.Cancelled ? Severity.Info : Severity.Warning);
    }

    private Task RefreshReal() => RunThermostatAction(() => Defender.RefreshRealThermostatAsync(CancellationToken.None), "Thermostat refreshed.", "refresh thermostat", bypassDebounce: true);
    private Task ForceTarget() => RunThermostatAction(() => Defender.ForceTargetAsync(CancellationToken.None), "Exact target sent.", "force exact target");
    private Task ForceBoost() => RunThermostatAction(() => Defender.ForceCoolingBoostAsync(CancellationToken.None), "Cooling boost sent.", "force cooling");
    private Task RunEmergencyProtocol() => RunThermostatAction(
        () => Defender.ApplyEmergencyProtocolAsync(_emergencyProtocol, CancellationToken.None),
        "Emergency protocol started.",
        $"emergency {_emergencyProtocol}",
        bypassDebounce: !string.Equals(_emergencyProtocol, "too-cold", StringComparison.OrdinalIgnoreCase));
    private Task TurnThermostatOffAfterGate(string successMessage = "Thermostat turned off.") =>
        RunThermostatActionAfterGate(() => Defender.TurnThermostatOffAsync(CancellationToken.None), successMessage);

    private async Task TurnOffFromControls()
    {
        if (!TryBeginWebsiteCommand("stand down defender and turn thermostat off", bypassDebounce: true))
        {
            return;
        }

        // Persist the stand-down before the real off command. Otherwise the worker can see HVAC off
        // while containment is still enabled and Cool Mode Restore can immediately put it back in cool.
        try
        {
            await Defender.SetDefenderEnabledAsync(false, CancellationToken.None);
        }
        catch (ThermostatOperationSupersededException)
        {
            State.Refresh();
            Snackbar.Add("A newer defender switch action won; refreshed the live state.", Severity.Info);
            return;
        }
        State.Refresh();
        await TurnThermostatOffAfterGate("Defender stood down and thermostat turned off.");
    }

    private bool _learningHistory;
    private async Task LearnFromHistory()
    {
        if (_learningHistory)
        {
            return;
        }

        _learningHistory = true;
        try
        {
            var result = await Defender.LearnFromHistoryAsync(CancellationToken.None);
            State.Refresh();
            Snackbar.Add(result.Status, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"History learning failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _learningHistory = false;
        }
    }

    private async Task ApplyFanModeTo(string mode)
    {
        if (!FanModes.Contains(mode, StringComparer.OrdinalIgnoreCase))
        {
            Snackbar.Add("That fan mode is not advertised by the real Home Assistant climate entity.", Severity.Warning);
            return;
        }

        await RunThermostatAction(() => Defender.ForceFanModeAsync(mode, CancellationToken.None), $"Fan set to {mode}.", $"set fan to {mode}");
    }

    private bool TryBeginWebsiteCommand(string actionName, bool bypassDebounce = false)
    {
        var gate = StateStore.TryBeginWebsiteCommand(actionName, bypassDebounce);
        State.Refresh();
        if (gate.Accepted)
        {
            return true;
        }

        Snackbar.Add(gate.Message, Severity.Warning);
        return false;
    }

    private async Task RunThermostatAction(Func<Task> action, string successMessage, string actionName, bool bypassDebounce = false)
    {
        if (!TryBeginWebsiteCommand(actionName, bypassDebounce))
        {
            return;
        }

        await RunThermostatActionAfterGate(action, successMessage);
    }

    private async Task RunThermostatActionAfterGate(Func<Task> action, string successMessage)
    {
        try
        {
            await action();
            State.Refresh();
            if (!_targetDirty)
            {
                _targetInput = Snapshot?.TargetTemperatureCelsius ?? _targetInput;
            }

            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (ThermostatOperationSupersededException)
        {
            State.Refresh();
            Snackbar.Add("A newer thermostat action took priority; Home Assistant remains connected.", Severity.Info);
        }
        catch (ThermostatCommandRetryDeferredException ex)
        {
            State.Refresh();
            Snackbar.Add(ex.Message, Severity.Info);
        }
        catch (ThermostatCommandRejectedException ex)
        {
            State.Refresh();
            Snackbar.Add($"Home Assistant rejected the thermostat command: {ex.Message}", Severity.Error);
        }
        catch (HttpRequestException ex) when (ex.StatusCode is not null)
        {
            StateStore.RecordHomeAssistantRequestRejected(
                $"Home Assistant rejected the request ({(int)ex.StatusCode.Value}): {ex.Message}");
            State.Refresh();
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            StateStore.RecordHomeAssistantUnavailable($"Home Assistant error: {ex.Message}");
            State.Refresh();
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    public void Dispose() => State.Changed -= OnStateChanged;
}
