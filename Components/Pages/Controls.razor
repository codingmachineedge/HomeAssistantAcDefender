@page "/controls"
@implements IDisposable
@inject DefenderStateProvider State
@inject DefenderStateStore StateStore
@inject AcDefenderService Defender
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Controls - AC Defender</PageTitle>

<MudStack Spacing="3">
    <SectionCard Title="Defender"
                 Subtitle="@(Snapshot?.DefenderEnabled == true ? "Active" : "Paused")"
        Help="The switch turns the helper on or pauses it. Pausing offers to turn the real thermostat off.">
        <Actions>
            <MudButton Class="@DefenderToggleClass" Variant="Variant.Filled" Color="@DefenderToggleColor"
                       Size="Size.Large" StartIcon="@DefenderToggleIcon" OnClick="ToggleDefender">
                @DefenderToggleText
            </MudButton>
        </Actions>
        <ChildContent>
            @if (Snapshot?.WebsiteCommandDebounce.Active == true)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">@Snapshot.WebsiteCommandDebounce.Status</MudAlert>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="helper-text">No website lock active.</MudText>
            }
            @if (Snapshot?.FrontDoorKillSwitch.Active == true || Snapshot?.FrontDoorKillSwitch.PersonDetected == true)
            {
                <MudAlert Class="mt-2" Severity="Severity.Error" Variant="Variant.Filled" Dense="true">@Snapshot.FrontDoorKillSwitch.Status</MudAlert>
            }
        </ChildContent>
    </SectionCard>

    @if (Snapshot?.DefenderEnabled == true)
    {
    <SectionCard Title="Super Defender"
                 Subtitle="@(Snapshot?.SuperDefender.Active == true ? "Armed" : "Watching")"
                 Help="Detects repeated phone/Home Assistant thermostat changes and can tighten response without cutting Wi-Fi.">
        <Actions>
            <MudChip T="string" Color="@(Snapshot?.SuperDefender.BypassingQuietTiming == true ? Color.Error : Snapshot?.SuperDefender.Active == true ? Color.Warning : Color.Default)" Variant="Variant.Outlined" Size="Size.Small">
                @(Snapshot?.SuperDefender.BypassingQuietTiming == true ? "Strict" : Snapshot?.SuperDefender.Active == true ? "Armed" : "Ready")
            </MudChip>
        </Actions>
        <ChildContent>
            <MudText Typo="Typo.body2">@Snapshot?.SuperDefender.Status</MudText>
            <MudText Typo="Typo.caption" Class="helper-text">Last source: @(Snapshot?.SuperDefender.LastChangeSource ?? "none")</MudText>
            <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">@Snapshot?.SuperDefender.NetworkLockdownStatus</MudAlert>
        </ChildContent>
    </SectionCard>

    <SectionCard Title="Desired-State Enforcer"
                 Subtitle="@EnforcerSubtitle"
                 Help="Makes your chosen AC state win automatically. Configure it on the Settings page (Desired-State Enforcer).">
        <Actions>
            <MudChip T="string" Color="@EnforcerChipColor" Variant="Variant.Outlined" Size="Size.Small">@EnforcerChipText</MudChip>
        </Actions>
        <ChildContent>
            @if (Snapshot?.Enforcer is { } enforcer)
            {
                <MudText Typo="Typo.body2">@enforcer.Status</MudText>
                @if (enforcer.Enabled)
                {
                    <MudText Typo="Typo.caption" Class="helper-text">
                        Holding @enforcer.DesiredTargetCelsius.ToString("0.0") C ·
                        overrides @enforcer.RecentOverrideCount ·
                        asserts @enforcer.RecentAssertCount ·
                        last changed by @enforcer.LastChangeUser
                    </MudText>
                    <MudText Typo="Typo.caption" Class="helper-text">
                        Interference model: @(enforcer.LearningActive ? enforcer.InterferenceProbability.ToString("0.00") : "learning")
                    </MudText>
                    @if (enforcer.Escalated)
                    {
                        <MudAlert Class="mt-2" Severity="Severity.Error" Variant="Variant.Filled" Dense="true">Repeated interference detected — enforcing firmly.</MudAlert>
                    }
                }
                else
                {
                    <MudAlert Class="mt-2" Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">Off. Turn it on under Settings → Desired-State Enforcer to make your chosen state win automatically.</MudAlert>
                }
            }
        </ChildContent>
    </SectionCard>

    <SectionCard Title="Alectra Peak Power Saver"
                 Subtitle="@(Snapshot?.PeakPowerSaver.Active == true ? "Saving" : "Watching")"
                 Help="Uses real Alectra Hui power, price, and TOU sensors to hold only safe cooling during peak or high-load periods.">
        <Actions>
            <MudChip T="string" Color="@(Snapshot?.PeakPowerSaver.Holding == true ? Color.Warning : Snapshot?.PeakPowerSaver.Active == true ? Color.Info : Color.Default)" Variant="Variant.Outlined" Size="Size.Small">
                @(Snapshot?.PeakPowerSaver.Holding == true ? "Holding" : Snapshot?.PeakPowerSaver.Active == true ? "Peak" : "Ready")
            </MudChip>
        </Actions>
        <ChildContent>
            <MudText Typo="Typo.body2">@Snapshot?.PeakPowerSaver.Status</MudText>
            <MudText Typo="Typo.caption" Class="helper-text">
                Power @(Snapshot?.PeakPowerSaver.CurrentPowerKilowatts?.ToString("0.00") ?? "--") kW ·
                Price @(Snapshot?.PeakPowerSaver.CurrentPriceCentsPerKwh?.ToString("0.0") ?? "--") c/kWh ·
                TOU @(Snapshot?.PeakPowerSaver.TouPeriod ?? "--")
            </MudText>
        </ChildContent>
    </SectionCard>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <SectionCard Title="Temp I want" Subtitle="My number" Help="Yours until you change it — the defenders hold this and never touch it themselves. Tap − / + to dial it in, just like a real thermostat.">
                <MudGrid Spacing="2">
                    <MudItem xs="12" Class="d-flex justify-center">
                        <ThermostatDial Target="_targetInput"
                                        Current="Snapshot?.HomeAssistantThermostat?.CurrentTemperatureCelsius"
                                        Mode="@(Snapshot?.HomeAssistantThermostat?.HvacMode ?? "cool")"
                                        Action="@(Snapshot?.HomeAssistantThermostat?.HvacAction ?? "idle")"
                                        Min="16" Max="30" Step="0.5"
                                        TargetChanged="OnTargetInputChanged" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudNumericField T="double" Value="_targetInput" ValueChanged="OnTargetInputChanged" Label="Or type it"
                                         HelperText="Type the temperature you want." Variant="Variant.Outlined"
                                         Min="10" Max="35" Step="0.1" Adornment="Adornment.End" AdornmentText="C" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyTarget" StartIcon="@Icons.Material.Filled.Check">Apply</MudButton>
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="GenerateTarget" StartIcon="@Icons.Material.Filled.AutoAwesome">Generate</MudButton>
                    </MudItem>
                </MudGrid>
            </SectionCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <SectionCard Title="Fan" Help="Send a fan mode to the real thermostat.">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudSelect T="string" @bind-Value="_fanMode" Label="Fan mode" HelperText="Pick how the fan should blow air." Variant="Variant.Outlined">
                            @foreach (var mode in FanModes)
                            {
                                <MudSelectItem T="string" Value="@mode">@mode</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ApplyFanMode" StartIcon="@Icons.Material.Filled.Air">Set fan</MudButton>
                    </MudItem>
                </MudGrid>
            </SectionCard>
        </MudItem>
    </MudGrid>

    <SectionCard Title="Real thermostat actions" Help="These buttons send real Home Assistant service calls now.">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshReal" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
                <MudText Typo="Typo.caption" Class="helper-text">Ask Home Assistant for the newest reading.</MudText>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ForceTarget" StartIcon="@Icons.Material.Filled.TrackChanges">Force target</MudButton>
                <MudText Typo="Typo.caption" Class="helper-text">Set the thermostat to the exact target now.</MudText>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ForceBoost" StartIcon="@Icons.Material.Filled.AcUnit">Force cooling</MudButton>
                <MudText Typo="Typo.caption" Class="helper-text">Use the room-minus-1 C cooling push right now.</MudText>
            </MudItem>
        </MudGrid>
    </SectionCard>
    }
    else
    {
        <SectionCard Title="Guard post standby"
                     Subtitle="Defender is paused"
                     Help="The live boards are covered with a tarp. Tap Activate Defender when the tiny shift is back on duty.">
            <MudButton Class="@DefenderToggleClass" Variant="Variant.Filled" Color="@DefenderToggleColor"
                       Size="Size.Large" StartIcon="@DefenderToggleIcon" OnClick="ToggleDefender">
                @DefenderToggleText
            </MudButton>
        </SectionCard>
    }

    <SectionCard Title="Emergency" Help="Urgent quiet actions. These bypass the website lock.">
        <MudGrid Spacing="2">
            <MudItem xs="12" md="7">
                <MudSelect T="string" @bind-Value="_emergencyProtocol" Label="Emergency protocol" HelperText="@EmergencyProtocolHelp" Variant="Variant.Outlined">
                    @foreach (var option in EmergencyProtocols)
                    {
                        <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="5" Class="d-flex align-center">
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Error" OnClick="RunEmergencyProtocol" StartIcon="@Icons.Material.Filled.ReportProblem">Run emergency</MudButton>
            </MudItem>
        </MudGrid>
        @if (Snapshot?.Emergency.Active == true)
        {
            <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined">@Snapshot.Emergency.Status</MudAlert>
        }
    </SectionCard>

    <SectionCard Title="Learning" Help="A machine-learning trainer learns automatically from the someone-upset button and your real Home Assistant thermostat history (retrains in the background; no action needed).">
        <MudStack Spacing="2">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LearnFromHistory" Disabled="_learningHistory" StartIcon="@Icons.Material.Filled.ModelTraining">
                @(_learningHistory ? "Retraining…" : "Retrain from history now")
            </MudButton>
            @if (Snapshot is { } learnSnapshot)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">@learnSnapshot.HistoryLearning.Status</MudAlert>
                @if (learnSnapshot.LearningModel is { } ml)
                {
                    <MudAlert Severity="@(ml.AngerModelTrained || ml.ComfortModelTrained ? Severity.Success : Severity.Normal)" Variant="Variant.Outlined" Dense="true">
                        ML trainer — anger model: @(ml.AngerModelTrained ? $"trained ({ml.AngerPositiveSamples} upset / {ml.AngerNegativeSamples} benign, log-loss {ml.AngerLogLoss:0.00})" : "gathering data");
                        comfort model: @(ml.ComfortModelTrained ? $"trained ({ml.ComfortSamples} samples, RMSE {ml.ComfortRmse:0.0} C)" : "gathering data").
                        @if (ml.TrainedAt is { } trainedAt)
                        {
                            <text> Last trained @trainedAt.ToLocalTime().ToString("MMM d HH:mm").</text>
                        }
                    </MudAlert>
                }
                <MudAlert Severity="@(learnSnapshot.AngerLearning.CurrentHourSensitivity > 0 ? Severity.Warning : Severity.Normal)" Variant="Variant.Outlined" Dense="true">
                    Anger learning: @learnSnapshot.AngerLearning.EventCount upset press(es) recorded.
                    @if (learnSnapshot.AngerLearning.CurrentHourSensitivity > 0)
                    {
                        <text> This hour is @(((int)Math.Round(learnSnapshot.AngerLearning.CurrentHourSensitivity * 100)))% sensitive, adding @learnSnapshot.AngerLearning.ExtraGraceMinutes min of hands-off grace.</text>
                    }
                </MudAlert>
            }
        </MudStack>
    </SectionCard>
</MudStack>

@code {
    private double _targetInput = 22.0;
    private bool _targetDirty;
    private string? _fanMode;
    private string _emergencyProtocol = "suspicion";

    private static readonly (string Value, string Label, string Help)[] EmergencyProtocols =
    [
        ("too-cold", "Too cold", "Pauses the defender and turns the real thermostat off."),
        ("someone-upset", "Someone upset", "Starts quiet observe-only mode so wall changes are not fought."),
        ("suspicion", "Suspicion quiet", "Starts a longer quiet window where corrections stand down but readings continue.")
    ];

    private DefenderSnapshot? Snapshot => State.Snapshot;
    private string EmergencyProtocolHelp => EmergencyProtocols.FirstOrDefault(o => o.Value == _emergencyProtocol).Help ?? "Pick an emergency action.";

    private string EnforcerSubtitle => Snapshot?.Enforcer switch
    {
        { Enabled: false } => "Off",
        { Escalated: true } => "Escalated",
        { Active: true, Stealth: true } => "Enforcing (stealth)",
        { Active: true } => "Enforcing",
        { Enabled: true } => "Watching",
        _ => "Off"
    };
    private string EnforcerChipText => EnforcerSubtitle;
    private Color EnforcerChipColor => Snapshot?.Enforcer switch
    {
        { Enabled: false } => Color.Default,
        { Escalated: true } => Color.Error,
        { Active: true } => Color.Warning,
        _ => Color.Success
    };
    private bool DefenderIsEnabled => Snapshot?.DefenderEnabled == true;
    private string DefenderToggleText => DefenderIsEnabled ? "Stand Down Defender" : "Activate Defender";
    private string DefenderToggleIcon => DefenderIsEnabled ? Icons.Material.Filled.Shield : Icons.Material.Filled.PowerSettingsNew;
    private Color DefenderToggleColor => DefenderIsEnabled ? Color.Success : Color.Error;
    private string DefenderToggleClass => DefenderIsEnabled ? "defender-toggle defender-toggle--active" : "defender-toggle defender-toggle--paused";

    private IReadOnlyList<string> FanModes
    {
        get
        {
            var modes = Snapshot?.HomeAssistantThermostat?.AvailableFanModes;
            if (modes is { Count: > 0 })
            {
                return modes;
            }

            return string.IsNullOrWhiteSpace(Snapshot?.HomeAssistantThermostat?.FanMode)
                ? ["auto"]
                : [Snapshot.HomeAssistantThermostat.FanMode!];
        }
    }

    protected override void OnInitialized()
    {
        _targetInput = Snapshot?.TargetTemperatureCelsius ?? 22.0;
        _fanMode = Snapshot?.HomeAssistantThermostat?.FanMode ?? FanModes.FirstOrDefault();
        State.Changed += OnStateChanged;
    }

    private void OnStateChanged()
    {
        if (!_targetDirty && Snapshot is not null)
        {
            _targetInput = Snapshot.TargetTemperatureCelsius;
        }

        InvokeAsync(StateHasChanged);
    }

    private void OnTargetInputChanged(double value)
    {
        _targetInput = value;
        _targetDirty = true;
    }

    private void GenerateTarget()
    {
        if (!TryBeginWebsiteCommand("generate target", bypassDebounce: true))
        {
            return;
        }

        var snapshot = StateStore.GenerateTarget();
        State.Refresh();
        _targetInput = snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
        Snackbar.Add("Generated a new target.", Severity.Success);
    }

    private void ApplyTarget()
    {
        if (!TryBeginWebsiteCommand("set target", bypassDebounce: true))
        {
            return;
        }

        var snapshot = StateStore.SetTarget(_targetInput);
        State.Refresh();
        _targetInput = snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
        Snackbar.Add("Target saved.", Severity.Success);
    }

    private Task ToggleDefender() => SetDefenderEnabled(!DefenderIsEnabled);

    private async Task SetDefenderEnabled(bool enabled)
    {
        if (!TryBeginWebsiteCommand(enabled ? "turn defender on" : "pause defender", bypassDebounce: true))
        {
            return;
        }

        StateStore.SetDefenderEnabled(enabled);
        State.Refresh();
        Snackbar.Add(enabled ? "Defender turned on." : "Defender paused.", Severity.Info);

        if (enabled)
        {
            return;
        }

        var turnOff = await DialogService.ShowMessageBoxAsync(
            "Turn off the real thermostat too?",
            "The defender is paused now. Do you also want to send a real Home Assistant command to turn the thermostat off?",
            yesText: "Turn thermostat off",
            cancelText: "Leave thermostat on");

        if (turnOff == true)
        {
            await TurnThermostatOff();
        }
    }

    private Task RefreshReal() => RunThermostatAction(() => Defender.RefreshRealThermostatAsync(CancellationToken.None), "Thermostat refreshed.", "refresh thermostat", bypassDebounce: true);
    private Task ForceTarget() => RunThermostatAction(() => Defender.ForceTargetAsync(CancellationToken.None), "Exact target sent.", "force exact target");
    private Task ForceBoost() => RunThermostatAction(() => Defender.ForceCoolingBoostAsync(CancellationToken.None), "Cooling boost sent.", "force cooling");
    private Task RunEmergencyProtocol() => RunThermostatAction(
        () => Defender.ApplyEmergencyProtocolAsync(_emergencyProtocol, CancellationToken.None),
        "Emergency protocol started.",
        $"emergency {_emergencyProtocol}",
        bypassDebounce: !string.Equals(_emergencyProtocol, "too-cold", StringComparison.OrdinalIgnoreCase));
    private Task TurnThermostatOff(bool bypassDebounce = false) => RunThermostatAction(() => Defender.TurnThermostatOffAsync(CancellationToken.None), "Thermostat turned off.", "turn thermostat off", bypassDebounce);

    private bool _learningHistory;
    private async Task LearnFromHistory()
    {
        if (_learningHistory)
        {
            return;
        }

        _learningHistory = true;
        try
        {
            var result = await Defender.LearnFromHistoryAsync(CancellationToken.None);
            State.Refresh();
            Snackbar.Add(result.Status, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"History learning failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _learningHistory = false;
        }
    }

    private async Task ApplyFanMode()
    {
        if (string.IsNullOrWhiteSpace(_fanMode))
        {
            Snackbar.Add("Pick a fan mode first.", Severity.Warning);
            return;
        }

        await RunThermostatAction(() => Defender.ForceFanModeAsync(_fanMode, CancellationToken.None), "Fan mode sent.", $"set fan to {_fanMode}");
    }

    private bool TryBeginWebsiteCommand(string actionName, bool bypassDebounce = false)
    {
        var gate = StateStore.TryBeginWebsiteCommand(actionName, bypassDebounce);
        State.Refresh();
        if (gate.Accepted)
        {
            return true;
        }

        Snackbar.Add(gate.Message, Severity.Warning);
        return false;
    }

    private async Task RunThermostatAction(Func<Task> action, string successMessage, string actionName, bool bypassDebounce = false)
    {
        if (!TryBeginWebsiteCommand(actionName, bypassDebounce))
        {
            return;
        }

        try
        {
            await action();
            State.Refresh();
            if (!_targetDirty)
            {
                _targetInput = Snapshot?.TargetTemperatureCelsius ?? _targetInput;
            }

            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception ex)
        {
            StateStore.RecordHomeAssistantUnavailable($"Home Assistant error: {ex.Message}");
            State.Refresh();
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    public void Dispose() => State.Changed -= OnStateChanged;
}
