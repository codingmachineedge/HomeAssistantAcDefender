@page "/settings/repository"
@page "/repository"
@inject DefenderStateStore StateStore
@inject ISnackbar Snackbar

<PageTitle>Settings Repository — SCP AC Defender</PageTitle>

<div class="ops-dash-stack">

    @* ── repo status bar ── *@
    <div class="ops-repo-bar">
        <div class="ops-repo-bar__icon" aria-hidden="true">⇄</div>
        <div class="ops-repo-bar__id">
            <div class="ops-repo-bar__title">@RepoName <span class="ops-repo-bar__origin">· @(_repo?.RepositoryPath ?? "local settings repository")</span></div>
            <div class="ops-repo-chips">
                <span class="ops-repo-chip ops-repo-chip--branch">⎇ @BranchText</span>
                @if (_repo is { Clean: false })
                {
                    <span class="ops-repo-chip ops-repo-chip--dirty">● @(_repo.Files.Count) FILE@(_repo.Files.Count == 1 ? "" : "S") MODIFIED</span>
                }
                else
                {
                    <span class="ops-repo-chip ops-repo-chip--clean">✓ CLEAN</span>
                }
                <span class="ops-repo-chip">@(_repo?.History.Count ?? 0) COMMITS</span>
                <span class="ops-repo-chip">HEAD @HeadShort</span>
            </div>
        </div>
        <div class="ops-repo-actions">
            <button class="ops-btn" @onclick="Refresh">⟳ REFRESH</button>
            <button class="ops-btn ops-btn--outline" @onclick="CommitNow">⇡ COMMIT SNAPSHOT</button>
            <button class="ops-btn ops-btn--danger" disabled="@(!CanUndo)" @onclick="UndoLast">↺ UNDO LAST</button>
        </div>
    </div>

    @if (_repo?.Error is { Length: > 0 } error)
    {
        <div class="ops-alert-row ops-alert-row--bad">
            <span class="ops-alert-row__glyph" aria-hidden="true">⚠</span>
            <span class="ops-alert-row__tag">GIT</span>
            <span class="ops-alert-row__text">@error</span>
        </div>
    }
    else if (_repo is { Available: false } or { Initialized: false })
    {
        <div class="ops-alert-row ops-alert-row--warn">
            <span class="ops-alert-row__glyph" aria-hidden="true">◔</span>
            <span class="ops-alert-row__tag">STATUS</span>
            <span class="ops-alert-row__text">@RepoStatus</span>
        </div>
    }

    <div class="ops-repo-grid">
        @* ── left: uncommitted changes + commit ── *@
        <div class="@(_repo is { Clean: false } ? "ops-panel ops-panel--pad ops-repo-pending ops-repo-pending--dirty" : "ops-panel ops-panel--pad ops-repo-pending")">
            <div class="ops-panel__label" style="@(_repo is { Clean: false } ? "color: var(--warn);" : "")">UNCOMMITTED STANDING-ORDER CHANGES — settings.json</div>
            @if (_repo is { Clean: false, Files.Count: > 0 })
            {
                <pre class="ops-repo-diff">@foreach (var file in _repo.Files)
{<span class="ops-repo-diff__line ops-repo-diff__line--@DiffKind(file.Code)">@file.Code  @file.Path
</span>}</pre>
                <input class="ops-input ops-commit-input" value="@_commitMessage" @oninput="OnCommitMessageChanged"
                       placeholder="Commit message… (be honest, git remembers)" aria-label="Commit message" />
                <button class="ops-commit-btn" @onclick="CommitWithMessage">⇡ COMMIT &amp; SAVE</button>
            }
            else
            {
                <div class="ops-repo-clean">
                    Working tree clean. ✨<br />
                    Every standing order matches HEAD. The guards find this deeply satisfying.
                </div>
            }
        </div>

        @* ── right: commit history ── *@
        <div class="ops-panel ops-panel--pad" style="min-width: 0;">
            <div class="ops-panel__label">COMMIT HISTORY — ⎇ @BranchText</div>
            <input class="ops-input" style="width: 100%; box-sizing: border-box; margin: 0 0 10px 0;"
                   value="@_historySearch" @oninput="OnHistorySearchChanged"
                   placeholder="SEARCH COMMITS…" aria-label="Search commits" />
            <div class="ops-commit-list">
                @if (FilteredHistory.Count > 0)
                {
                    @for (var i = 0; i < FilteredHistory.Count; i++)
                    {
                        var commit = FilteredHistory[i];
                        var newest = i == 0 && string.IsNullOrWhiteSpace(_historySearch);
                        <div class="@(newest ? "ops-commit-row ops-commit-row--newest" : "ops-commit-row")">
                            <div class="ops-commit-row__top">
                                <span class="ops-commit-row__hash">@commit.ShortHash</span>
                                <span class="ops-commit-row__msg">@commit.Message</span>
                                <span class="ops-commit-row__when">@CommitWhen(commit)</span>
                            </div>
                            <div class="ops-commit-row__meta">
                                settings.json snapshot
                                @if (CanRestore)
                                {
                                    <button class="ops-commit-row__restore" @onclick="@(() => Restore(commit))">↩ restore</button>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="helper-text">No settings commits match.</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private SettingsRepositoryState? _repo;
    private string _historySearch = "";
    private string _commitMessage = "";

    protected override void OnInitialized() => Refresh();

    private void Refresh() => _repo = StateStore.GetSettingsRepositoryState();

    private void OnHistorySearchChanged(ChangeEventArgs e) => _historySearch = e.Value?.ToString() ?? "";
    private void OnCommitMessageChanged(ChangeEventArgs e) => _commitMessage = e.Value?.ToString() ?? "";

    private void CommitNow()
    {
        ShowResult(StateStore.CommitSettingsRepositorySnapshot("Manual settings repository snapshot"));
        Refresh();
    }

    private void CommitWithMessage()
    {
        var message = string.IsNullOrWhiteSpace(_commitMessage)
            ? "tweak standing orders (no comment. do not ask.)"
            : _commitMessage.Trim();
        ShowResult(StateStore.CommitSettingsRepositorySnapshot(message));
        _commitMessage = "";
        Refresh();
    }

    private void UndoLast()
    {
        ShowResult(StateStore.UndoLastSettingsRepositoryCommit());
        Refresh();
    }

    private void Restore(SettingsRepositoryCommit commit)
    {
        ShowResult(StateStore.RestoreSettingsRepositoryCommit(commit.Hash));
        Refresh();
    }

    private void ShowResult(SettingsRepositoryActionResult result) =>
        Snackbar.Add(result.Message, result.Success ? Severity.Success : Severity.Warning);

    private IReadOnlyList<SettingsRepositoryCommit> FilteredHistory
    {
        get
        {
            var history = _repo?.History ?? [];
            if (string.IsNullOrWhiteSpace(_historySearch))
            {
                return history;
            }

            var terms = _historySearch.Split(' ', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
            return history
                .Where(commit => terms.All(term =>
                    commit.ShortHash.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || commit.Timestamp.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || commit.Message.Contains(term, StringComparison.OrdinalIgnoreCase)))
                .ToArray();
        }
    }

    private bool CanUndo => _repo is { Available: true, Initialized: true, Clean: true, History.Count: > 1 };
    private bool CanRestore => _repo is { Available: true, Initialized: true, Clean: true };

    private string RepoName => _repo?.RepositoryPath is { Length: > 0 } path
        ? System.IO.Path.GetFileName(path.TrimEnd('/', '\\')) + ".git"
        : "acdefender-settings.git";

    private string RepoStatus => _repo?.Status ?? "Loading";
    private string BranchText => string.IsNullOrWhiteSpace(_repo?.Branch) ? "main" : _repo.Branch;
    private string HeadShort => string.IsNullOrWhiteSpace(_repo?.Head) ? "—" : _repo.Head;

    private static string DiffKind(string code) => code.Trim() switch
    {
        "A" or "??" => "add",
        "D" => "del",
        _ => "ctx"
    };

    private static string CommitWhen(SettingsRepositoryCommit commit) =>
        DateTimeOffset.TryParse(commit.Timestamp, out var parsed) ? Format.RelativeTime(parsed) : commit.Timestamp;
}
