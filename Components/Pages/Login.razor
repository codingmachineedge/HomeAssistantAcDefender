@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using System.Security.Cryptography
@using System.Text
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject TwoFactorAuth TwoFactorAuth
@inject GoogleDeviceLogin GoogleLogin

@if (_error is not null)
{
    <div class="login-error">
        <svg class="login-error-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
        <span>@_error</span>
    </div>
}

@if (_formMode == "owner")
{
    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <div class="login-mark" aria-hidden="true">❆</div>
                <h1 class="login-title">AC DEFENDER</h1>
                <p class="login-code">TACTICAL OPS // FIRST BOOT</p>
                <p class="login-subtitle">Create the owner account. This first account is the owner. Later sign-ups need a registration code you set in Standing Orders.</p>
            </div>

            <form method="post" class="login-form" data-enhance="false" @formname="ownersignup">
                <AntiforgeryToken />
                <input type="hidden" name="action" value="ownersignup" />
                <div class="input-group"><input type="text" name="username" class="text-input" placeholder="Username" aria-label="Username" autocomplete="username" required autofocus /></div>
                <div class="input-group"><input type="password" name="password" class="text-input" placeholder="Password (at least 6 characters)" aria-label="Password, at least 6 characters" autocomplete="new-password" minlength="6" required /></div>
                <div class="input-group"><input type="password" name="confirmPassword" class="text-input" placeholder="Confirm password" aria-label="Confirm password" autocomplete="new-password" minlength="6" required /></div>
                <div class="login-options">
                    <label class="option-label"><input type="checkbox" name="keepSignedIn" value="true" checked /><span>Keep me signed in</span></label>
                </div>
                <button type="submit" class="login-submit">Create owner account</button>
            </form>
        </div>
    </div>
}
else if (_formMode == "signup")
{
    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <div class="login-mark" aria-hidden="true">❆</div>
                <h1 class="login-title">AC DEFENDER</h1>
                <p class="login-code">TACTICAL OPS // RECRUITMENT</p>
                <p class="login-subtitle">Create an account. Ask the owner for the registration code.</p>
            </div>

            <form method="post" class="login-form" data-enhance="false" @formname="signup">
                <AntiforgeryToken />
                <input type="hidden" name="action" value="signup" />
                <div class="input-group"><input type="text" name="username" class="text-input" placeholder="Username" aria-label="Username" autocomplete="username" required autofocus /></div>
                <div class="input-group"><input type="password" name="password" class="text-input" placeholder="Password (at least 6 characters)" aria-label="Password, at least 6 characters" autocomplete="new-password" minlength="6" required /></div>
                <div class="input-group"><input type="password" name="confirmPassword" class="text-input" placeholder="Confirm password" aria-label="Confirm password" autocomplete="new-password" minlength="6" required /></div>
                <div class="input-group"><input type="text" name="registrationCode" class="text-input" placeholder="Registration code" aria-label="Registration code" required /></div>
                <div class="login-options">
                    <label class="option-label"><input type="checkbox" name="keepSignedIn" value="true" checked /><span>Keep me signed in</span></label>
                </div>
                <button type="submit" class="login-submit">Create account</button>
            </form>
            <a href="/login" style="display:block;text-align:center;margin-top:14px;color:#3ddc97;font-size:0.72rem;letter-spacing:0.08em;text-decoration:none;">Back to sign in</a>
        </div>
    </div>
}
else if (_formMode == "google")
{
    @* Device-flow wait screen: the meta refresh re-GETs this page every few seconds; each GET polls
       Google once (rate-limited server-side) until the code is approved, declined, or expires. *@
    <meta http-equiv="refresh" content="5">
    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <div class="login-mark" aria-hidden="true">❆</div>
                <h1 class="login-title">AC DEFENDER</h1>
                <p class="login-code">TACTICAL OPS // GOOGLE HANDSHAKE</p>
                <p class="login-subtitle">On any device, open the link below and enter this code with the Google account on the defender's allow-list.</p>
            </div>
            <div class="google-code" aria-label="Google device code">@_googleUserCode</div>
            <a class="google-link" href="@_googleVerificationUrl" target="_blank" rel="noopener">@_googleVerificationUrl</a>
            <p class="google-wait">⟳ Standing by — this page checks with Google every few seconds…</p>
            <a href="/login?googlecancel=1" style="display:block;text-align:center;margin-top:14px;color:#6d7c86;font-size:0.72rem;letter-spacing:0.08em;text-decoration:none;">Cancel and go back</a>
        </div>
    </div>
}
else
{
    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <div class="login-mark" aria-hidden="true">❆</div>
                <h1 class="login-title">AC DEFENDER</h1>
                <p class="login-code">TACTICAL OPS // GUARD POST</p>
                <p class="login-subtitle">Identify yourself to enter the command tent.</p>
            </div>

            <form method="post" class="login-form" data-enhance="false" @formname="login">
                <AntiforgeryToken />
                <input type="hidden" name="action" value="login" />
                <div class="input-group"><input type="text" name="username" class="text-input" placeholder="Username" aria-label="Username" autocomplete="username" required autofocus /></div>
                <div class="input-group"><input type="password" name="password" class="text-input" placeholder="Password" aria-label="Password" autocomplete="current-password" required /></div>
                <div class="login-options">
                    <label class="option-label"><input type="checkbox" name="keepSignedIn" value="true" checked /><span>Keep me signed in</span></label>
                </div>
                <button type="submit" class="login-submit">Sign in</button>
            </form>

            @if (GoogleLogin.Enabled)
            {
                <div class="login-divider" style="margin:16px 0 12px;"><span>or</span></div>
                <form method="post" class="login-form" data-enhance="false" @formname="googlestart">
                    <AntiforgeryToken />
                    <input type="hidden" name="action" value="googlestart" />
                    <div class="login-options">
                        <label class="option-label"><input type="checkbox" name="keepSignedIn" value="true" checked /><span>Keep me signed in</span></label>
                    </div>
                    <button type="submit" class="login-submit login-submit--google">
                        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="#4285F4" d="M23.5 12.3c0-.9-.1-1.5-.3-2.2H12v4.1h6.5c-.1 1.1-.8 2.7-2.4 3.8l3.7 2.9c2.3-2.1 3.7-5.1 3.7-8.6z"/><path fill="#34A853" d="M12 24c3.2 0 6-1.1 7.9-2.9l-3.7-2.9c-1 .7-2.4 1.2-4.2 1.2-3.2 0-6-2.1-6.9-5.1L1.2 17.2C3.2 21.2 7.3 24 12 24z"/><path fill="#FBBC05" d="M5.1 14.3c-.2-.7-.4-1.5-.4-2.3s.1-1.6.4-2.3L1.2 6.8C.4 8.4 0 10.1 0 12s.4 3.6 1.2 5.2l3.9-2.9z"/><path fill="#EA4335" d="M12 4.6c1.8 0 3 .8 3.7 1.4l2.7-2.7C16.5 1.2 14.2 0 12 0 7.3 0 3.2 2.8 1.2 6.8l3.9 2.9c.9-3 3.7-5.1 6.9-5.1z"/></svg>
                        Sign in with Google
                    </button>
                </form>
            }
            <a href="/login?signup=1" style="display:block;text-align:center;margin-top:14px;color:#3ddc97;font-size:0.72rem;letter-spacing:0.08em;text-decoration:none;">Create an account</a>
        </div>
    </div>
}

<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #07090c;
        background-image: repeating-linear-gradient(0deg, #1d2731 0 1px, transparent 1px 34px), repeating-linear-gradient(90deg, #1d2731 0 1px, transparent 1px 34px);
        padding: 24px;
        font-family: 'JetBrains Mono', Consolas, monospace;
    }

    .login-card {
        width: 100%;
        max-width: 420px;
        padding: 34px 30px 28px;
        background: #0d1116;
        border: 1px solid #2a3742;
        box-shadow: 0 12px 44px rgba(0, 0, 0, 0.6);
    }

    .onboarding .login-card {
        max-width: 460px;
    }

    .login-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .login-mark {
        width: 40px;
        height: 40px;
        margin: 0 auto 12px auto;
        border: 2px solid #3ddc97;
        border-radius: 4px;
        display: grid;
        place-items: center;
        color: #3ddc97;
        font-weight: 800;
        font-size: 18px;
    }

    .login-title {
        color: #d9e2e6;
        font-family: 'Archivo', sans-serif;
        font-weight: 900;
        font-size: 1.3rem;
        letter-spacing: 0.1em;
        margin-bottom: 6px;
    }

    .login-code {
        color: #3ddc97;
        font-size: 0.6rem;
        letter-spacing: 0.28em;
        margin-bottom: 10px;
    }

    .login-subtitle {
        color: #6d7c86;
        font-size: 0.72rem;
        line-height: 1.6;
    }

    .login-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .input-group {
        position: relative;
    }

    .code-input {
        width: 100%;
        padding: 14px 16px;
        font-size: 1.5rem;
        letter-spacing: 0.25em;
        font-family: 'SF Mono', 'Cascadia Code', Consolas, monospace;
        text-align: center;
        background: #0f1614;
        border: 1px solid #2a3832;
        border-radius: 8px;
        color: #e7f6ef;
        outline: none;
        transition: border-color 0.2s;
    }

    .code-input:focus {
        border-color: #46c1a7;
        box-shadow: 0 0 0 2px rgba(70,193,167,0.2);
    }

    .code-input::placeholder {
        color: #4a5c54;
    }

    .text-input {
        width: 100%;
        padding: 12px 14px;
        font-size: 0.85rem;
        font-family: 'JetBrains Mono', Consolas, monospace;
        letter-spacing: 0.04em;
        background: #131a21;
        border: 1px solid #2a3742;
        color: #d9e2e6;
        outline: none;
        transition: border-color 0.2s;
    }

    .text-input:focus {
        border-color: #3ddc97;
        box-shadow: 0 0 0 2px rgba(61, 220, 151, 0.15);
    }

    .text-input::placeholder {
        color: #6d7c86;
    }

    .password-setup {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 12px;
        background: #0f1614;
        border-radius: 8px;
        border: 1px dashed #2a3832;
    }

    .password-setup-label {
        color: #9fb0a8;
        font-size: 0.78rem;
        margin-bottom: 2px;
    }

    .login-divider {
        display: flex;
        align-items: center;
        text-align: center;
        color: #6b7d75;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .login-divider::before,
    .login-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #2a3832;
    }

    .login-divider span {
        padding: 0 12px;
    }

    .login-options {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 4px 0;
    }

    .option-label {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #6d7c86;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        cursor: pointer;
        user-select: none;
    }

    .option-label input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: #3ddc97;
        cursor: pointer;
    }

    .login-submit {
        margin-top: 8px;
        padding: 13px;
        font-size: 0.75rem;
        font-weight: 800;
        font-family: 'JetBrains Mono', Consolas, monospace;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #07090c;
        background: #3ddc97;
        border: none;
        cursor: pointer;
        transition: filter 0.2s;
    }

    .login-submit:hover {
        filter: brightness(1.12);
    }

    .login-submit:active {
        filter: brightness(0.92);
    }

    .login-error {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 24px;
        background: #2b0d09;
        border-bottom: 2px solid #ff5c47;
        color: #ff5c47;
        font-family: 'JetBrains Mono', Consolas, monospace;
        font-size: 0.75rem;
        letter-spacing: 0.06em;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    .login-error-icon {
        width: 20px;
        height: 20px;
    }

    .login-submit--google {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        background: #d9e2e6;
    }

    .google-code {
        text-align: center;
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: 0.3em;
        color: #3ddc97;
        background: #0f1614;
        border: 1px dashed #2a3832;
        padding: 18px 10px;
        margin-bottom: 14px;
        user-select: all;
    }

    .google-link {
        display: block;
        text-align: center;
        color: #d9e2e6;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        margin-bottom: 16px;
    }

    .google-wait {
        text-align: center;
        color: #6d7c86;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
    }

    .qr-container {
        display: flex;
        justify-content: center;
        padding: 16px;
        background: #ffffff;
        border-radius: 12px;
        border: 2px solid #46c1a7;
    }

    .qr-container svg {
        display: block;
        max-width: 100%;
        height: auto;
    }

    .manual-key {
        text-align: center;
        padding: 12px;
        background: #0f1614;
        border-radius: 8px;
        border: 1px solid #2a3832;
    }

    .manual-key-label {
        color: #9fb0a8;
        font-size: 0.8rem;
        margin-bottom: 4px;
    }

    .manual-key-value {
        font-family: 'SF Mono', 'Cascadia Code', Consolas, monospace;
        font-size: 0.95rem;
        color: #46c1a7;
        word-break: break-all;
        letter-spacing: 0.1em;
    }
</style>

@code {
    [SupplyParameterFromForm(Name = "action")] public string? ActionForm { get; set; }
    [SupplyParameterFromForm(Name = "username")] public string? UsernameForm { get; set; }
    [SupplyParameterFromForm(Name = "password")] public string? PasswordForm { get; set; }
    [SupplyParameterFromForm(Name = "confirmPassword")] public string? ConfirmPasswordForm { get; set; }
    [SupplyParameterFromForm(Name = "registrationCode")] public string? RegistrationCodeForm { get; set; }
    [SupplyParameterFromForm(Name = "keepSignedIn")] public bool KeepSignedInForm { get; set; }
    [SupplyParameterFromQuery(Name = "signup")] public string? SignupQuery { get; set; }
    [SupplyParameterFromQuery(Name = "googlecancel")] public string? GoogleCancelQuery { get; set; }

    // "owner" (first-run owner signup) | "signup" (registration-code signup) | "login" |
    // "google" (device-flow wait screen showing the code)
    private string _formMode = "login";
    private string? _error;
    private string? _googleUserCode;
    private string? _googleVerificationUrl;

    private const string GooglePendingCookie = "acdef-google-pending";

    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext!;

        if (httpContext.User.Identity?.IsAuthenticated == true
            && !httpContext.Request.Method.Equals("POST", StringComparison.OrdinalIgnoreCase))
        {
            httpContext.Response.Redirect("/");
            return;
        }

        if (httpContext.Request.Method.Equals("POST", StringComparison.OrdinalIgnoreCase))
        {
            await HandlePostAsync(httpContext);
            return;
        }

        // Google device-flow: cancel link, then the pending-poll cycle (each GET of this page while
        // the cookie is set polls Google once; the wait screen meta-refreshes back here).
        if (httpContext.Request.Cookies.TryGetValue(GooglePendingCookie, out var pendingId)
            && !string.IsNullOrEmpty(pendingId))
        {
            if (string.Equals(GoogleCancelQuery, "1", StringComparison.Ordinal))
            {
                GoogleLogin.Cancel(pendingId);
                httpContext.Response.Cookies.Delete(GooglePendingCookie);
                httpContext.Response.Redirect("/login");
                return;
            }

            var poll = await GoogleLogin.PollAsync(pendingId);
            switch (poll.Status)
            {
                case GoogleDeviceLogin.PollStatus.SignedIn:
                    httpContext.Response.Cookies.Delete(GooglePendingCookie);
                    await SignInAsync(httpContext, poll.Email!, poll.KeepSignedIn);
                    httpContext.Response.Redirect("/");
                    return;
                case GoogleDeviceLogin.PollStatus.Pending:
                    _formMode = "google";
                    _googleUserCode = poll.UserCode;
                    _googleVerificationUrl = poll.VerificationUrl;
                    return;
                default:
                    httpContext.Response.Cookies.Delete(GooglePendingCookie);
                    _error = poll.Error;
                    _formMode = "login";
                    return;
            }
        }

        _formMode = !TwoFactorAuth.HasAnyAccount
            ? "owner"
            : (string.Equals(SignupQuery, "1", StringComparison.Ordinal) ? "signup" : "login");
    }

    private async Task HandlePostAsync(HttpContext httpContext)
    {
        var action = (ActionForm ?? "login").Trim().ToLowerInvariant();
        var username = UsernameForm?.Trim() ?? "";
        var password = PasswordForm ?? "";
        var confirm = ConfirmPasswordForm ?? "";

        // Start the Google device flow, then post-redirect-get to the wait screen: the GET branch
        // above reads the pending cookie, polls, and renders the code page.
        if (action is "googlestart")
        {
            _formMode = "login";
            var start = await GoogleLogin.StartAsync(KeepSignedInForm);
            if (start is null)
            {
                _error = "Google sign-in could not start — check the defender's Google configuration.";
                return;
            }

            httpContext.Response.Cookies.Append(GooglePendingCookie, start.PendingId, new CookieOptions
            {
                HttpOnly = true,
                SameSite = SameSiteMode.Lax,
                MaxAge = TimeSpan.FromMinutes(30)
            });
            httpContext.Response.Redirect("/login");
            return;
        }

        // Keep the rendered form matching the submitted form name (Blazor SSR re-renders after the
        // handler and 400s if the submitted form no longer exists); the redirect below then wins.
        if (action is "ownersignup")
        {
            _formMode = "owner";
            if (TwoFactorAuth.HasAnyAccount)
            {
                _error = "An owner account already exists — please sign in.";
                return;
            }
            if (!string.Equals(password, confirm, StringComparison.Ordinal))
            {
                _error = "Passwords do not match.";
                return;
            }
            if (!TwoFactorAuth.TryCreateAccount(username, password, null, out var ownerError))
            {
                _error = ownerError;
                return;
            }
        }
        else if (action is "signup")
        {
            _formMode = "signup";
            if (!string.Equals(password, confirm, StringComparison.Ordinal))
            {
                _error = "Passwords do not match.";
                return;
            }
            if (!TwoFactorAuth.TryCreateAccount(username, password, RegistrationCodeForm, out var signupError))
            {
                _error = signupError;
                return;
            }
        }
        else
        {
            _formMode = "login";
            if (!TwoFactorAuth.ValidateAccount(username, password))
            {
                _error = "Incorrect username or password.";
                return;
            }
        }

        await SignInAsync(httpContext, username, KeepSignedInForm);
        httpContext.Response.Redirect("/");
    }

    private static async Task SignInAsync(HttpContext httpContext, string username, bool persistent)
    {
        var claims = new List<Claim>
        {
            new(ClaimTypes.Name, username),
            new("auth_time", DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString())
        };

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        await httpContext.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            principal,
            new AuthenticationProperties
            {
                IsPersistent = persistent,
                ExpiresUtc = persistent ? DateTimeOffset.UtcNow.AddDays(30) : null,
                AllowRefresh = true
            });
    }
}
