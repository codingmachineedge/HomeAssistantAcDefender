@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using System.Security.Cryptography
@using System.Text
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject TwoFactorAuth TwoFactorAuth

@if (_error is not null)
{
    <div class="login-error">
        <svg class="login-error-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
        <span>@_error</span>
    </div>
}

@if (_formMode == "owner")
{
    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <svg class="login-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <h1 class="login-title">Create the owner account</h1>
                <p class="login-subtitle">This first account is the owner. Later sign-ups need a registration code you set in Settings.</p>
            </div>

            <form method="post" class="login-form" data-enhance="false" @formname="ownersignup">
                <AntiforgeryToken />
                <input type="hidden" name="action" value="ownersignup" />
                <div class="input-group"><input type="text" name="username" class="text-input" placeholder="Username" aria-label="Username" autocomplete="username" required autofocus /></div>
                <div class="input-group"><input type="password" name="password" class="text-input" placeholder="Password (at least 6 characters)" aria-label="Password, at least 6 characters" autocomplete="new-password" minlength="6" required /></div>
                <div class="input-group"><input type="password" name="confirmPassword" class="text-input" placeholder="Confirm password" aria-label="Confirm password" autocomplete="new-password" minlength="6" required /></div>
                <div class="login-options">
                    <label class="option-label"><input type="checkbox" name="keepSignedIn" value="true" checked /><span>Keep me signed in</span></label>
                </div>
                <button type="submit" class="login-submit">Create owner account</button>
            </form>
        </div>
    </div>
}
else if (_formMode == "signup")
{
    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <svg class="login-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <h1 class="login-title">Create an account</h1>
                <p class="login-subtitle">Ask the owner for the registration code.</p>
            </div>

            <form method="post" class="login-form" data-enhance="false" @formname="signup">
                <AntiforgeryToken />
                <input type="hidden" name="action" value="signup" />
                <div class="input-group"><input type="text" name="username" class="text-input" placeholder="Username" aria-label="Username" autocomplete="username" required autofocus /></div>
                <div class="input-group"><input type="password" name="password" class="text-input" placeholder="Password (at least 6 characters)" aria-label="Password, at least 6 characters" autocomplete="new-password" minlength="6" required /></div>
                <div class="input-group"><input type="password" name="confirmPassword" class="text-input" placeholder="Confirm password" aria-label="Confirm password" autocomplete="new-password" minlength="6" required /></div>
                <div class="input-group"><input type="text" name="registrationCode" class="text-input" placeholder="Registration code" aria-label="Registration code" required /></div>
                <div class="login-options">
                    <label class="option-label"><input type="checkbox" name="keepSignedIn" value="true" checked /><span>Keep me signed in</span></label>
                </div>
                <button type="submit" class="login-submit">Create account</button>
            </form>
            <a href="/login" style="display:block;text-align:center;margin-top:14px;color:#46c1a7;font-size:0.85rem;text-decoration:none;">Back to sign in</a>
        </div>
    </div>
}
else
{
    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <svg class="login-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <h1 class="login-title">AC Defender Guard Post</h1>
                <p class="login-subtitle">Sign in to continue.</p>
            </div>

            <form method="post" class="login-form" data-enhance="false" @formname="login">
                <AntiforgeryToken />
                <input type="hidden" name="action" value="login" />
                <div class="input-group"><input type="text" name="username" class="text-input" placeholder="Username" aria-label="Username" autocomplete="username" required autofocus /></div>
                <div class="input-group"><input type="password" name="password" class="text-input" placeholder="Password" aria-label="Password" autocomplete="current-password" required /></div>
                <div class="login-options">
                    <label class="option-label"><input type="checkbox" name="keepSignedIn" value="true" checked /><span>Keep me signed in</span></label>
                </div>
                <button type="submit" class="login-submit">Sign in</button>
            </form>
            <a href="/login?signup=1" style="display:block;text-align:center;margin-top:14px;color:#46c1a7;font-size:0.85rem;text-decoration:none;">Create an account</a>
        </div>
    </div>
}

<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0f1614;
        padding: 24px;
    }

    .login-card {
        width: 100%;
        max-width: 420px;
        padding: 40px 32px 32px;
        background: #17211c;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.4);
    }

    .onboarding .login-card {
        max-width: 460px;
    }

    .login-header {
        text-align: center;
        margin-bottom: 32px;
    }

    .login-icon {
        width: 48px;
        height: 48px;
        color: #46c1a7;
        margin-bottom: 12px;
    }

    .login-title {
        color: #e7f6ef;
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .login-subtitle {
        color: #9fb0a8;
        font-size: 0.9rem;
    }

    .login-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .input-group {
        position: relative;
    }

    .code-input {
        width: 100%;
        padding: 14px 16px;
        font-size: 1.5rem;
        letter-spacing: 0.25em;
        font-family: 'SF Mono', 'Cascadia Code', Consolas, monospace;
        text-align: center;
        background: #0f1614;
        border: 1px solid #2a3832;
        border-radius: 8px;
        color: #e7f6ef;
        outline: none;
        transition: border-color 0.2s;
    }

    .code-input:focus {
        border-color: #46c1a7;
        box-shadow: 0 0 0 2px rgba(70,193,167,0.2);
    }

    .code-input::placeholder {
        color: #4a5c54;
    }

    .text-input {
        width: 100%;
        padding: 12px 16px;
        font-size: 1rem;
        background: #0f1614;
        border: 1px solid #2a3832;
        border-radius: 8px;
        color: #e7f6ef;
        outline: none;
        transition: border-color 0.2s;
    }

    .text-input:focus {
        border-color: #46c1a7;
        box-shadow: 0 0 0 2px rgba(70,193,167,0.2);
    }

    .text-input::placeholder {
        color: #4a5c54;
    }

    .password-setup {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 12px;
        background: #0f1614;
        border-radius: 8px;
        border: 1px dashed #2a3832;
    }

    .password-setup-label {
        color: #9fb0a8;
        font-size: 0.78rem;
        margin-bottom: 2px;
    }

    .login-divider {
        display: flex;
        align-items: center;
        text-align: center;
        color: #6b7d75;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .login-divider::before,
    .login-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #2a3832;
    }

    .login-divider span {
        padding: 0 12px;
    }

    .login-options {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 4px 0;
    }

    .option-label {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #cfe0d8;
        font-size: 0.9rem;
        cursor: pointer;
        user-select: none;
    }

    .option-label input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: #46c1a7;
        cursor: pointer;
    }

    .login-submit {
        margin-top: 8px;
        padding: 14px;
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        background: #0f7d67;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.2s;
        letter-spacing: 0.02em;
    }

    .login-submit:hover {
        background: #0e9177;
    }

    .login-submit:active {
        background: #0c6956;
    }

    .login-error {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 24px;
        background: #c0392b;
        color: #fff;
        font-size: 0.9rem;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }

    .login-error-icon {
        width: 20px;
        height: 20px;
    }

    .qr-container {
        display: flex;
        justify-content: center;
        padding: 16px;
        background: #ffffff;
        border-radius: 12px;
        border: 2px solid #46c1a7;
    }

    .qr-container svg {
        display: block;
        max-width: 100%;
        height: auto;
    }

    .manual-key {
        text-align: center;
        padding: 12px;
        background: #0f1614;
        border-radius: 8px;
        border: 1px solid #2a3832;
    }

    .manual-key-label {
        color: #9fb0a8;
        font-size: 0.8rem;
        margin-bottom: 4px;
    }

    .manual-key-value {
        font-family: 'SF Mono', 'Cascadia Code', Consolas, monospace;
        font-size: 0.95rem;
        color: #46c1a7;
        word-break: break-all;
        letter-spacing: 0.1em;
    }
</style>

@code {
    [SupplyParameterFromForm(Name = "action")] public string? ActionForm { get; set; }
    [SupplyParameterFromForm(Name = "username")] public string? UsernameForm { get; set; }
    [SupplyParameterFromForm(Name = "password")] public string? PasswordForm { get; set; }
    [SupplyParameterFromForm(Name = "confirmPassword")] public string? ConfirmPasswordForm { get; set; }
    [SupplyParameterFromForm(Name = "registrationCode")] public string? RegistrationCodeForm { get; set; }
    [SupplyParameterFromForm(Name = "keepSignedIn")] public bool KeepSignedInForm { get; set; }
    [SupplyParameterFromQuery(Name = "signup")] public string? SignupQuery { get; set; }

    // "owner" (first-run owner signup) | "signup" (registration-code signup) | "login"
    private string _formMode = "login";
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext!;

        if (httpContext.User.Identity?.IsAuthenticated == true
            && !httpContext.Request.Method.Equals("POST", StringComparison.OrdinalIgnoreCase))
        {
            httpContext.Response.Redirect("/");
            return;
        }

        if (httpContext.Request.Method.Equals("POST", StringComparison.OrdinalIgnoreCase))
        {
            await HandlePostAsync(httpContext);
            return;
        }

        _formMode = !TwoFactorAuth.HasAnyAccount
            ? "owner"
            : (string.Equals(SignupQuery, "1", StringComparison.Ordinal) ? "signup" : "login");
    }

    private async Task HandlePostAsync(HttpContext httpContext)
    {
        var action = (ActionForm ?? "login").Trim().ToLowerInvariant();
        var username = UsernameForm?.Trim() ?? "";
        var password = PasswordForm ?? "";
        var confirm = ConfirmPasswordForm ?? "";

        // Keep the rendered form matching the submitted form name (Blazor SSR re-renders after the
        // handler and 400s if the submitted form no longer exists); the redirect below then wins.
        if (action is "ownersignup")
        {
            _formMode = "owner";
            if (TwoFactorAuth.HasAnyAccount)
            {
                _error = "An owner account already exists — please sign in.";
                return;
            }
            if (!string.Equals(password, confirm, StringComparison.Ordinal))
            {
                _error = "Passwords do not match.";
                return;
            }
            if (!TwoFactorAuth.TryCreateAccount(username, password, null, out var ownerError))
            {
                _error = ownerError;
                return;
            }
        }
        else if (action is "signup")
        {
            _formMode = "signup";
            if (!string.Equals(password, confirm, StringComparison.Ordinal))
            {
                _error = "Passwords do not match.";
                return;
            }
            if (!TwoFactorAuth.TryCreateAccount(username, password, RegistrationCodeForm, out var signupError))
            {
                _error = signupError;
                return;
            }
        }
        else
        {
            _formMode = "login";
            if (!TwoFactorAuth.ValidateAccount(username, password))
            {
                _error = "Incorrect username or password.";
                return;
            }
        }

        await SignInAsync(httpContext, username, KeepSignedInForm);
        httpContext.Response.Redirect("/");
    }

    private static async Task SignInAsync(HttpContext httpContext, string username, bool persistent)
    {
        var claims = new List<Claim>
        {
            new(ClaimTypes.Name, username),
            new("auth_time", DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString())
        };

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        await httpContext.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            principal,
            new AuthenticationProperties
            {
                IsPersistent = persistent,
                ExpiresUtc = persistent ? DateTimeOffset.UtcNow.AddDays(30) : null,
                AllowRefresh = true
            });
    }
}
