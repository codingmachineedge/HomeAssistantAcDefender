@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using System.Security.Cryptography
@using System.Text
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject TwoFactorAuth TwoFactorAuth

@if (_error is not null)
{
    <div class="login-error">
        <svg class="login-error-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
        <span>@_error</span>
    </div>
}

@if (_onboarding)
{
    <div class="login-page onboarding">
        <div class="login-card">
            <div class="login-header">
                <svg class="login-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <h1 class="login-title">Set Up Two-Factor Authentication</h1>
                <p class="login-subtitle">Scan the QR code with your authenticator app, or enter the key manually.</p>
            </div>

            <form method="post" class="login-form" data-enhance="false">
                <AntiforgeryToken />
                <input type="hidden" name="pendingSecret" value="@_pendingSecret" />
                <input type="hidden" name="onboarding" value="true" />

                <div class="qr-container">
                    @((MarkupString)_qrSvg)
                </div>

                <div class="manual-key">
                    <p class="manual-key-label">Manual entry key</p>
                    <p class="manual-key-value">@_pendingSecret</p>
                </div>

                <div class="input-group">
                    <input type="text" name="code" class="code-input" placeholder="000000" maxlength="6"
                           inputmode="numeric" pattern="[0-9]{6}" autocomplete="one-time-code" required />
                </div>

                <div class="login-options">
                    <label class="option-label">
                        <input type="checkbox" name="keepSignedIn" value="true" checked />
                        <span>Keep me signed in</span>
                    </label>
                    <label class="option-label">
                        <input type="checkbox" name="rememberIp" value="true" checked />
                        <span>Remember this IP</span>
                    </label>
                </div>

                <button type="submit" class="login-submit">Verify &amp; Activate</button>
            </form>
        </div>
    </div>
}
else
{
    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <svg class="login-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <h1 class="login-title">AC Defender Guard Post</h1>
                <p class="login-subtitle">Enter the code from your authenticator app.</p>
            </div>

            <form method="post" class="login-form" data-enhance="false">
                <AntiforgeryToken />

                <div class="input-group">
                    <input type="text" name="code" class="code-input" placeholder="000000" maxlength="6"
                           inputmode="numeric" pattern="[0-9]{6}" autocomplete="one-time-code" required autofocus />
                </div>

                <div class="login-options">
                    <label class="option-label">
                        <input type="checkbox" name="keepSignedIn" value="true" checked />
                        <span>Keep me signed in</span>
                    </label>
                    <label class="option-label">
                        <input type="checkbox" name="rememberIp" value="true" checked />
                        <span>Remember this IP</span>
                    </label>
                </div>

                <button type="submit" class="login-submit">Verify</button>
            </form>
        </div>
    </div>
}

<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0f1614;
        padding: 24px;
    }

    .login-card {
        width: 100%;
        max-width: 420px;
        padding: 40px 32px 32px;
        background: #17211c;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.4);
    }

    .onboarding .login-card {
        max-width: 460px;
    }

    .login-header {
        text-align: center;
        margin-bottom: 32px;
    }

    .login-icon {
        width: 48px;
        height: 48px;
        color: #46c1a7;
        margin-bottom: 12px;
    }

    .login-title {
        color: #e7f6ef;
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .login-subtitle {
        color: #9fb0a8;
        font-size: 0.9rem;
    }

    .login-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .input-group {
        position: relative;
    }

    .code-input {
        width: 100%;
        padding: 14px 16px;
        font-size: 1.5rem;
        letter-spacing: 0.25em;
        font-family: 'SF Mono', 'Cascadia Code', Consolas, monospace;
        text-align: center;
        background: #0f1614;
        border: 1px solid #2a3832;
        border-radius: 8px;
        color: #e7f6ef;
        outline: none;
        transition: border-color 0.2s;
    }

    .code-input:focus {
        border-color: #46c1a7;
        box-shadow: 0 0 0 2px rgba(70,193,167,0.2);
    }

    .code-input::placeholder {
        color: #4a5c54;
    }

    .login-options {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 4px 0;
    }

    .option-label {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #cfe0d8;
        font-size: 0.9rem;
        cursor: pointer;
        user-select: none;
    }

    .option-label input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: #46c1a7;
        cursor: pointer;
    }

    .login-submit {
        margin-top: 8px;
        padding: 14px;
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        background: #0f7d67;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.2s;
        letter-spacing: 0.02em;
    }

    .login-submit:hover {
        background: #0e9177;
    }

    .login-submit:active {
        background: #0c6956;
    }

    .login-error {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 24px;
        background: #c0392b;
        color: #fff;
        font-size: 0.9rem;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }

    .login-error-icon {
        width: 20px;
        height: 20px;
    }

    .qr-container {
        display: flex;
        justify-content: center;
        padding: 16px;
        background: #ffffff;
        border-radius: 12px;
        border: 2px solid #46c1a7;
    }

    .qr-container svg {
        display: block;
        max-width: 100%;
        height: auto;
    }

    .manual-key {
        text-align: center;
        padding: 12px;
        background: #0f1614;
        border-radius: 8px;
        border: 1px solid #2a3832;
    }

    .manual-key-label {
        color: #9fb0a8;
        font-size: 0.8rem;
        margin-bottom: 4px;
    }

    .manual-key-value {
        font-family: 'SF Mono', 'Cascadia Code', Consolas, monospace;
        font-size: 0.95rem;
        color: #46c1a7;
        word-break: break-all;
        letter-spacing: 0.1em;
    }
</style>

@code {
    [SupplyParameterFromForm(Name = "code")]
    public string? Code { get; set; }

    [SupplyParameterFromForm(Name = "keepSignedIn")]
    public bool KeepSignedInForm { get; set; }

    [SupplyParameterFromForm(Name = "rememberIp")]
    public bool RememberIpForm { get; set; }

    [SupplyParameterFromForm(Name = "pendingSecret")]
    public string? PendingSecretForm { get; set; }

    [SupplyParameterFromForm(Name = "onboarding")]
    public bool OnboardingForm { get; set; }

    private string? _pendingSecret;
    private string _qrSvg = "";
    private bool _onboarding;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext!;

        if (httpContext.User.Identity?.IsAuthenticated == true && !httpContext.Request.Method.Equals("POST", StringComparison.OrdinalIgnoreCase))
        {
            httpContext.Response.Redirect("/");
            return;
        }

        if (httpContext.Request.Method.Equals("POST", StringComparison.OrdinalIgnoreCase))
        {
            await HandlePostAsync(httpContext);
            return;
        }

        if (await TryAutoLoginAsync(httpContext))
            return;

        _onboarding = !TwoFactorAuth.IsConfigured;

        if (_onboarding)
        {
            _pendingSecret = TwoFactorAuth.GenerateNewSecret();
            var url = TwoFactorAuth.GetOtpAuthUrl(_pendingSecret);
            _qrSvg = TwoFactorAuth.GenerateQrSvg(url);
        }
    }

    private async Task<bool> TryAutoLoginAsync(HttpContext httpContext)
    {
        var clientIp = GetClientIp(httpContext);
        var trustedIpHash = httpContext.Request.Cookies["AC_Defender_TrustedIP"];

        if (!string.IsNullOrWhiteSpace(trustedIpHash) && !string.IsNullOrWhiteSpace(clientIp))
        {
            var currentHash = HashIp(clientIp);
            if (string.Equals(currentHash, trustedIpHash, StringComparison.Ordinal))
            {
                await SignInAsync(httpContext, persistent: true);
                httpContext.Response.Redirect("/");
                return true;
            }
        }

        return false;
    }

    private async Task HandlePostAsync(HttpContext httpContext)
    {
        var code = Code?.Trim() ?? "";

        if (OnboardingForm)
        {
            var pendingSecret = PendingSecretForm?.Trim() ?? "";
            if (string.IsNullOrWhiteSpace(pendingSecret))
            {
                _error = "Session expired. Please reload the page.";
                return;
            }

            if (!TwoFactorAuth.ValidateCode(pendingSecret, code))
            {
                _error = "Incorrect verification code. Please try again.";
                _pendingSecret = pendingSecret;
                var url = TwoFactorAuth.GetOtpAuthUrl(_pendingSecret);
                _qrSvg = TwoFactorAuth.GenerateQrSvg(url);
                _onboarding = true;
                return;
            }

            TwoFactorAuth.SaveSecret(pendingSecret);
            _pendingSecret = null;
            _qrSvg = "";
            _onboarding = false;
        }
        else
        {
            if (!TwoFactorAuth.IsConfigured)
            {
                _error = "2FA is not configured. Please reload the page.";
                return;
            }

            if (!TwoFactorAuth.ValidateCurrentCode(code))
            {
                _error = "Incorrect code. Please try again.";
                return;
            }
        }

        var keepSignedIn = KeepSignedInForm;
        var rememberIp = RememberIpForm;

        var clientIp = GetClientIp(httpContext);
        if (rememberIp && !string.IsNullOrWhiteSpace(clientIp))
        {
            httpContext.Response.Cookies.Append("AC_Defender_TrustedIP", HashIp(clientIp), new CookieOptions
            {
                HttpOnly = true,
                Secure = false,
                SameSite = SameSiteMode.Lax,
                Expires = DateTimeOffset.UtcNow.AddDays(365),
                Path = "/"
            });
        }

        await SignInAsync(httpContext, keepSignedIn);
        httpContext.Response.Redirect("/");
    }

    private async Task SignInAsync(HttpContext httpContext, bool persistent)
    {
        var claims = new List<Claim>
        {
            new(ClaimTypes.Name, "guard"),
            new(ClaimTypes.Role, "admin"),
            new("auth_time", DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString())
        };

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        await httpContext.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            principal,
            new AuthenticationProperties
            {
                IsPersistent = persistent,
                ExpiresUtc = persistent ? DateTimeOffset.UtcNow.AddDays(30) : null,
                AllowRefresh = true
            });
    }

    private static string GetClientIp(HttpContext httpContext)
    {
        var forwarded = httpContext.Request.Headers["X-Forwarded-For"].FirstOrDefault();
        if (!string.IsNullOrWhiteSpace(forwarded))
        {
            return forwarded.Split(',')[0].Trim();
        }

        return httpContext.Connection.RemoteIpAddress?.ToString() ?? "";
    }

    private static string HashIp(string ip)
    {
        var hash = SHA256.HashData(Encoding.UTF8.GetBytes(ip));
        return Convert.ToBase64String(hash);
    }
}
