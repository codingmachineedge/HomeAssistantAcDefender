<MudItem xs="6" sm="4" lg="3">
    <MudPaper Class="metric-card" Outlined="true">
        <MudText Typo="Typo.overline">@Label</MudText>
        <MudText Typo="Typo.h6">@Value</MudText>
        <MudText Typo="Typo.caption" Class="helper-text">@Help</MudText>
    </MudPaper>
</MudItem>

@code {
    [Parameter]
    public string Label { get; set; } = "";

    [Parameter]
    public string Value { get; set; } = "--";

    [Parameter]
    public string Help { get; set; } = "";
}
