@page "/"
@implements IDisposable
@inject DefenderStateStore StateStore
@inject AcDefenderService Defender
@inject HomeAssistantClient HomeAssistant
@inject ISnackbar Snackbar

<PageTitle>Dashboard - Home Assistant AC Defender</PageTitle>

<MudStack Spacing="3">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="4">
            <MudPaper Class="panel-card target-card">
                <MudText Typo="Typo.overline">Generated Target</MudText>
                <MudText Typo="Typo.body2" Class="helper-text">This is the cool number the defender is trying to keep.</MudText>
                <MudText Typo="Typo.h1" Class="target-readout">@TargetText</MudText>

                <MudGrid Spacing="2" Class="mt-2">
                    <MudItem xs="12">
                        <MudNumericField T="double"
                                         Value="_targetInput"
                                         ValueChanged="OnTargetInputChanged"
                                         Label="Set target"
                                         HelperText="Type the temperature you want, like picking a number on a toy dial."
                                         Variant="Variant.Outlined"
                                         Min="10"
                                         Max="35"
                                         Step="0.1"
                                         Adornment="Adornment.End"
                                         AdornmentText="C" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ApplyTarget" StartIcon="@Icons.Material.Filled.Check">Apply</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Sends the number in the box to the defender.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateTarget" StartIcon="@Icons.Material.Filled.AutoAwesome">Generate</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Lets the website pick a comfy cool number.</MudText>
                    </MudItem>
                </MudGrid>

                <MudSwitch T="bool"
                           Value="@(Snapshot?.DefenderEnabled ?? false)"
                           ValueChanged="SetDefenderEnabled"
                           Label="Defender active"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">On means the helper keeps watching and fixes the AC.</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudPaper Class="panel-card">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
                    <div>
                        <MudText Typo="Typo.overline">Dining Room Climate</MudText>
                        <MudText Typo="Typo.h5">@EntityText</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">This card shows what the real Home Assistant thermostat says right now.</MudText>
                    </div>
                    <MudChip T="string" Color="@ConnectionColor" Variant="Variant.Filled">@ConnectionText</MudChip>
                </MudStack>

                <MudGrid Spacing="2" Class="mt-2">
                    <MetricCard Label="Room" Value="@Temp(Snapshot?.HomeAssistantThermostat?.CurrentTemperatureCelsius)" Help="How warm the dining room is." />
                    <MetricCard Label="Setpoint" Value="@Temp(Snapshot?.HomeAssistantThermostat?.SetPointCelsius)" Help="The number the thermostat is set to." />
                    <MetricCard Label="Outdoor" Value="@Temp(Snapshot?.Weather?.OutdoorTemperatureCelsius)" Help="How warm it is outside." />
                    <MetricCard Label="Weather" Value="@(Snapshot?.Weather?.Condition ?? "--")" Help="What the weather looks like now." />
                    <MetricCard Label="Mode" Value="@(Snapshot?.HomeAssistantThermostat?.HvacMode ?? "--")" Help="The AC must stay on cool." />
                    <MetricCard Label="Action" Value="@(Snapshot?.HomeAssistantThermostat?.HvacAction ?? "--")" Help="What the thermostat is doing." />
                    <MetricCard Label="Fan" Value="@(Snapshot?.HomeAssistantThermostat?.FanMode ?? "--")" Help="How the fan is blowing air." />
                    <MetricCard Label="Cooldown" Value="@CooldownText" Help="A short wait before fixing again." />
                </MudGrid>

                <MudAlert Class="mt-3" Severity="Severity.Info" Variant="Variant.Outlined">@NextActionText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This tells what the defender plans to do next.</MudText>

                <MudAlert Class="mt-2" Severity="@NaturalSeverity" Variant="Variant.Outlined">@NaturalRecoveryText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if comfort sync is waiting, nudging, or skipping quiet waits because it is too warm.</MudText>

                <MudAlert Class="mt-2" Severity="@NaturalWalkbackSeverity" Variant="Variant.Outlined">@NaturalWalkbackText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if safe corrections are walking back slowly after repeated wall touches.</MudText>

                <MudAlert Class="mt-2" Severity="@TouchSignatureSeverity" Variant="Variant.Outlined">@TouchSignatureText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if safe nudges are matching the way the wall thermostat was changed.</MudText>

                <MudAlert Class="mt-2" Severity="@VisibilityGuardSeverity" Variant="Variant.Outlined">@VisibilityGuardText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if a wall touch happened soon after a helper command and safe nudges are slowing down.</MudText>

                <MudAlert Class="mt-2" Severity="@RoutineTimingSeverity" Variant="Variant.Outlined">@RoutineTimingText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if a safe adjustment is waiting for a normal comfort-check rhythm.</MudText>

                <MudAlert Class="mt-2" Severity="@ComfortBudgetSeverity" Variant="Variant.Outlined">@ComfortBudgetText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if repeated safe adjustments are resting for a while.</MudText>

                <MudAlert Class="mt-2" Severity="@NaturalCadenceSeverity" Variant="Variant.Outlined">@NaturalCadenceText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if safe nudges are waiting for a quieter natural time slot.</MudText>

                <MudAlert Class="mt-2" Severity="@ComfortCompromiseSeverity" Variant="Variant.Outlined">@ComfortCompromiseText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if a wall choice is being blended back gently while the room is safe.</MudText>

                <MudAlert Class="mt-2" Severity="@ComfortMemorySeverity" Variant="Variant.Outlined">@ComfortMemoryText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if this time of day has a small learned comfort preference.</MudText>

                <MudAlert Class="mt-2" Severity="@CoolModeRestoreSeverity" Variant="Variant.Outlined">@CoolModeRestoreText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if cool mode is waiting before it comes back.</MudText>

                <MudAlert Class="mt-2" Severity="@ConflictQuietSeverity" Variant="Variant.Outlined">@ConflictQuietText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if repeated wall touches made the helper stand down.</MudText>

                <MudAlert Class="mt-2" Severity="@ManualGraceSeverity" Variant="Variant.Outlined">@ManualGraceText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if a wall thermostat change is being left alone while the room still feels okay.</MudText>

                <MudAlert Class="mt-2" Severity="@TouchIntentSeverity" Variant="Variant.Outlined">@TouchIntentText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if recent wall changes look warmer, cooler, or mixed.</MudText>

                <MudAlert Class="mt-2" Severity="@SetpointEchoSeverity" Variant="Variant.Outlined">@SetpointEchoText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if the helper is waiting for Home Assistant to repeat back the last setpoint.</MudText>

                <MudAlert Class="mt-2" Severity="@RepeatCommandSeverity" Variant="Variant.Outlined">@RepeatCommandText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if the helper is waiting before sending the same thermostat number again.</MudText>

                <MudAlert Class="mt-2" Severity="@SensorRhythmSeverity" Variant="Variant.Outlined">@SensorRhythmText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if a safe correction is waiting for a normal Home Assistant sensor beat.</MudText>

                <MudAlert Class="mt-2" Severity="@CoolingRunwaySeverity" Variant="Variant.Outlined">@CoolingRunwayText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if cooling just started and the helper is giving the AC time to work.</MudText>

                <MudAlert Class="mt-2" Severity="@RoomTrendSeverity" Variant="Variant.Outlined">@RoomTrendText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if the room is warming, stable, or cooling before the helper nudges.</MudText>

                <MudAlert Class="mt-2" Severity="@ThermalMomentumSeverity" Variant="Variant.Outlined">@ThermalMomentumText</MudAlert>
                <MudText Typo="Typo.caption" Class="helper-text">This says if the room is cooling fast enough to wait.</MudText>

                <MudText Typo="Typo.subtitle2" Class="mt-3">@LastCommandText</MudText>
                <MudText Typo="Typo.caption" Class="helper-text">This shows the last command the website sent to Home Assistant.</MudText>

                @if (!string.IsNullOrWhiteSpace(Snapshot?.LastError))
                {
                    <MudAlert Class="mt-3" Severity="Severity.Warning" Variant="Variant.Outlined">@Snapshot.LastError</MudAlert>
                }
                <MudText Typo="Typo.caption" Class="helper-text">If something goes wrong, the problem shows here.</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">
        <MudItem xs="12">
            <MudPaper Class="panel-card">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
                    <div>
                        <MudText Typo="Typo.overline">Energy Usage</MudText>
                        <MudText Typo="Typo.h5">Home Assistant live sensors</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">Reads configured usage sensors, such as the Alectra Hui power, energy, and cost entities.</MudText>
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshUsageNow" StartIcon="@Icons.Material.Filled.Refresh">Refresh usage</MudButton>
                </MudStack>

                <MudGrid Spacing="2" Class="mt-2">
                    <MetricCard Label="Power now" Value="@UsageValue(Usage?.Power)" Help="@UsageHelp(Usage?.Power)" />
                    <MetricCard Label="Energy today" Value="@UsageValue(Usage?.Energy)" Help="@UsageHelp(Usage?.Energy)" />
                    <MetricCard Label="Cost today" Value="@UsageValue(Usage?.Cost)" Help="@UsageHelp(Usage?.Cost)" />
                    <MetricCard Label="Usage updated" Value="@ShortTime(Usage?.UpdatedAt)" Help="When AC Defender last read usage sensors." />
                    <MetricCard Label="24h delta" Value="@UsageHistoryValue(UsageHistory?.Delta, UsageHistory?.Unit)" Help="@UsageHistoryHelp" />
                    <MetricCard Label="24h max" Value="@UsageHistoryValue(UsageHistory?.Max, UsageHistory?.Unit)" Help="@UsageHistoryHelp" />
                    <MetricCard Label="24h samples" Value="@(UsageHistory?.Count.ToString() ?? "--")" Help="@UsageHistoryHelp" />
                    <MetricCard Label="History updated" Value="@ShortTime(UsageHistoryUpdatedAt)" Help="When AC Defender last checked recorder history." />
                </MudGrid>

                @if (!string.IsNullOrWhiteSpace(UsageError))
                {
                    <MudAlert Class="mt-3" Severity="Severity.Warning" Variant="Variant.Outlined">@UsageError</MudAlert>
                }
                @if (!string.IsNullOrWhiteSpace(UsageHistoryError))
                {
                    <MudAlert Class="mt-3" Severity="Severity.Warning" Variant="Variant.Outlined">@UsageHistoryError</MudAlert>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="panel-card">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
                    <div>
                        <MudText Typo="Typo.overline">Upstairs Comfort</MudText>
                        <MudText Typo="Typo.h5">@(Snapshot?.Comfort.Status ?? "Waiting for upstairs readings")</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">This helps stop upstairs from feeling too hot.</MudText>
                    </div>
                    <MudChip T="string" Color="@(Snapshot?.Comfort.IsHome == true ? Color.Success : Color.Warning)" Variant="Variant.Filled">@HomePresenceText</MudChip>
                </MudStack>

                <MudGrid Spacing="2" Class="mt-2">
                    <MetricCard Label="Hottest upstairs" Value="@Temp(Snapshot?.Comfort.HottestUpstairsTemperatureCelsius)" Help="The warmest upstairs sensor." />
                    <MetricCard Label="Guard" Value="@GuardText" Help="Shows if upstairs help is watching or cooling." />
                    <MetricCard Label="Presence" Value="@PresenceRequiredText" Help="Says if someone must be home first." />
                </MudGrid>

                <MudStack Spacing="1" Class="mt-3">
                    @if (Snapshot?.Comfort.UpstairsSensors?.Count > 0)
                    {
                        @foreach (var sensor in Snapshot.Comfort.UpstairsSensors)
                        {
                            <MudPaper Class="sensor-row" Outlined="true">
                                <MudText Typo="Typo.subtitle2">@sensor.Name</MudText>
                                <MudText Typo="Typo.body2">@SensorValue(sensor)</MudText>
                            </MudPaper>
                        }
                    }
                    else
                    {
                        <MudText Class="helper-text">No upstairs sensors found or configured.</MudText>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="panel-card">
                <MudText Typo="Typo.overline">Real Thermostat Controls</MudText>
                <MudText Typo="Typo.h5">Dining room climate</MudText>
                <MudText Typo="Typo.body2" Class="helper-text">These buttons talk to the real dining room thermostat.</MudText>

                <MudGrid Spacing="2" Class="mt-2">
                    <MetricCard Label="Boost" Value="@Temp(Snapshot?.BoostOffsetCelsius)" Help="How much colder it may set the AC." />
                    <MetricCard Label="Quiet level" Value="@QuietLevelText" Help="How soft comfort sync is being." />
                    <MetricCard Label="Quiet wait" Value="@NaturalWaitText" Help="How long comfort sync is waiting." />
                    <MetricCard Label="Touch count" Value="@RecentTouchText" Help="Wall thermostat changes counted right now." />
                    <MetricCard Label="Touch pressure" Value="@NaturalWalkbackScoreText" Help="How strong recent wall changes are." />
                    <MetricCard Label="Cool restore" Value="@CoolModeRestoreWaitText" Help="How long before cool mode comes back." />
                    <MetricCard Label="Walk step" Value="@NaturalWalkbackStepText" Help="Safe-band nudge size after repeated touches." />
                    <MetricCard Label="Touch step" Value="@TouchSignatureStepText" Help="Learned wall-step size for safe nudges." />
                    <MetricCard Label="Touch samples" Value="@TouchSignatureSamplesText" Help="Recent wall steps used by signature learning." />
                    <MetricCard Label="Visibility wait" Value="@VisibilityGuardWaitText" Help="Hold time after noticed corrections." />
                    <MetricCard Label="Visibility pressure" Value="@VisibilityGuardPressureText" Help="How strongly noticed corrections affect timing." />
                    <MetricCard Label="Routine wait" Value="@RoutineTimingWaitText" Help="Wait for a normal-looking comfort check." />
                    <MetricCard Label="Routine rhythm" Value="@RoutineTimingRhythmText" Help="Minute rhythm with small wiggle time." />
                    <MetricCard Label="Budget wait" Value="@ComfortBudgetWaitText" Help="Rest after repeated safe adjustments." />
                    <MetricCard Label="Budget used" Value="@ComfortBudgetUsedText" Help="Safe adjustments used in the budget window." />
                    <MetricCard Label="Cadence wait" Value="@NaturalCadenceWaitText" Help="Quiet future slot for safe nudges." />
                    <MetricCard Label="Cadence pressure" Value="@NaturalCadencePressureText" Help="How much repeated wall touching is affecting timing." />
                    <MetricCard Label="Blend target" Value="@ComfortCompromiseTargetText" Help="Temporary target while a wall choice fades back." />
                    <MetricCard Label="Blend wait" Value="@ComfortCompromiseWaitText" Help="How long the temporary blend remains." />
                    <MetricCard Label="Memory bias" Value="@ComfortMemoryOffsetText" Help="Small learned time-of-day adjustment." />
                    <MetricCard Label="Memory target" Value="@ComfortMemoryTargetText" Help="Target after comfort memory is applied." />
                    <MetricCard Label="Nudge size" Value="@NaturalStepText" Help="The biggest gentle thermostat move right now." />
                    <MetricCard Label="Hold chance" Value="@HoldChanceText" Help="Chance it waits one more beat." />
                    <MetricCard Label="Command gap" Value="@CommandGapText" Help="Space between automatic nudges." />
                    <MetricCard Label="Stand-down" Value="@ConflictQuietWaitText" Help="How long conflict quiet is standing down." />
                    <MetricCard Label="Wall grace" Value="@ManualGraceWaitText" Help="How long a wall change can rest." />
                    <MetricCard Label="Touch intent" Value="@TouchIntentDirectionText" Help="Recent wall choices: warmer, cooler, mixed, or learning." />
                    <MetricCard Label="Intent grace" Value="@TouchIntentGraceText" Help="Extra safe grace available for clear warmer intent." />
                    <MetricCard Label="Echo wait" Value="@SetpointEchoWaitText" Help="Wait for Home Assistant to confirm the last setpoint." />
                    <MetricCard Label="Echo target" Value="@SetpointEchoTargetText" Help="The last setpoint Home Assistant has not reported back yet." />
                    <MetricCard Label="Repeat wait" Value="@RepeatCommandWaitText" Help="Wait before repeating the same thermostat number." />
                    <MetricCard Label="Repeat pressure" Value="@RepeatCommandPressureText" Help="How strongly repeated touches and commands are slowing repeats." />
                    <MetricCard Label="Sensor rhythm" Value="@SensorRhythmWaitText" Help="Wait for a normal Home Assistant sensor beat." />
                    <MetricCard Label="Sensor beat" Value="@SensorRhythmBeatText" Help="Learned reading interval from real Home Assistant updates." />
                    <MetricCard Label="Runway wait" Value="@CoolingRunwayWaitText" Help="Wait after cooling starts before another safe nudge." />
                    <MetricCard Label="Runway pressure" Value="@CoolingRunwayPressureText" Help="How strongly recent touches and commands are extending the runway." />
                    <MetricCard Label="Room trend" Value="@RoomTrendDirectionText" Help="Whether the room is warming or cooling." />
                    <MetricCard Label="Trend hold" Value="@RoomTrendHoldText" Help="How long trend guard is observing." />
                    <MetricCard Label="Cooling rate" Value="@ThermalMomentumRateText" Help="How fast the room is cooling." />
                    <MetricCard Label="Target ETA" Value="@ThermalMomentumEtaText" Help="Estimated minutes until target." />
                    <MetricCard Label="Updated" Value="@ShortTime(Snapshot?.HomeAssistantThermostat?.UpdatedAt)" Help="When this thermostat data was seen." />
                    <MetricCard Label="Entity" Value="@(Snapshot?.HomeAssistantEntityId ?? "--")" Help="The Home Assistant thermostat name." />
                </MudGrid>

                <MudGrid Spacing="2" Class="mt-3">
                    <MudItem xs="12" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshReal" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Asks Home Assistant for the newest thermostat reading.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ForceTarget" StartIcon="@Icons.Material.Filled.TrackChanges">Force target</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Sets the thermostat to the exact target now.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ForceBoost" StartIcon="@Icons.Material.Filled.AcUnit">Force cooling</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Makes the AC cool harder right now.</MudText>
                    </MudItem>
                </MudGrid>

                <MudGrid Spacing="2" Class="mt-3">
                    <MudItem xs="12" sm="8">
                        <MudSelect T="string" @bind-Value="_fanMode" Label="Fan mode" HelperText="Pick how the fan should blow air." Variant="Variant.Outlined">
                            @foreach (var mode in FanModes)
                            {
                                <MudSelectItem T="string" Value="@mode">@mode</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ApplyFanMode" StartIcon="@Icons.Material.Filled.Air">Set fan</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Sends the fan choice to the thermostat.</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="panel-card">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="wrap-gap">
                    <div>
                        <MudText Typo="Typo.overline">Thermostat Touch Log</MudText>
                        <MudText Typo="Typo.h5">External changes</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">This list shows when someone changed the thermostat away from the website.</MudText>
                    </div>
                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined">@TouchCount</MudChip>
                </MudStack>

                <MudStack Spacing="1" Class="scroll-list mt-3">
                    @if (Snapshot?.ThermostatChanges?.Count > 0)
                    {
                        @foreach (var change in Snapshot.ThermostatChanges)
                        {
                            <MudPaper Class="touch-row" Outlined="true">
                                <MudText Typo="Typo.subtitle2">@($"{change.PreviousSetPointCelsius:0.0} C -> {change.NewSetPointCelsius:0.0} C")</MudText>
                                <MudText Typo="Typo.caption">@DateTimeText(change.Timestamp)</MudText>
                                <MudText Typo="Typo.caption">@($"{Temp(change.RoomTemperatureCelsius)} room / {Temp(change.OutdoorTemperatureCelsius)} outdoor / {change.WeatherCondition ?? "weather --"}")</MudText>
                            </MudPaper>
                        }
                    }
                    else
                    {
                        <MudText Class="helper-text">No external thermostat changes detected.</MudText>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="panel-card">
                <MudText Typo="Typo.overline">Activity</MudText>
                <MudText Typo="Typo.body2" Class="helper-text">This is the story of what the defender has been doing.</MudText>

                <MudStack Spacing="1" Class="scroll-list mt-3">
                    @if (Snapshot?.Events?.Count > 0)
                    {
                        @foreach (var item in Snapshot.Events)
                        {
                            <MudAlert Severity="@EventSeverity(item.Level)" Variant="Variant.Outlined" Dense="true">
                                <MudText Typo="Typo.caption">@DateTimeText(item.Timestamp)</MudText>
                                <MudText Typo="Typo.body2">@item.Message</MudText>
                            </MudAlert>
                        }
                    }
                    else
                    {
                        <MudText Class="helper-text">No activity yet.</MudText>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private PeriodicTimer? timer;
    private CancellationTokenSource? timerCancellation;
    private DefenderSnapshot? Snapshot { get; set; }
    private UsageLiveSnapshot? Usage { get; set; }
    private UsageHistorySnapshot? UsageHistory { get; set; }
    private DateTimeOffset? UsageHistoryUpdatedAt { get; set; }
    private string? UsageError { get; set; }
    private string? UsageHistoryError { get; set; }
    private DateTimeOffset _nextUsageRefresh = DateTimeOffset.MinValue;
    private DateTimeOffset _nextUsageHistoryRefresh = DateTimeOffset.MinValue;
    private double _targetInput = 22.0;
    private bool _targetDirty;
    private string? _fanMode;

    private string TargetText => Snapshot is null ? "-- C" : $"{Snapshot.TargetTemperatureCelsius:0.0} C";
    private string EntityText => Snapshot?.HomeAssistantEntityId ?? "No entity";
    private string ConnectionText => Snapshot?.ConnectionState ?? "--";
    private string CooldownText => Snapshot?.CooldownSeconds > 0 ? $"{Snapshot.CooldownSeconds}s" : "Ready";
    private string NextActionText => Snapshot?.NextAction ?? "Waiting for defender status.";
    private string NaturalRecoveryText => Snapshot?.NaturalRecovery.Status ?? "Comfort sync is waiting for status.";
    private string NaturalWalkbackText => Snapshot?.NaturalWalkback.Status ?? "Natural walkback is watching.";
    private string NaturalWalkbackScoreText => Snapshot?.NaturalWalkback.Enabled == true ? $"{Snapshot.NaturalWalkback.SuspicionScore}/100" : "Off";
    private string NaturalWalkbackStepText => Snapshot?.NaturalWalkback.Enabled == true ? $"{Snapshot.NaturalWalkback.StepCelsius:0.0} C" : "Off";
    private string TouchSignatureText => Snapshot?.TouchSignature.Status ?? "Touch signature is watching.";
    private string TouchSignatureStepText => Snapshot?.TouchSignature.LearnedStepCelsius is { } step ? $"{step:0.0} C" : Snapshot?.TouchSignature.Enabled == true ? "--" : "Off";
    private string TouchSignatureSamplesText => Snapshot?.TouchSignature.Enabled == true ? Snapshot.TouchSignature.SampleCount.ToString() : "Off";
    private string VisibilityGuardText => Snapshot?.VisibilityGuard.Status ?? "Visibility guard is watching.";
    private string VisibilityGuardWaitText => Snapshot?.VisibilityGuard.Active == true ? $"{Snapshot.VisibilityGuard.SecondsRemaining}s" : "Ready";
    private string VisibilityGuardPressureText => Snapshot?.VisibilityGuard.Enabled == true ? $"{Snapshot.VisibilityGuard.Pressure}/100" : "Off";
    private string RoutineTimingText => Snapshot?.RoutineTiming.Status ?? "Routine timing is watching.";
    private string RoutineTimingWaitText => Snapshot?.RoutineTiming.Waiting == true ? $"{Snapshot.RoutineTiming.SecondsRemaining}s" : "Ready";
    private string RoutineTimingRhythmText => Snapshot?.RoutineTiming.Enabled == true ? $"{Snapshot.RoutineTiming.IntervalMinutes}+{Snapshot.RoutineTiming.JitterMinutes} min" : "Off";
    private string ComfortBudgetText => Snapshot?.ComfortBudget.Status ?? "Comfort budget is watching.";
