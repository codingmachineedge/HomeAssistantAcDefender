    // ---------- defender on/off ----------

    private string DefenderSwitchClass => DefenderIsEnabled ? "ops-defender-switch ops-defender-switch--on" : "ops-defender-switch ops-defender-switch--off";

    private async Task ToggleDefender()
    {
        var enable = !DefenderIsEnabled;
        if (!TryBeginWebsiteCommand(enable ? "turn defender on" : "pause defender", bypassDebounce: true))
        {
            return;
        }

        try
        {
            await Defender.SetDefenderEnabledAsync(enable, CancellationToken.None);
        }
        catch (ThermostatOperationSupersededException)
        {
            State.Refresh();
            Snackbar.Add("A newer defender switch action won; refreshed the live state.", Severity.Info);
            return;
        }
        State.Refresh();
        Snackbar.Add(enable ? "Defender turned on." : "Defender paused.", Severity.Info);

        if (enable)
        {
            return;
        }

        // Paused: park the unguarded unit at the stand-down setpoint so it barely runs (same as the
        // header master switch). A Home Assistant hiccup here must not throw out of the click handler.
        try
        {
            if (await Defender.ParkThermostatForStandDownAsync(CancellationToken.None) is { } parked)
            {
                State.Refresh();
                Snackbar.Add(parked, Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    // ---------- defender's last moves ----------

    private IReadOnlyList<DefenderCommandLogEntry> RecentDefenderCommands =>
        (Snapshot?.DefenderCommands ?? Array.Empty<DefenderCommandLogEntry>()).Take(3).ToArray();

    private static string CommandDescription(DefenderCommandLogEntry move)
    {
        var parts = new List<string>();
        if (move.SetPointCelsius is { } sp)
        {
            parts.Add($"{sp:0.0}°C");
        }
        if (!string.IsNullOrWhiteSpace(move.HvacMode))
        {
            parts.Add(move.HvacMode.ToUpperInvariant());
        }
        if (!string.IsNullOrWhiteSpace(move.FanMode))
        {
            parts.Add($"FAN {move.FanMode.ToUpperInvariant()}");
        }

        return parts.Count > 0 ? string.Join(" · ", parts) : "COMMAND";
    }

    private Task RefreshReal() => RunThermostatAction(() => Defender.RefreshRealThermostatAsync(CancellationToken.None), "Thermostat refreshed.", "refresh thermostat", bypassDebounce: true);
    private Task ForceTarget() => RunThermostatAction(() => Defender.ForceTargetAsync(CancellationToken.None), "Exact target sent.", "force exact target");
    private Task ForceBoost() => RunThermostatAction(() => Defender.ForceCoolingBoostAsync(CancellationToken.None), "Cooling boost sent.", "force cooling");

    private async Task TurnOff()
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Turn off the real thermostat?",
            "This sends a real Home Assistant command to turn the dining-room thermostat off.",
            yesText: "Turn thermostat off",
            cancelText: "Cancel");

        if (confirm == true)
        {
            await RunThermostatAction(() => Defender.TurnThermostatOffAsync(CancellationToken.None), "Thermostat turned off.", "turn thermostat off");
        }
    }

    private bool TryBeginWebsiteCommand(string actionName, bool bypassDebounce = false)
    {
        var gate = StateStore.TryBeginWebsiteCommand(actionName, bypassDebounce);
        State.Refresh();
        if (gate.Accepted)
        {
            return true;
        }

        Snackbar.Add(gate.Message, Severity.Warning);
        return false;
    }

    private async Task RunThermostatAction(Func<Task> action, string successMessage, string actionName, bool bypassDebounce = false)
    {
        if (!TryBeginWebsiteCommand(actionName, bypassDebounce))
        {
            return;
        }

        try
        {
            await action();
            State.Refresh();
            if (!_targetDirty)
            {
                _targetInput = Snapshot?.TargetTemperatureCelsius ?? _targetInput;
            }

            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (ThermostatOperationSupersededException)
        {
            State.Refresh();
            Snackbar.Add("A newer thermostat action took priority; Home Assistant remains connected.", Severity.Info);
        }
        catch (ThermostatCommandRetryDeferredException ex)
        {
            State.Refresh();
            Snackbar.Add(ex.Message, Severity.Info);
        }
        catch (ThermostatCommandRejectedException ex)
        {
            State.Refresh();
            Snackbar.Add($"Home Assistant rejected the thermostat command: {ex.Message}", Severity.Error);
        }
        catch (HttpRequestException ex) when (ex.StatusCode is not null)
        {
            StateStore.RecordHomeAssistantRequestRejected(
                $"Home Assistant rejected the request ({(int)ex.StatusCode.Value}): {ex.Message}");
            State.Refresh();
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            StateStore.RecordHomeAssistantUnavailable($"Home Assistant error: {ex.Message}");
            State.Refresh();
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    protected override void OnInitialized()
    {
        _targetInput = Snapshot?.TargetTemperatureCelsius ?? 22.0;
        State.Changed += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusApology && _apologyVisible)
        {
            _focusApology = false;
            await JS.InvokeVoidAsync("acAccessibility.activateModal", _apologyDialog);
        }
    }

    private void OnStateChanged()
    {
        if (!_targetDirty && Snapshot is not null)
        {
            _targetInput = Snapshot.TargetTemperatureCelsius;
        }

        // The rage detector fired: show the apologetic overlay without anyone pressing anything.
        if (Snapshot?.Emergency is { Active: true } emergency
            && emergency.Protocol.Contains("auto", StringComparison.OrdinalIgnoreCase)
            && emergency.Until is { } until
            && until != _lastAutoApologyUntil)
        {
            _lastAutoApologyUntil = until;
            _apologyVisible = true;
            _apologyAuto = true;
            _focusApology = true;
        }

        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => State.Changed -= OnStateChanged;
}
