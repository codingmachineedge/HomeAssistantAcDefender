@page "/"
@implements IDisposable
@inject DefenderStateProvider State
@inject DefenderStateStore StateStore
@inject AcDefenderService Defender
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>Command Center - AC Defender</PageTitle>

<div class="ops-dash-stack">

    @* ---------- alert rows ---------- *@
    @if (Snapshot?.FrontDoorKillSwitch.Active == true || Snapshot?.FrontDoorKillSwitch.PersonDetected == true)
    {
        <div class="ops-alert-row ops-alert-row--bad">
            <span class="ops-alert-row__glyph" aria-hidden="true">⛔</span>
            <span class="ops-alert-row__tag">DOOR TRIP</span>
            <span class="ops-alert-row__text">@Snapshot.FrontDoorKillSwitch.Status</span>
        </div>
    }
    @if (Snapshot?.Emergency.Active == true)
    {
        <div class="ops-alert-row ops-alert-row--warn">
            <span class="ops-alert-row__glyph" aria-hidden="true">‼</span>
            <span class="ops-alert-row__tag">EMERGENCY</span>
            <span class="ops-alert-row__text">@Snapshot.Emergency.Status</span>
        </div>
    }
    @if (Snapshot?.WebsiteCommandDebounce.Active == true)
    {
        <div class="ops-alert-row ops-alert-row--warn">
            <span class="ops-alert-row__glyph" aria-hidden="true">◔</span>
            <span class="ops-alert-row__tag">DEBOUNCE</span>
            <span class="ops-alert-row__text">@Snapshot.WebsiteCommandDebounce.Status</span>
        </div>
    }
    <div class="ops-alert-row">
        <span class="ops-alert-row__glyph" aria-hidden="true">@NextActionGlyph</span>
        <span class="ops-alert-row__tag">@NextActionTag</span>
        <span class="ops-alert-row__text">@NextActionText</span>
    </div>

    @* bill watch — brother will yell when this bill lands *@
    @if (BillWarningActive)
    {
        <div class="ops-bill-warn">
            <div class="ops-bill-warn__head">
                <span class="ops-bill-warn__glyph" aria-hidden="true">💸</span>
                <span class="ops-bill-warn__title">BILL WATCH — BROTHER WILL YELL</span>
                <span class="ops-bill-warn__amount">projected @BillProjectedText</span>
            </div>
            <div class="ops-bill-warn__body">
                The projected power bill is <strong>@BillProjectedText</strong> — past the $@BillThresholdText line. When this lands, brother is going to yell and get mad. Get ahead of it:
                <ul class="ops-bill-warn__tips">
                    <li><strong>Break the news first.</strong> Mention the heat wave and time-of-use rates before he opens the bill — surprise is what sets him off.</li>
                    <li><strong>Lead with the save.</strong> Pull up the Energy page: show the AC runtime, the cost breakdown, and what the guards already trimmed this month.</li>
                    <li><strong>Tighten the rest of the month now.</strong> Nudge the target up ~1 °C and let the $@BudgetText budget guard ease cooling harder so the projection drops before month-end.</li>
                    <li><strong>Offer a peace gesture.</strong> Bump the AC up a touch tonight so the next bill trends down and you can say you're already on it.</li>
                </ul>
            </div>
        </div>
    }

    <div class="ops-dash-grid">

        @* ── TACTICAL FLOOR ── *@
        <div class="ops-floor">
            <div class="ops-floor__head">
                <span class="ops-floor__title">DEFENSE FLOOR — LIVE</span>
                <span class="ops-floor__rec-dot" aria-hidden="true"></span>
                <span class="ops-floor__rec">REC</span>
                <span class="ops-floor__spacer"></span>
                <span class="ops-floor__status">@FloorStatus</span>
            </div>

            <div class="ops-floor__map" @onclick="CloseThermostat">
                <div class="ops-floor__radar" aria-hidden="true"><div class="ops-floor__radar-cone"></div></div>
                <div class="ops-floor__scanline" aria-hidden="true"></div>

                <div class="ops-room" style="left: 6%; top: 8%; width: 42%; height: 40%;"><span class="ops-room__label">DINING ROOM</span></div>
                <div class="ops-room" style="left: 54%; top: 8%; width: 40%; height: 26%;"><span class="ops-room__label">KITCHEN</span></div>
                <div class="ops-room" style="left: 54%; top: 40%; width: 40%; height: 32%;"><span class="ops-room__label">LIVING ROOM</span></div>
                <div class="ops-room" style="left: 6%; top: 54%; width: 42%; height: 34%;"><span class="ops-room__label">HALLWAY · FRONT DOOR</span></div>

                @* patrol routes *@
                <div class="ops-floor__route-h" style="left: 14%; top: 36%; width: 34%;" aria-hidden="true"></div>
                <div class="ops-floor__route-v" style="left: 62%; top: 30%; height: 38%;" aria-hidden="true"></div>

                @* thermostat node *@
                <div class="ops-thermo-node" @onclick:stopPropagation="true">
                    <button type="button" class="@ThermoDiscClass" @onclick="ToggleThermostatPop" @onclick:stopPropagation="true"
                            aria-label="@($"{SetpointShort} — {(_thermoOpen ? "Close thermostat unit control" : "Open thermostat unit control")}")"
                            aria-expanded="@(_thermoOpen ? "true" : "false")" aria-controls="@(_thermoOpen ? "thermostat-unit-control" : null)">
                        <span class="ops-thermo-node__value">@SetpointShort</span>
                        <span class="ops-thermo-node__ping" aria-hidden="true"></span>
                        <span class="ops-thermo-node__ping ops-thermo-node__ping--late" aria-hidden="true"></span>
                    </button>
                    <div class="ops-thermo-node__tag">THERMOSTAT · TAP</div>

                    @if (_thermoOpen)
                    {
                        <div id="thermostat-unit-control" class="ops-thermo-pop" role="dialog" aria-label="Thermostat unit control">
                            <div class="ops-thermo-pop__head">
                                <span class="ops-thermo-pop__title">UNIT CONTROL</span>
                                <button class="ops-thermo-pop__close" @onclick="CloseThermostat" aria-label="Close unit control">✕</button>
                            </div>
                            <div class="ops-thermo-pop__row">
                                <button class="ops-step-btn" @onclick="TargetDown" aria-label="Lower target">−</button>
                                <div>
                                    <div class="ops-thermo-pop__value">@TargetText</div>
                                    <div class="ops-thermo-pop__value-label">TEMP I WANT</div>
                                </div>
                                <button class="ops-step-btn" @onclick="TargetUp" aria-label="Raise target">+</button>
                            </div>
                            <div class="ops-thermo-pop__actions">
                                <button class="ops-mode-btn active" @onclick="ForceBoost">❆ COOL</button>
                                <button class="ops-mode-btn" @onclick="ForceTarget">⌖ TARGET</button>
                                <button class="ops-mode-btn" @onclick="RefreshReal">⟳ REFRESH</button>
                                <button class="ops-mode-btn" @onclick="TurnOff">⏻ OFF</button>
                            </div>
                            <div class="@ThermoNoteClass">@ThermoNote</div>
                        </div>
                    }
                </div>

                @* cold air particles while actively cooling *@
                @if (CoolingActive)
                {
                    <span class="ops-flake" style="left: 24%; top: 32%; font-size: 11px; animation-duration: 5s;" aria-hidden="true">❆</span>
                    <span class="ops-flake" style="left: 29%; top: 30%; font-size: 9px; animation-duration: 6.5s; animation-delay: 1.2s;" aria-hidden="true">❆</span>
                    <span class="ops-flake" style="left: 21%; top: 34%; font-size: 8px; animation-duration: 7.5s; animation-delay: 2.6s;" aria-hidden="true">❆</span>
                    <span class="ops-flake" style="left: 33%; top: 33%; font-size: 10px; animation-duration: 5.8s; animation-delay: 3.4s;" aria-hidden="true">❆</span>
                    <span class="ops-flake" style="left: 26%; top: 28%; font-size: 8.5px; animation-duration: 8.2s; animation-delay: 0.6s;" aria-hidden="true">❆</span>
                }

                @* front door sensor *@
                <div class="@DoorClass">
                    <span class="ops-door__diamond" aria-hidden="true"></span>
                    <span class="ops-door__label">DOOR SENSOR</span>
                </div>

                @* wall-touch blip *@
                @if (ShowIntruder)
                {
                    <div class="ops-intruder">
                        <div class="ops-intruder__blip" aria-hidden="true"><span class="ops-intruder__blip-ping"></span></div>
                        <div class="ops-intruder__label">@IntruderLabel</div>
                    </div>
                }

                @* defender agents *@
                @foreach (var agent in Agents)
                {
                    <div class="@agent.Css" style="left: @agent.X; top: @agent.Y;">
                        <div class="ops-agent__inner">
                            <div class="ops-agent__disc">
                                @agent.Initials
                                @if (agent.Engaged)
                                {
                                    <span class="ops-agent__ring" aria-hidden="true"></span>
                                }
                            </div>
                            <div class="ops-agent__name">@agent.Name</div>
                            <div class="ops-agent__state">@agent.State</div>
                        </div>
                    </div>
                }

                <span class="ops-floor__corner ops-floor__corner--tl" aria-hidden="true"></span>
                <span class="ops-floor__corner ops-floor__corner--tr" aria-hidden="true"></span>
                <span class="ops-floor__corner ops-floor__corner--bl" aria-hidden="true"></span>
                <span class="ops-floor__corner ops-floor__corner--br" aria-hidden="true"></span>
            </div>

            <div class="ops-ticker">
                <span class="ops-ticker__tag">FEED</span>
                <div class="ops-ticker__viewport">
                    <div class="ops-ticker__scroll">@TickerText@TickerText</div>
                </div>
            </div>
        </div>

        @* ── RIGHT COLUMN ── *@
        <div class="ops-dash-col">

            @* defender master switch — prominent on/off *@
            <button class="@DefenderSwitchClass" @onclick="ToggleDefender" aria-pressed="@(DefenderIsEnabled ? "true" : "false")">
                <span class="ops-defender-switch__glyph" aria-hidden="true">⏻</span>
                <span class="ops-defender-switch__body">
                    <span class="ops-defender-switch__label">DEFENDER</span>
                    <span class="ops-defender-switch__state">@(DefenderIsEnabled ? "ON DUTY" : "STOOD DOWN")</span>
                    <span class="ops-defender-switch__hint">@(DefenderIsEnabled ? "Tap to stand the guards down" : "Tap to wake the guard shift")</span>
                </span>
                <span class="ops-defender-switch__pill" aria-hidden="true"><span class="ops-defender-switch__knob"></span></span>
            </button>

            @* wall thermostat *@
            <div class="ops-panel ops-panel--pad">
                <div class="ops-dial-head">
                    <span class="ops-panel__label">WALL THERMOSTAT — LIVE UNIT</span>
                    <span class="@DialStateClass">@DialStateText</span>
                </div>
                <div class="ops-dial-wrap">
                    <div class="ops-dial" style="background: @DialBackground;">
                        <div class="ops-dial__center">
                            <div>
                                <div class="ops-dial__value">@SetpointText</div>
                                <div class="ops-dial__mode">SETPOINT · @HvacModeText</div>
                                <div class="ops-dial__room">ROOM @RoomText</div>
                            </div>
                        </div>
                        <div class="ops-dial__knob" style="left: @KnobX; top: @KnobY;" aria-hidden="true"></div>
                    </div>
                </div>
                <div class="ops-dial-scale"><span>16°</span><span>LIVE WALL UNIT</span><span>30°</span></div>
                <div class="ops-weather-strip" aria-label="Outdoor weather">
                    <div class="ops-weather-strip__item">
                        <span class="ops-weather-strip__label">OUTDOOR</span>
                        <span class="ops-weather-strip__value">@OutdoorText</span>
                    </div>
                    <div class="ops-weather-strip__item">
                        <span class="ops-weather-strip__label">@WeatherStatusText</span>
                        <span class="ops-weather-strip__value ops-weather-strip__value--sub">@WeatherUpdatedText</span>
                    </div>
                </div>
                <div class="ops-dial-controls__label">TEMP I WANT</div>
                <div class="ops-dial-controls">
                    <input type="number" min="10" max="35" step="0.5" value="@TargetInputText"
                           @onchange="OnTargetInputChanged" aria-label="The temp I want" />
                    <button class="ops-btn ops-btn--outline" @onclick="ForceTarget">⌖ SEND</button>
                    <button class="ops-btn ops-btn--danger" @onclick="TurnOff">⏻ OFF</button>
                </div>
                <div class="@ThermoNoteClass" style="margin-top: 10px;">@ThermoNote</div>
            </div>

            @* the temp I want *@
            <div class="ops-panel ops-panel--pad ops-want-panel">
                <div class="ops-panel__label">⌖ TEMP I WANT — MY NUMBER</div>
                <div class="ops-target__row">
                    <div class="ops-target__value">@TargetShort</div>
                    <div class="ops-target__steppers">
                        <button @onclick="TargetUp" aria-label="Raise the temp I want">▲</button>
                        <button @onclick="TargetDown" aria-label="Lower the temp I want">▼</button>
                    </div>
                </div>
                <div class="ops-target__help">Yours until you change it — the defenders hold this number for the dining room and never touch it themselves. APPLY sends it to the wall unit right now.</div>
                <div class="ops-target__actions">
                    <button class="ops-btn ops-btn--solid" @onclick="ApplyTarget">APPLY MY TEMP</button>
                    <button class="ops-btn ops-btn--outline" @onclick="GenerateTarget">✦ GENERATE</button>
                </div>
            </div>

            @* live telemetry *@
            <div class="ops-panel ops-panel--pad">
                <div class="ops-panel__label">LIVE TELEMETRY</div>
                <div class="ops-telemetry">
                    @foreach (var row in Telemetry)
                    {
                        <div>
                            <div class="ops-telemetry__row-top">
                                <span class="ops-telemetry__label">@row.Label</span>
                                <span class="ops-telemetry__value @row.ValueCss">@row.Value</span>
                            </div>
                            <div class="ops-bar"><div class="ops-bar__fill @row.BarCss" style="width: @row.Bar;"></div></div>
                        </div>
                    }
                </div>
            </div>

            @* AC runtime *@
            <div class="ops-panel ops-panel--pad">
                <div class="ops-panel__label">AC RUNTIME — HOURS COOLING</div>
                <div class="ops-runtime">
                    <div class="ops-runtime__stat">
                        <div class="ops-runtime__value">@RuntimeText(Snapshot?.AcRuntime?.TodayHours)</div>
                        @if (Snapshot?.AcRuntime?.EstimatedCostEnabled == true)
                        {
                            <div class="ops-runtime__cost">@CostText(Snapshot?.AcRuntime?.EstimatedCostTodayDollars)</div>
                        }
                        <div class="ops-runtime__label">TODAY</div>
                    </div>
                    <div class="ops-runtime__stat">
                        <div class="ops-runtime__value">@RuntimeText(Snapshot?.AcRuntime?.MonthHours)</div>
                        @if (Snapshot?.AcRuntime?.EstimatedCostEnabled == true)
                        {
                            <div class="ops-runtime__cost">@CostText(Snapshot?.AcRuntime?.EstimatedCostMonthDollars)</div>
                        }
                        <div class="ops-runtime__label">THIS MONTH</div>
                    </div>
                    <div class="ops-runtime__stat">
                        <div class="ops-runtime__value">@RuntimeText(Snapshot?.AcRuntime?.LifetimeHours)</div>
                        @if (Snapshot?.AcRuntime?.EstimatedCostEnabled == true)
                        {
                            <div class="ops-runtime__cost">@CostText(Snapshot?.AcRuntime?.EstimatedCostLifetimeDollars)</div>
                        }
                        <div class="ops-runtime__label">LIFETIME</div>
                    </div>
                </div>
                <div class="helper-text" style="margin-top: 8px;">Real compressor time (hvac_action = cooling)@(Snapshot?.AcRuntime?.TrackingSince is { } since ? $", counted since {Format.ToToronto(since):yyyy-MM-dd}" : "").@(Snapshot?.AcRuntime?.EstimatedCostEnabled == true ? $" Cost estimated at {Snapshot?.AcRuntime?.AssumedKilowatts:0.0} kW assumed AC load × the Alectra time-of-use rate at each moment — no Alectra sensor needed." : "")</div>
            </div>

            @* defender's last moves *@
            <div class="ops-panel ops-panel--pad ops-panel--flag">
                <div class="ops-panel__label">DEFENDER'S LAST MOVES — THERMOSTAT <span class="ops-tag-new">NEW</span></div>
                @if (RecentDefenderCommands.Count > 0)
                {
                    <div class="ops-moves">
                        @foreach (var move in RecentDefenderCommands)
                        {
                            <div class="ops-move" title="@move.Detail">
                                <span class="ops-move__change">@CommandDescription(move)</span>
                                <span class="ops-move__source">@move.SourceLabel</span>
                                <span class="ops-move__time">@Format.ShortTime(move.Timestamp)</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="ops-moves-empty">
                        <span class="ops-moves-empty__glyph" aria-hidden="true">◦</span>
                        <span>Waiting for the defender's first move. Every setpoint, mode, or fan command it sends lands here — press <strong>STEP TOWARD MY TEMP</strong> or <strong>FORCE COOLING</strong> to log one now.</span>
                    </div>
                }
            </div>

            @* direct orders *@
            <div class="ops-panel ops-panel--pad">
                <div class="ops-panel__label">DIRECT ORDERS</div>
                <div class="ops-orders">
                    <button class="ops-order-btn" @onclick="RefreshReal">
                        <span aria-hidden="true">⟳</span>
                        <span class="ops-order-btn__label">REFRESH READING</span>
                        <span class="ops-order-btn__hint">ask HA again</span>
                    </button>
                    <button class="ops-order-btn" @onclick="ForceTarget">
                        <span aria-hidden="true">⌖</span>
                        <span class="ops-order-btn__label">STEP TOWARD MY TEMP</span>
                        <span class="ops-order-btn__hint">0.5° at a time → @TargetText</span>
                    </button>
                    <button class="ops-order-btn ops-order-btn--solid" @onclick="ForceBoost">
                        <span aria-hidden="true">❆</span>
                        <span class="ops-order-btn__label">FORCE COOLING</span>
                        <span class="ops-order-btn__hint">no waiting</span>
                    </button>
                    <a class="ops-order-btn" href="/controls">
                        <span aria-hidden="true">⌘</span>
                        <span class="ops-order-btn__label">ALL CONTROLS</span>
                        <span class="ops-order-btn__hint">STN-06 →</span>
                    </a>
                    <div style="margin-top: 4px;">
                        <div class="ops-panel__label" style="color: var(--bad); margin-bottom: 5px;">🚨 BROTHER MAD — apologize + stand down 2h</div>
                        <SlideToConfirm Label="SLIDE TO APOLOGIZE" ConfirmedLabel="APOLOGY SENT 🙇" Glyph="🚨" OnConfirmed="BrotherMad" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* very apologetic overlay *@
@if (_apologyVisible)
{
    <div class="ops-apology" role="dialog" aria-modal="true" aria-labelledby="apology-title" aria-describedby="apology-description"
         tabindex="-1" @ref="_apologyDialog" @onkeydown="HandleApologyKeyDown" @onclick="CloseApology">
        <div class="ops-apology__box" @onclick:stopPropagation="true">
            <button type="button" class="ops-apology__close" @onclick="CloseApology" aria-label="Close apology message">✕</button>
            <div class="ops-apology__bow" aria-hidden="true">❆</div>
            <h2 id="apology-title" class="ops-apology__title">WE ARE SO, SO SORRY</h2>
            <div id="apology-description">
                <div class="ops-apology__line">The defenders are bowing as deeply as tiny snowflakes can bow.</div>
                <div class="ops-apology__line">@(_apologyAuto ? "The upset was detected automatically — nobody needed to press anything." : "The AC has been eased up ") @(_apologyAuto ? "" : "+1.0 °C immediately as a peace gesture.")</div>
                <div class="ops-apology__line">All corrections are <strong>stopped for 2 hours</strong>. The thermostat is yours.</div>
                <div class="ops-apology__line ops-apology__line--small">The anger model has recorded this hour as sensitive — the defenders will be more hands-off at this time from now on. Please forgive us. 🙇</div>
            </div>
        </div>
    </div>
}

@code {
    private double _targetInput = 22.0;
    private bool _targetDirty;
    private bool _thermoOpen;

    private DefenderSnapshot? Snapshot => State.Snapshot;

    // Bill watch: warn when the projected month-end power bill runs past this line — brother yells
    // when the real bill lands, so surface it early with prep tips.
    private const double BillYellThresholdDollars = 180.0;
    private double? BillProjectedCad => Snapshot?.ElectricityBudget?.ProjectedMonthEndCad;
    private bool BillWarningActive => BillProjectedCad is { } p && p > BillYellThresholdDollars;
    private string BillProjectedText => BillProjectedCad is { } p ? $"${p:0.00}" : "--";
    private string BillThresholdText => BillYellThresholdDollars.ToString("0", System.Globalization.CultureInfo.InvariantCulture);
    private string BudgetText => Snapshot?.ElectricityBudget?.MonthlyBudgetCad is { } b and > 0
        ? b.ToString("0", System.Globalization.CultureInfo.InvariantCulture)
        : "100";

    private bool DefenderIsEnabled => Snapshot?.DefenderEnabled == true;
    private bool IsAlert => Snapshot?.CoolingFailure.Alerting == true || Snapshot?.CoolingFailure.OmegaAlerting == true
        || Snapshot?.FrontDoorKillSwitch.Active == true || Snapshot?.FrontDoorKillSwitch.PersonDetected == true;

    private int BusyGuardCount => Snapshot is null ? 0 : GuardCatalog.Live.Count(g => g.Project!(Snapshot).Busy);
    private bool Engaged => DefenderIsEnabled && (BusyGuardCount > 0 || IsAlert);

    // ---------- alert / next-action row ----------

    private string NextActionGlyph => !DefenderIsEnabled ? "☾" : BusyGuardCount > 0 ? "◔" : "✓";
    private string NextActionTag => !DefenderIsEnabled ? "STAND-DOWN" : BusyGuardCount > 0 ? "NEXT MOVE" : "ALL QUIET";
    private string NextActionText => Snapshot?.NextAction ?? "Waiting for defender status.";

    private static string RuntimeText(double? hours) => hours is { } h
        ? h >= 10 ? $"{h:0}h" : $"{(int)h}h {(int)Math.Round(h % 1 * 60)}m"
        : "--";

    // Estimated AC-only cost under each runtime stat (assumed load × TOU rate; see helper text).
    private static string CostText(double? dollars) => dollars is { } d ? $"≈ ${d:0.00}" : "--";

    // ---------- floor ----------

    private string FloorStatus => $"{Agents.Count(a => a.Engaged)} ENGAGED · {(DefenderIsEnabled ? 4 : 0)} ON DUTY";
    private bool CoolingActive => DefenderIsEnabled && string.Equals(Snapshot?.HomeAssistantThermostat?.HvacAction, "cooling", StringComparison.OrdinalIgnoreCase);
    private bool ShowIntruder => Engaged && BusyGuardCount > 0;
    private string IntruderLabel => IsAlert ? "HOSTILE · WALL TOUCH" : "WALL TOUCH";
    private string DoorClass => Snapshot?.FrontDoorKillSwitch.Active == true || Snapshot?.FrontDoorKillSwitch.PersonDetected == true
        ? "ops-door ops-door--tripped"
        : "ops-door";

    private sealed record FloorAgent(string Name, string Initials, string X, string Y, string Route, string State, bool Engaged)
    {
        public string Css => $"ops-agent ops-agent--{Route}{(Engaged ? " ops-agent--engaged" : "")}";
    }

    private IReadOnlyList<FloorAgent> Agents
    {
        get
        {
            var alert = IsAlert;
            var standby = !DefenderIsEnabled;
            var engagedCount = Math.Min(BusyGuardCount, 4);

            return
            [
                MakeAgent("SGT FROST", "F", "20%", "44%", "a", 0),
                MakeAgent("CPL BREEZE", "B", "68%", "20%", "b", 1),
                MakeAgent("PVT CHILL", "C", "72%", "56%", "c", 2),
                MakeAgent("LT GLACIER", "G", "30%", "74%", "d", 3),
            ];

            FloorAgent MakeAgent(string name, string initials, string x, string y, string route, int index)
            {
                var engaged = !standby && (index < engagedCount || (alert && index < 2));
                var state = standby ? "OFF DUTY"
                    : alert ? (engaged ? "ENGAGING" : "COVERING")
                    : engaged ? "CORRECTING"
                    : "PATROLLING";
                return new FloorAgent(name, initials, x, y, route, state, engaged);
            }
        }
    }

    // ---------- ticker ----------

    private string TickerText
    {
        get
        {
            var bits = new List<string>();
            if (!DefenderIsEnabled)
            {
                bits.Add("DEFENDER OFFLINE");
                bits.Add("SNACK INVENTORY: ADEQUATE");
                bits.Add("WAKE THE CREW WHEN READY");
            }
            else
            {
                if (Snapshot?.HomeAssistantThermostat is { } t)
                {
                    bits.Add($"ROOM {t.CurrentTemperatureCelsius:0.0}°C · SETPOINT {t.SetPointCelsius:0.0}°C · {t.HvacAction?.ToUpperInvariant()}");
                }
                if (Snapshot?.Weather?.OutdoorTemperatureCelsius is { } o)
                {
                    bits.Add($"OUTDOOR {o:0.0}°C {Snapshot.Weather.Condition?.ToUpperInvariant()}");
                }
                if (Snapshot?.Forecast is { Available: true } fc && fc.MaxNextGateHoursCelsius is { } fcMax)
                {
                    bits.Add(fc.PeakAt is { } fcPeak
                        ? $"FORECAST PEAK {fcMax:0.0}°C @ {fcPeak.ToLocalTime():HH:mm}"
                        : $"FORECAST PEAK {fcMax:0.0}°C");
                }
                else if (Snapshot?.Forecast is { Available: false })
                {
                    bits.Add("FORECAST OFFLINE");
                }
                if (Snapshot?.Siesta is { Active: true } nap)
                {
                    bits.Add($"MESS HALL OPEN — GUARDS WAKE {nap.Until?.ToLocalTime():HH:mm} · RATIONS +${nap.FoodEarnedThisSiestaCad:0.00}");
                }
                if (Snapshot?.FoodRations is { ReactorPowerActive: true } reactor && reactor.ReactorPowerUntil is { } reactorUntil)
                {
                    bits.Add($"☢ WINFORGE REACTOR POWERED UNTIL {reactorUntil.ToLocalTime():HH:mm}");
                }
                if (!string.IsNullOrWhiteSpace(Snapshot?.PeakPowerSaver.TouPeriod))
                {
                    bits.Add($"ALECTRA {Snapshot.PeakPowerSaver.TouPeriod.ToUpperInvariant()}");
                }
                foreach (var e in (Snapshot?.Events ?? Array.Empty<DefenderEvent>()).Take(4))
                {
                    bits.Add($"{Format.ShortTime(e.Timestamp)} {e.Message.ToUpperInvariant()}");
                }
                if (bits.Count == 0)
                {
                    bits.Add("ALL SECTORS NOMINAL");
                }
            }

            return " /// " + string.Join(" /// ", bits) + " /// ";
        }
    }

