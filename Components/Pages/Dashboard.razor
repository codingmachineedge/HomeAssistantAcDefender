@page "/"
@implements IDisposable
@using System.Text.Json
@inject DefenderStateStore StateStore
@inject AcDefenderService Defender
@inject HomeAssistantClient HomeAssistant
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Dashboard - Home Assistant AC Defender</PageTitle>

<MudStack Spacing="2" Class="dashboard-shell">
    <MudPaper Class="panel-card compact-panel dashboard-status-panel">
        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
            <div>
                <MudText Typo="Typo.overline">Generated Target</MudText>
                <MudText Typo="Typo.h2" Class="target-readout">@TargetText</MudText>
                <MudText Typo="Typo.body2" Class="helper-text">This is the cool number the defender is trying to keep.</MudText>
            </div>
            <div>
                <MudChip T="string" Color="@ConnectionColor" Variant="Variant.Filled">@ConnectionText</MudChip>
                <MudSwitch T="bool"
                           Value="@(Snapshot?.DefenderEnabled ?? false)"
                           ValueChanged="SetDefenderEnabled"
                           Label="Defender active"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">The switch turns the helper on or pauses it.</MudText>
            </div>
        </MudStack>

        <MudGrid Spacing="2" Class="mt-2 compact-reading-grid">
            @foreach (var metric in SummaryMetrics)
            {
                <MudItem xs="3">
                    <div class="reading-tile">
                        <MudText Typo="Typo.overline">@metric.Label</MudText>
                        <MudText Typo="Typo.subtitle1">@metric.Value</MudText>
                        <MudText Typo="Typo.caption" Class="helper-text">@metric.Help</MudText>
                    </div>
                </MudItem>
            }
        </MudGrid>

        @if (Snapshot?.CoolingFailure.Alerting == true)
        {
            <MudAlert Class="mt-2" Severity="Severity.Error" Variant="Variant.Filled" Dense="false">@Snapshot.CoolingFailure.Status</MudAlert>
            <MudText Typo="Typo.caption" Class="helper-text">This repeats because cool mode is asking for cooling but the real thermostat readings do not look right.</MudText>
        }

        <MudAlert Class="mt-2" Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">@NextActionText</MudAlert>
        <MudText Typo="Typo.caption" Class="helper-text">This tells what the defender plans to do next.</MudText>
        @if (Snapshot?.WebsiteCommandDebounce.Active == true)
        {
            <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">@Snapshot.WebsiteCommandDebounce.Status</MudAlert>
            <MudText Typo="Typo.caption" Class="helper-text">The website waits two minutes after a button press so fast tapping does not spam Home Assistant.</MudText>
        }

    </MudPaper>

    <MudTabs Class="app-tabs" Elevation="0" Rounded="true">
        <MudTabPanel Text="Overview">
            <MudGrid Spacing="2">
                <MudItem xs="12" lg="7">
                    <MudPaper Class="panel-card">
                        <MudText Typo="Typo.overline">Priority Status</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">The few messages most worth seeing first.</MudText>
                        <MudStack Spacing="1" Class="mt-2">
                            @foreach (var item in PriorityStatuses)
                            {
                                <MudAlert Severity="@item.Severity" Variant="Variant.Outlined" Dense="true">
                                    <MudText Typo="Typo.subtitle2">@item.Name</MudText>
                                    <MudText Typo="Typo.body2">@item.Status</MudText>
                                </MudAlert>
                                <MudText Typo="Typo.caption" Class="helper-text">@item.Help</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="5">
                    <MudPaper Class="panel-card">
                        <MudText Typo="Typo.overline">Quick Real Controls</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">These buttons talk to the real dining room thermostat.</MudText>
                        <MudGrid Spacing="2" Class="mt-2">
                            <MudItem xs="12" sm="4" lg="12">
                                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshReal" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Asks Home Assistant for the newest thermostat reading.</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="4" lg="12">
                                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ForceTarget" StartIcon="@Icons.Material.Filled.TrackChanges">Force target</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Sets the thermostat to the exact website target now.</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="4" lg="12">
                                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ForceBoost" StartIcon="@Icons.Material.Filled.AcUnit">Force cooling</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Uses the current-room-minus-1 C cooling push right now.</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Defense">
            <MudPaper Class="panel-card">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
                    <div>
                        <MudText Typo="Typo.overline">Natural Defender</MudText>
                        <MudText Typo="Typo.h5">Searchable timing, touch, and safety guards</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">Search for words like cooldown, touch, weather, fan, runway, or echo.</MudText>
                    </div>
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@DefenseResultText</MudChip>
                </MudStack>
                <MudTextField T="string"
                              @bind-Value="_defenseSearch"
                              Immediate="true"
                              Clearable="true"
                              Placeholder="Search defender guards"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Class="mt-2" />

                <MudTabs Class="app-tabs compact-subtabs" Elevation="0" Rounded="true">
                    <MudTabPanel Text="Core">
                        <MudGrid Spacing="2" Class="mt-2">
                            @foreach (var metric in FilterMetrics(CoreDefenseMetrics))
                            {
                                <MetricCard Label="@metric.Label" Value="@metric.Value" Help="@metric.Help" />
                            }
                        </MudGrid>
                        <MudStack Spacing="1" Class="scroll-list compact-list mt-3">
                            @foreach (var item in FilterStatuses(CoreDefenseStatuses))
                            {
                                <MudAlert Severity="@item.Severity" Variant="Variant.Outlined" Dense="true">
                                    <MudText Typo="Typo.subtitle2">@item.Name</MudText>
                                    <MudText Typo="Typo.body2">@item.Status</MudText>
                                </MudAlert>
                                <MudText Typo="Typo.caption" Class="helper-text">@item.Help</MudText>
                            }
                            @if (!FilterStatuses(CoreDefenseStatuses).Any())
                            {
                                <MudText Class="helper-text">No core status matches that search.</MudText>
                            }
                        </MudStack>
                    </MudTabPanel>
                    <MudTabPanel Text="Wall Touch">
                        <MudGrid Spacing="2" Class="mt-2">
                            @foreach (var metric in FilterMetrics(WallTouchDefenseMetrics))
                            {
                                <MetricCard Label="@metric.Label" Value="@metric.Value" Help="@metric.Help" />
                            }
                        </MudGrid>
                        <MudStack Spacing="1" Class="scroll-list compact-list mt-3">
                            @foreach (var item in FilterStatuses(WallTouchDefenseStatuses))
                            {
                                <MudAlert Severity="@item.Severity" Variant="Variant.Outlined" Dense="true">
                                    <MudText Typo="Typo.subtitle2">@item.Name</MudText>
                                    <MudText Typo="Typo.body2">@item.Status</MudText>
                                </MudAlert>
                                <MudText Typo="Typo.caption" Class="helper-text">@item.Help</MudText>
                            }
                            @if (!FilterStatuses(WallTouchDefenseStatuses).Any())
                            {
                                <MudText Class="helper-text">No wall-touch status matches that search.</MudText>
                            }
                        </MudStack>
                    </MudTabPanel>
                    <MudTabPanel Text="Sensors">
                        <MudGrid Spacing="2" Class="mt-2">
                            @foreach (var metric in FilterMetrics(SensorDefenseMetrics))
                            {
                                <MetricCard Label="@metric.Label" Value="@metric.Value" Help="@metric.Help" />
                            }
                        </MudGrid>
                        <MudStack Spacing="1" Class="scroll-list compact-list mt-3">
                            @foreach (var item in FilterStatuses(SensorDefenseStatuses))
                            {
                                <MudAlert Severity="@item.Severity" Variant="Variant.Outlined" Dense="true">
                                    <MudText Typo="Typo.subtitle2">@item.Name</MudText>
                                    <MudText Typo="Typo.body2">@item.Status</MudText>
                                </MudAlert>
                                <MudText Typo="Typo.caption" Class="helper-text">@item.Help</MudText>
                            }
                            @if (!FilterStatuses(SensorDefenseStatuses).Any())
                            {
                                <MudText Class="helper-text">No sensor status matches that search.</MudText>
                            }
                        </MudStack>
                    </MudTabPanel>
                    <MudTabPanel Text="All">
                        <MudGrid Spacing="2" Class="mt-2">
                            @foreach (var metric in FilteredDefenseMetrics)
                            {
                                <MetricCard Label="@metric.Label" Value="@metric.Value" Help="@metric.Help" />
                            }
                        </MudGrid>

                        <MudStack Spacing="1" Class="scroll-list tall-list mt-3">
                            @foreach (var item in FilteredDefenseStatuses)
                            {
                                <MudAlert Severity="@item.Severity" Variant="Variant.Outlined" Dense="true">
                                    <MudText Typo="Typo.subtitle2">@item.Name</MudText>
                                    <MudText Typo="Typo.body2">@item.Status</MudText>
                                </MudAlert>
                                <MudText Typo="Typo.caption" Class="helper-text">@item.Help</MudText>
                            }
                            @if (!FilteredDefenseStatuses.Any())
                            {
                                <MudText Class="helper-text">No defender status matches that search.</MudText>
                            }
                        </MudStack>
                    </MudTabPanel>
                </MudTabs>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Comfort">
            <MudGrid Spacing="2">
                <MudItem xs="12" lg="6">
                    <MudPaper Class="panel-card">
                        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
                            <div>
                                <MudText Typo="Typo.overline">Upstairs Comfort</MudText>
                                <MudText Typo="Typo.h5">@(Snapshot?.Comfort.Status ?? "Waiting for upstairs readings")</MudText>
                                <MudText Typo="Typo.body2" Class="helper-text">This helps stop upstairs from feeling too hot.</MudText>
                            </div>
                            <MudChip T="string" Color="@(Snapshot?.Comfort.IsHome == true ? Color.Success : Color.Warning)" Variant="Variant.Filled">@HomePresenceText</MudChip>
                        </MudStack>

                        <MudGrid Spacing="2" Class="mt-2">
                            @foreach (var metric in ComfortMetrics)
                            {
                                <MetricCard Label="@metric.Label" Value="@metric.Value" Help="@metric.Help" />
                            }
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="6">
                    <MudPaper Class="panel-card">
                        <MudText Typo="Typo.overline">Upstairs Sensors</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">The warmest sensors are easiest to scan here.</MudText>
                        <MudStack Spacing="1" Class="scroll-list mt-2">
                            @if (Snapshot?.Comfort.UpstairsSensors?.Count > 0)
                            {
                                @foreach (var sensor in Snapshot.Comfort.UpstairsSensors)
                                {
                                    <MudPaper Class="sensor-row" Outlined="true">
                                        <MudText Typo="Typo.subtitle2">@sensor.Name</MudText>
                                        <MudText Typo="Typo.body2">@SensorValue(sensor)</MudText>
                                    </MudPaper>
                                }
                            }
                            else
                            {
                                <MudText Class="helper-text">No upstairs sensors found or configured.</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Energy">
            <MudPaper Class="panel-card">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
                    <div>
                        <MudText Typo="Typo.overline">Energy Usage</MudText>
                        <MudText Typo="Typo.h5">Home Assistant live sensors</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">Reads configured usage sensors, such as the Alectra Hui power, energy, and cost entities.</MudText>
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshUsageNow" StartIcon="@Icons.Material.Filled.Refresh">Refresh usage</MudButton>
                </MudStack>
                <MudText Typo="Typo.caption" Class="helper-text">Pulls fresh usage and history from Home Assistant.</MudText>

                <MudGrid Spacing="2" Class="mt-2">
                    @foreach (var metric in EnergyMetrics)
                    {
                        <MetricCard Label="@metric.Label" Value="@metric.Value" Help="@metric.Help" />
                    }
                </MudGrid>

                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="wrap-gap mt-3">
                    <div>
                        <MudText Typo="Typo.overline">Alectra Hui Entities</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">All Home Assistant entities whose entity ID contains alectra_hui.</MudText>
                    </div>
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@AlectraHuiEntityCount</MudChip>
                </MudStack>
                <MudStack Spacing="1" Class="scroll-list compact-list mt-2">
                    @if (AlectraHuiEntities.Any())
                    {
                        @foreach (var entity in AlectraHuiEntities)
                        {
                            <div class="sensor-row">
                                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
                                    <div>
                                        <MudText Typo="Typo.subtitle2">@entity.Name</MudText>
                                        <MudText Typo="Typo.caption">@entity.EntityId</MudText>
                                    </div>
                                    <div class="text-right">
                                        <MudText Typo="Typo.subtitle2">@UsageValue(entity)</MudText>
                                        <MudText Typo="Typo.caption">@ShortTime(entity.LastChanged)</MudText>
                                    </div>
                                </MudStack>
                            </div>
                        }
                    }
                    else
                    {
                        <MudText Class="helper-text">No Alectra Hui entities found in Home Assistant yet.</MudText>
                    }
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(UsageError))
                {
                    <MudAlert Class="mt-3" Severity="Severity.Warning" Variant="Variant.Outlined">@UsageError</MudAlert>
                }
                @if (!string.IsNullOrWhiteSpace(UsageHistoryError))
                {
                    <MudAlert Class="mt-3" Severity="Severity.Warning" Variant="Variant.Outlined">@UsageHistoryError</MudAlert>
                }
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Logs">
            <MudTabs Class="app-tabs compact-subtabs" Elevation="0" Rounded="true">
                <MudTabPanel Text="Wall Touches">
                    <MudPaper Class="panel-card">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="wrap-gap">
                            <div>
                                <MudText Typo="Typo.overline">Thermostat Touch Log</MudText>
                                <MudText Typo="Typo.h5">External changes</MudText>
                                <MudText Typo="Typo.body2" Class="helper-text">Search by temperature, room, outdoor, weather, or time.</MudText>
                            </div>
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined">@FilteredTouchCount</MudChip>
                        </MudStack>
                        <MudTextField T="string"
                                      @bind-Value="_touchSearch"
                                      Immediate="true"
                                      Clearable="true"
                                      Placeholder="Search wall touches"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined"
                                      Class="mt-2" />

                        <MudStack Spacing="1" Class="scroll-list tall-list mt-2">
                            @if (FilteredThermostatChanges.Any())
                            {
                                @foreach (var change in FilteredThermostatChanges)
                                {
                                    <MudPaper Class="touch-row clickable-row" Outlined="true" @onclick="@(() => SelectTouchLog(change))">
                                        <MudText Typo="Typo.subtitle2">@($"{change.PreviousSetPointCelsius:0.0} C -> {change.NewSetPointCelsius:0.0} C")</MudText>
                                        <MudText Typo="Typo.caption">@DateTimeText(change.Timestamp)</MudText>
                                        <MudText Typo="Typo.caption">@($"{Temp(change.RoomTemperatureCelsius)} room / {Temp(change.OutdoorTemperatureCelsius)} outdoor / {change.WeatherCondition ?? "weather --"}")</MudText>
                                    </MudPaper>
                                }
                            }
                            else
                            {
                                <MudText Class="helper-text">No external thermostat changes match.</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Activity">
                    <MudPaper Class="panel-card">
                        <MudText Typo="Typo.overline">Activity</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">Search the story of what the defender has been doing.</MudText>
                        <MudTextField T="string"
                                      @bind-Value="_eventSearch"
                                      Immediate="true"
                                      Clearable="true"
                                      Placeholder="Search activity"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined"
                                      Class="mt-2" />

                        <MudStack Spacing="1" Class="scroll-list tall-list mt-2">
                            @if (FilteredEvents.Any())
                            {
                                @foreach (var item in FilteredEvents)
                                {
                                    <MudAlert Class="clickable-row" Severity="@EventSeverity(item.Level)" Variant="Variant.Outlined" Dense="true" @onclick="@(() => SelectEventLog(item))">
                                        <MudText Typo="Typo.caption">@DateTimeText(item.Timestamp)</MudText>
                                        <MudText Typo="Typo.body2">@item.Message</MudText>
                                    </MudAlert>
                                }
                            }
                            else
                            {
                                <MudText Class="helper-text">No activity matches.</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudTabPanel>
            </MudTabs>
            @if (!string.IsNullOrWhiteSpace(_selectedLogJson))
            {
                <MudPaper Class="panel-card log-detail-panel mt-2" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="wrap-gap">
                        <div>
                            <MudText Typo="Typo.overline">Selected Log Detail</MudText>
                            <MudText Typo="Typo.subtitle2">@_selectedLogTitle</MudText>
                        </div>
                        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="ClearSelectedLog" StartIcon="@Icons.Material.Filled.Close">Clear</MudButton>
                    </MudStack>
                    <pre class="json-detail">@_selectedLogJson</pre>
                    <MudText Typo="Typo.caption" Class="helper-text">This is the log item plus the latest thermostat and weather JSON the website has.</MudText>
                </MudPaper>
            }
        </MudTabPanel>

        <MudTabPanel Text="Controls">
            <MudPaper Class="panel-card">
                <MudText Typo="Typo.overline">Real Thermostat Controls</MudText>
                <MudText Typo="Typo.h5">Dining room climate</MudText>
                <MudText Typo="Typo.body2" Class="helper-text">These controls send real Home Assistant service calls.</MudText>

                <MudTabs Class="app-tabs compact-subtabs" Elevation="0" Rounded="true">
                    <MudTabPanel Text="Target">
                        <MudGrid Spacing="2" Class="mt-2">
                            <MudItem xs="12" md="6">
                                <MudNumericField T="double"
                                                 Value="_targetInput"
                                                 ValueChanged="OnTargetInputChanged"
                                                 Label="Set target"
                                                 HelperText="Type the temperature you want, like picking a number on a toy dial."
                                                 Variant="Variant.Outlined"
                                                 Min="10"
                                                 Max="35"
                                                 Step="0.1"
                                                 Adornment="Adornment.End"
                                                 AdornmentText="C" />
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ApplyTarget" StartIcon="@Icons.Material.Filled.Check">Apply</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Sends the number to the defender.</MudText>
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateTarget" StartIcon="@Icons.Material.Filled.AutoAwesome">Generate</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Lets the website pick a comfy number.</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>
                    <MudTabPanel Text="Fan">
                        <MudGrid Spacing="2" Class="mt-2">
                            <MudItem xs="12" md="8">
                                <MudSelect T="string" @bind-Value="_fanMode" Label="Fan mode" HelperText="Pick how the fan should blow air." Variant="Variant.Outlined">
                                    @foreach (var mode in FanModes)
                                    {
                                        <MudSelectItem T="string" Value="@mode">@mode</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ApplyFanMode" StartIcon="@Icons.Material.Filled.Air">Set fan</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Sends the fan choice to the thermostat.</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>
                    <MudTabPanel Text="Actions">
                        <MudGrid Spacing="2" Class="mt-2">
                            <MudItem xs="12" sm="4">
                                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshReal" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Asks Home Assistant for the newest thermostat reading.</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ForceTarget" StartIcon="@Icons.Material.Filled.TrackChanges">Force target</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Sets the thermostat to the exact target now.</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ForceBoost" StartIcon="@Icons.Material.Filled.AcUnit">Force cooling</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Sets the thermostat one degree below current room temp when cooling is needed.</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>
                    <MudTabPanel Text="Emergency">
                        <MudGrid Spacing="2" Class="mt-2">
                            <MudItem xs="12" md="7">
                                <MudSelect T="string"
                                           @bind-Value="_emergencyProtocol"
                                           Label="Emergency protocol"
                                           HelperText="Pick what kind of urgent quiet action is needed."
                                           Variant="Variant.Outlined">
                                    @foreach (var option in EmergencyProtocols)
                                    {
                                        <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudText Typo="Typo.caption" Class="helper-text">@EmergencyProtocolHelp</MudText>
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Error" OnClick="RunEmergencyProtocol" StartIcon="@Icons.Material.Filled.ReportProblem">Emergency</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Runs the selected real emergency action now.</MudText>
                            </MudItem>
                        </MudGrid>
                        @if (Snapshot?.Emergency.Active == true)
                        {
