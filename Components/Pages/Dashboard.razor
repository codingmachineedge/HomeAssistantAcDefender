@page "/"
@implements IDisposable
@inject DefenderStateProvider State
@inject DefenderStateStore StateStore
@inject AcDefenderService Defender
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Dashboard - AC Defender</PageTitle>

<MudStack Spacing="3">
    @* ---------- Hero ---------- *@
    <MudPaper Class="hero" Elevation="0">
        <div class="hero__main">
            <MudText Typo="Typo.overline">Generated target</MudText>
            <div class="hero__target">@TargetText</div>
            <MudText Typo="Typo.body2" Class="helper-text">The cool number the defender is keeping for the dining room.</MudText>

            <div class="hero__target-edit">
                <MudNumericField T="double" Value="_targetInput" ValueChanged="OnTargetInputChanged"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" Min="10" Max="35" Step="0.1"
                                 Adornment="Adornment.End" AdornmentText="C" Class="hero__target-field" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyTarget" StartIcon="@Icons.Material.Filled.Check">Apply</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="GenerateTarget" StartIcon="@Icons.Material.Filled.AutoAwesome">Generate</MudButton>
            </div>
        </div>

        <div class="hero__side">
            <MudChip T="string" Color="@ConnectionColor" Variant="Variant.Filled">@ConnectionText</MudChip>
            <MudButton Class="@DefenderToggleClass" FullWidth="true" Variant="Variant.Filled" Color="@DefenderToggleColor"
                       Size="Size.Large" StartIcon="@DefenderToggleIcon" OnClick="ToggleDefender">
                @DefenderToggleText
            </MudButton>
            <MudText Typo="Typo.caption" Class="helper-text">@DefenderToggleHelp</MudText>
        </div>
    </MudPaper>

    @* ---------- Priority alerts ---------- *@
    @if (Snapshot?.CoolingFailure.Alerting == true)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@Snapshot.CoolingFailure.Status</MudAlert>
    }
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">@NextActionText</MudAlert>
    @if (Snapshot?.WebsiteCommandDebounce.Active == true)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">@Snapshot.WebsiteCommandDebounce.Status</MudAlert>
    }
    @if (Snapshot?.Emergency.Active == true)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">@Snapshot.Emergency.Status</MudAlert>
    }
    @if (Snapshot?.FrontDoorKillSwitch.Active == true || Snapshot?.FrontDoorKillSwitch.PersonDetected == true)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">@Snapshot.FrontDoorKillSwitch.Status</MudAlert>
    }

    @if (Snapshot?.DefenderEnabled == true)
    {
    @* ---------- Live readings ---------- *@
    <SectionCard Title="Live readings" Help="The real dining-room thermostat right now.">
        <MudGrid Spacing="2">
            @foreach (var metric in ReadingMetrics)
            {
                <MetricCard Label="@metric.Label" Value="@metric.Value" Help="@metric.Help" Sm="4" Md="3" Lg="3" />
            }
        </MudGrid>
    </SectionCard>
    }
    else
    {
        <SectionCard Title="Guard post standby"
                     Subtitle="Defender is paused"
                     Help="Live tactical doodads are hidden while the crew is standing down. Very hush-hush, very snack-based.">
            <MudButton Class="@DefenderToggleClass" Variant="Variant.Filled" Color="@DefenderToggleColor"
                       Size="Size.Large" StartIcon="@DefenderToggleIcon" OnClick="ToggleDefender">
                @DefenderToggleText
            </MudButton>
        </SectionCard>
    }

    <MudGrid Spacing="3">
        @* ---------- Defense at a glance ---------- *@
        @if (Snapshot?.DefenderEnabled == true)
        {
        <MudItem xs="12" lg="7">
            <SectionCard Title="Defense at a glance"
                         Subtitle="@($"{BusyGuards.Count} guard{(BusyGuards.Count == 1 ? "" : "s")} acting")"
                         Help="The guards currently holding, waiting, or shaping a correction.">
                <Actions>
                    <MudButton Href="/defense" Variant="Variant.Text" Size="Size.Small" EndIcon="@Icons.Material.Filled.ArrowForward">Open board</MudButton>
                </Actions>
                <ChildContent>
                    @if (BusyGuards.Count > 0)
                    {
                        <MudStack Spacing="1">
                            @foreach (var item in BusyGuards)
                            {
                                <div class="glance-row">
                                    <span class="guard-dot guard-dot--@item.View.Tone.Css()"></span>
                                    <span class="glance-row__name">@item.Info.Name</span>
                                    <MudChip T="string" Size="Size.Small" Color="@item.View.Tone.ToColor()" Variant="Variant.Outlined">@item.View.StateLabel</MudChip>
                                    <span class="glance-row__status helper-text">@item.View.StatusText</span>
                                </div>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Class="helper-text">All guards are calm — the defender is just watching.</MudText>
                    }
                </ChildContent>
            </SectionCard>
        </MudItem>
        }

        @* ---------- Quick controls ---------- *@
        <MudItem xs="12" lg="@(Snapshot?.DefenderEnabled == true ? 5 : 12)">
            <SectionCard Title="Quick controls" Help="These talk to the real dining-room thermostat.">
                <MudStack Spacing="2">
                    <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshReal" StartIcon="@Icons.Material.Filled.Refresh">Refresh reading</MudButton>
                    <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ForceTarget" StartIcon="@Icons.Material.Filled.TrackChanges">Force exact target</MudButton>
                    <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ForceBoost" StartIcon="@Icons.Material.Filled.AcUnit">Force cooling</MudButton>
                    <MudButton FullWidth="true" Variant="Variant.Text" Href="/controls" EndIcon="@Icons.Material.Filled.ArrowForward">All controls</MudButton>
                </MudStack>
            </SectionCard>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private double _targetInput = 22.0;
    private bool _targetDirty;

    private DefenderSnapshot? Snapshot => State.Snapshot;

    private string TargetText => Snapshot is null ? "-- C" : $"{Snapshot.TargetTemperatureCelsius:0.0} C";
    private string ConnectionText => Snapshot?.ConnectionState == "home-assistant" ? "Home Assistant" : Snapshot?.ConnectionState ?? "--";
    private Color ConnectionColor => Snapshot?.ConnectionState == "home-assistant" ? Color.Success : Color.Error;
    private string NextActionText => Snapshot?.NextAction ?? "Waiting for defender status.";
    private bool DefenderIsEnabled => Snapshot?.DefenderEnabled == true;
    private string DefenderToggleText => DefenderIsEnabled ? "Stand Down Defender" : "Activate Defender";
    private string DefenderToggleHelp => DefenderIsEnabled ? "Green means the guard post is awake." : "Red means paused. Tap to wake the tiny guard shift.";
    private string DefenderToggleIcon => DefenderIsEnabled ? Icons.Material.Filled.Shield : Icons.Material.Filled.PowerSettingsNew;
    private Color DefenderToggleColor => DefenderIsEnabled ? Color.Success : Color.Error;
    private string DefenderToggleClass => DefenderIsEnabled ? "defender-toggle defender-toggle--active" : "defender-toggle defender-toggle--paused";

    private IReadOnlyList<MetricItem> ReadingMetrics =>
    [
        new("Room", Format.Temp(Snapshot?.HomeAssistantThermostat?.CurrentTemperatureCelsius), "How warm the dining room is."),
        new("Setpoint", Format.Temp(Snapshot?.HomeAssistantThermostat?.SetPointCelsius), "What the thermostat is set to."),
        new("Outdoor", Format.Temp(Snapshot?.Weather?.OutdoorTemperatureCelsius), "How warm it is outside."),
        new("Weather", Snapshot?.Weather?.Condition ?? "--", "What the weather looks like now."),
        new("Mode", Snapshot?.HomeAssistantThermostat?.HvacMode ?? "--", "The AC must stay on cool while active."),
        new("Action", Snapshot?.HomeAssistantThermostat?.HvacAction ?? "--", "What the thermostat is doing."),
        new("Fan", Snapshot?.HomeAssistantThermostat?.FanMode ?? "--", "How the fan is blowing air."),
        new("Cooldown", Snapshot?.CooldownSeconds > 0 ? $"{Snapshot.CooldownSeconds}s" : "Ready", "A short wait before fixing again."),
    ];

    private record BusyGuard(GuardInfo Info, GuardLiveView View);

    private IReadOnlyList<BusyGuard> BusyGuards =>
        Snapshot is null
            ? Array.Empty<BusyGuard>()
            : GuardCatalog.Live
                .Select(g => new BusyGuard(g, g.Project!(Snapshot)))
                .Where(x => x.View.Busy)
                .ToList();

    protected override void OnInitialized()
    {
        _targetInput = Snapshot?.TargetTemperatureCelsius ?? 22.0;
        State.Changed += OnStateChanged;
    }

    private void OnStateChanged()
    {
        if (!_targetDirty && Snapshot is not null)
        {
            _targetInput = Snapshot.TargetTemperatureCelsius;
        }

        InvokeAsync(StateHasChanged);
    }

    private void OnTargetInputChanged(double value)
    {
        _targetInput = value;
        _targetDirty = true;
    }

    private void GenerateTarget()
    {
        if (!TryBeginWebsiteCommand("generate target"))
        {
            return;
        }

        var snapshot = StateStore.GenerateTarget();
        State.Refresh();
        _targetInput = snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
        Snackbar.Add("Generated a new target.", Severity.Success);
    }

    private void ApplyTarget()
    {
        if (!TryBeginWebsiteCommand("set target"))
        {
            return;
        }

        var snapshot = StateStore.SetTarget(_targetInput);
        State.Refresh();
        _targetInput = snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
        Snackbar.Add("Target saved.", Severity.Success);
    }

    private Task ToggleDefender() => SetDefenderEnabled(!DefenderIsEnabled);

    private async Task SetDefenderEnabled(bool enabled)
    {
        if (!TryBeginWebsiteCommand(enabled ? "turn defender on" : "pause defender", bypassDebounce: true))
        {
            return;
        }

        StateStore.SetDefenderEnabled(enabled);
        State.Refresh();
        Snackbar.Add(enabled ? "Defender turned on." : "Defender paused.", Severity.Info);

        if (enabled)
        {
            return;
        }

        var turnOff = await DialogService.ShowMessageBoxAsync(
            "Turn off the real thermostat too?",
            "The defender is paused now. Do you also want to send a real Home Assistant command to turn the thermostat off?",
            yesText: "Turn thermostat off",
            cancelText: "Leave thermostat on");

        if (turnOff == true)
        {
            await RunThermostatAction(() => Defender.TurnThermostatOffAsync(CancellationToken.None), "Thermostat turned off.", "turn thermostat off");
        }
    }

    private Task RefreshReal() => RunThermostatAction(() => Defender.RefreshRealThermostatAsync(CancellationToken.None), "Thermostat refreshed.", "refresh thermostat", bypassDebounce: true);
    private Task ForceTarget() => RunThermostatAction(() => Defender.ForceTargetAsync(CancellationToken.None), "Exact target sent.", "force exact target");
    private Task ForceBoost() => RunThermostatAction(() => Defender.ForceCoolingBoostAsync(CancellationToken.None), "Cooling boost sent.", "force cooling");

    private bool TryBeginWebsiteCommand(string actionName, bool bypassDebounce = false)
    {
        var gate = StateStore.TryBeginWebsiteCommand(actionName, bypassDebounce);
        State.Refresh();
        if (gate.Accepted)
        {
            return true;
        }

        Snackbar.Add(gate.Message, Severity.Warning);
        return false;
    }

    private async Task RunThermostatAction(Func<Task> action, string successMessage, string actionName, bool bypassDebounce = false)
    {
        if (!TryBeginWebsiteCommand(actionName, bypassDebounce))
        {
            return;
        }

        try
        {
            await action();
            State.Refresh();
            if (!_targetDirty)
            {
                _targetInput = Snapshot?.TargetTemperatureCelsius ?? _targetInput;
            }

            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception ex)
        {
            StateStore.RecordHomeAssistantUnavailable($"Home Assistant error: {ex.Message}");
            State.Refresh();
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    public void Dispose() => State.Changed -= OnStateChanged;
}
