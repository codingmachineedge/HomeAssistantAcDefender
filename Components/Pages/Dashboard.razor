    // ---------- telemetry ----------

    private sealed record TelemetryRow(string Label, string Value, string Bar, string BarCss, string ValueCss);

    private IReadOnlyList<TelemetryRow> Telemetry
    {
        get
        {
            if (!DefenderIsEnabled)
            {
                return [new TelemetryRow("DEFENDER", "OFFLINE", "0%", "ops-bar__fill--sub", "")];
            }

            var t = Snapshot?.HomeAssistantThermostat;
            var rows = new List<TelemetryRow>();

            if (t is not null)
            {
                rows.Add(new TelemetryRow("ROOM TEMP", $"{t.CurrentTemperatureCelsius:0.0}°C",
                    Pct(t.CurrentTemperatureCelsius, 16, 32), IsAlert ? "ops-bar__fill--bad" : "", ""));
                rows.Add(new TelemetryRow("SETPOINT", $"{t.SetPointCelsius:0.0}°C",
                    Pct(t.SetPointCelsius, 16, 30), "", "ops-telemetry__value--accent"));
            }

            if (Snapshot?.Weather?.OutdoorTemperatureCelsius is { } o)
            {
                rows.Add(new TelemetryRow("OUTDOOR", $"{o:0.0}°C", Pct(o, 0, 40), "ops-bar__fill--warn", ""));
            }

            if (Snapshot?.Comfort.HottestUpstairsTemperatureCelsius is { } up)
            {
                rows.Add(new TelemetryRow("UPSTAIRS MAX", $"{up:0.0}°C", Pct(up, 16, 32), "ops-bar__fill--warn", ""));
            }

            var action = t?.HvacAction ?? "--";
            var cooling = string.Equals(action, "cooling", StringComparison.OrdinalIgnoreCase);
            rows.Add(new TelemetryRow("HVAC ACTION",
                IsAlert && !cooling ? $"{action.ToUpperInvariant()} ⚠" : action.ToUpperInvariant(),
                IsAlert && !cooling ? "4%" : cooling ? "70%" : "10%",
                IsAlert && !cooling ? "ops-bar__fill--bad" : cooling ? "ops-bar__fill--good" : "ops-bar__fill--warn",
                IsAlert && !cooling ? "ops-telemetry__value--bad" : cooling ? "ops-telemetry__value--good" : "ops-telemetry__value--warn"));

            if (Snapshot?.CooldownSeconds > 0)
            {
                rows.Add(new TelemetryRow("COOLDOWN", $"{Snapshot.CooldownSeconds}s", Pct(Snapshot.CooldownSeconds, 0, 600), "ops-bar__fill--sub", ""));
            }

            return rows;

            static string Pct(double value, double min, double max) =>
                $"{Math.Clamp((value - min) / (max - min) * 100, 2, 100).ToString("0", System.Globalization.CultureInfo.InvariantCulture)}%";
        }
    }

    // ---------- commands (same plumbing as before the redesign) ----------

    private async Task OnTargetInputChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var v))
        {
            _targetInput = Math.Clamp(v, 10, 35);
            _targetDirty = true;
            await SaveTarget(_targetInput);
        }
    }

    private Task TargetUp() => SaveTarget(Target + 0.5);
    private Task TargetDown() => SaveTarget(Target - 0.5);

    private async Task SaveTarget(double value)
    {
        if (!TryBeginWebsiteCommand("set target", bypassDebounce: true))
        {
            return;
        }

        var snapshot = await Defender.SetTargetAsync(Math.Clamp(value, 10, 35), CancellationToken.None);
        State.Refresh();
        _targetInput = snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
    }

    private async Task GenerateTarget()
    {
        if (!TryBeginWebsiteCommand("generate target", bypassDebounce: true))
        {
            return;
        }

        var snapshot = await Defender.GenerateTargetAsync(CancellationToken.None);
        State.Refresh();
        _targetInput = snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
        Snackbar.Add("Generated a new target.", Severity.Success);
    }

    private async Task ApplyTarget()
    {
        if (!TryBeginWebsiteCommand("set target", bypassDebounce: true))
        {
            return;
        }

        var snapshot = await Defender.SetTargetAsync(_targetDirty ? _targetInput : Target, CancellationToken.None);
        State.Refresh();
        _targetInput = snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
        await RunThermostatAction(() => Defender.ForceTargetAsync(CancellationToken.None), "Target applied to the wall unit.", "force exact target");
    }

