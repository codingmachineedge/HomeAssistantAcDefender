@page "/"
@implements IDisposable
@inject DefenderStateStore StateStore
@inject AcDefenderService Defender
@inject HomeAssistantClient HomeAssistant
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Dashboard - Home Assistant AC Defender</PageTitle>

<MudStack Spacing="2" Class="dashboard-shell">
    <MudPaper Class="panel-card compact-panel dashboard-status-panel">
        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
            <div>
                <MudText Typo="Typo.overline">Generated Target</MudText>
                <MudText Typo="Typo.h2" Class="target-readout">@TargetText</MudText>
                <MudText Typo="Typo.body2" Class="helper-text">This is the cool number the defender is trying to keep.</MudText>
            </div>
            <div>
                <MudChip T="string" Color="@ConnectionColor" Variant="Variant.Filled">@ConnectionText</MudChip>
                <MudSwitch T="bool"
                           Value="@(Snapshot?.DefenderEnabled ?? false)"
                           ValueChanged="SetDefenderEnabled"
                           Label="Defender active"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">The switch turns the helper on or pauses it.</MudText>
            </div>
        </MudStack>

        <MudGrid Spacing="2" Class="mt-2 compact-reading-grid">
            @foreach (var metric in SummaryMetrics)
            {
                <MudItem xs="6" sm="3">
                    <div class="reading-tile">
                        <MudText Typo="Typo.overline">@metric.Label</MudText>
                        <MudText Typo="Typo.subtitle1">@metric.Value</MudText>
                        <MudText Typo="Typo.caption" Class="helper-text">@metric.Help</MudText>
                    </div>
                </MudItem>
            }
        </MudGrid>

        <MudAlert Class="mt-2" Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">@NextActionText</MudAlert>
        <MudText Typo="Typo.caption" Class="helper-text">This tells what the defender plans to do next.</MudText>

    </MudPaper>

    <MudTabs Class="app-tabs" Elevation="0" Rounded="true">
        <MudTabPanel Text="Overview">
            <MudGrid Spacing="2">
                <MudItem xs="12" lg="7">
                    <MudPaper Class="panel-card">
                        <MudText Typo="Typo.overline">Priority Status</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">The few messages most worth seeing first.</MudText>
                        <MudStack Spacing="1" Class="mt-2">
                            @foreach (var item in PriorityStatuses)
                            {
                                <MudAlert Severity="@item.Severity" Variant="Variant.Outlined" Dense="true">
                                    <MudText Typo="Typo.subtitle2">@item.Name</MudText>
                                    <MudText Typo="Typo.body2">@item.Status</MudText>
                                </MudAlert>
                                <MudText Typo="Typo.caption" Class="helper-text">@item.Help</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="5">
                    <MudPaper Class="panel-card">
                        <MudText Typo="Typo.overline">Quick Real Controls</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">These buttons talk to the real dining room thermostat.</MudText>
                        <MudGrid Spacing="2" Class="mt-2">
                            <MudItem xs="12" sm="4" lg="12">
                                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshReal" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Asks Home Assistant for the newest thermostat reading.</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="4" lg="12">
                                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ForceTarget" StartIcon="@Icons.Material.Filled.TrackChanges">Force target</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Sets the thermostat to the exact website target now.</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="4" lg="12">
                                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ForceBoost" StartIcon="@Icons.Material.Filled.AcUnit">Force cooling</MudButton>
                                <MudText Typo="Typo.caption" Class="helper-text">Uses the current-room-minus-1 C cooling push right now.</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Defense">
            <MudPaper Class="panel-card">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
                    <div>
                        <MudText Typo="Typo.overline">Natural Defender</MudText>
                        <MudText Typo="Typo.h5">Searchable timing, touch, and safety guards</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">Search for words like cooldown, touch, weather, fan, runway, or echo.</MudText>
                    </div>
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@DefenseResultText</MudChip>
                </MudStack>
                <MudTextField T="string"
                              @bind-Value="_defenseSearch"
                              Immediate="true"
                              Clearable="true"
                              Placeholder="Search defender guards"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Class="mt-2" />

                <MudGrid Spacing="2" Class="mt-2">
                    @foreach (var metric in FilteredDefenseMetrics)
                    {
                        <MetricCard Label="@metric.Label" Value="@metric.Value" Help="@metric.Help" />
                    }
                </MudGrid>

                <MudStack Spacing="1" Class="scroll-list tall-list mt-3">
                    @foreach (var item in FilteredDefenseStatuses)
                    {
                        <MudAlert Severity="@item.Severity" Variant="Variant.Outlined" Dense="true">
                            <MudText Typo="Typo.subtitle2">@item.Name</MudText>
                            <MudText Typo="Typo.body2">@item.Status</MudText>
                        </MudAlert>
                        <MudText Typo="Typo.caption" Class="helper-text">@item.Help</MudText>
                    }
                    @if (!FilteredDefenseStatuses.Any())
                    {
                        <MudText Class="helper-text">No defender status matches that search.</MudText>
                    }
                </MudStack>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Comfort">
            <MudGrid Spacing="2">
                <MudItem xs="12" lg="6">
                    <MudPaper Class="panel-card">
                        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
                            <div>
                                <MudText Typo="Typo.overline">Upstairs Comfort</MudText>
                                <MudText Typo="Typo.h5">@(Snapshot?.Comfort.Status ?? "Waiting for upstairs readings")</MudText>
                                <MudText Typo="Typo.body2" Class="helper-text">This helps stop upstairs from feeling too hot.</MudText>
                            </div>
                            <MudChip T="string" Color="@(Snapshot?.Comfort.IsHome == true ? Color.Success : Color.Warning)" Variant="Variant.Filled">@HomePresenceText</MudChip>
                        </MudStack>

                        <MudGrid Spacing="2" Class="mt-2">
                            @foreach (var metric in ComfortMetrics)
                            {
                                <MetricCard Label="@metric.Label" Value="@metric.Value" Help="@metric.Help" />
                            }
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="6">
                    <MudPaper Class="panel-card">
                        <MudText Typo="Typo.overline">Upstairs Sensors</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">The warmest sensors are easiest to scan here.</MudText>
                        <MudStack Spacing="1" Class="scroll-list mt-2">
                            @if (Snapshot?.Comfort.UpstairsSensors?.Count > 0)
                            {
                                @foreach (var sensor in Snapshot.Comfort.UpstairsSensors)
                                {
                                    <MudPaper Class="sensor-row" Outlined="true">
                                        <MudText Typo="Typo.subtitle2">@sensor.Name</MudText>
                                        <MudText Typo="Typo.body2">@SensorValue(sensor)</MudText>
                                    </MudPaper>
                                }
                            }
                            else
                            {
                                <MudText Class="helper-text">No upstairs sensors found or configured.</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Energy">
            <MudPaper Class="panel-card">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="wrap-gap">
                    <div>
                        <MudText Typo="Typo.overline">Energy Usage</MudText>
                        <MudText Typo="Typo.h5">Home Assistant live sensors</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">Reads configured usage sensors, such as the Alectra Hui power, energy, and cost entities.</MudText>
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshUsageNow" StartIcon="@Icons.Material.Filled.Refresh">Refresh usage</MudButton>
                </MudStack>
                <MudText Typo="Typo.caption" Class="helper-text">Pulls fresh usage and history from Home Assistant.</MudText>

                <MudGrid Spacing="2" Class="mt-2">
                    @foreach (var metric in EnergyMetrics)
                    {
                        <MetricCard Label="@metric.Label" Value="@metric.Value" Help="@metric.Help" />
                    }
                </MudGrid>

                @if (!string.IsNullOrWhiteSpace(UsageError))
                {
                    <MudAlert Class="mt-3" Severity="Severity.Warning" Variant="Variant.Outlined">@UsageError</MudAlert>
                }
                @if (!string.IsNullOrWhiteSpace(UsageHistoryError))
                {
                    <MudAlert Class="mt-3" Severity="Severity.Warning" Variant="Variant.Outlined">@UsageHistoryError</MudAlert>
                }
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Logs">
            <MudGrid Spacing="2">
                <MudItem xs="12" lg="6">
                    <MudPaper Class="panel-card">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="wrap-gap">
                            <div>
                                <MudText Typo="Typo.overline">Thermostat Touch Log</MudText>
                                <MudText Typo="Typo.h5">External changes</MudText>
                                <MudText Typo="Typo.body2" Class="helper-text">Search by temperature, room, outdoor, weather, or time.</MudText>
                            </div>
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined">@FilteredTouchCount</MudChip>
                        </MudStack>
                        <MudTextField T="string"
                                      @bind-Value="_touchSearch"
                                      Immediate="true"
                                      Clearable="true"
                                      Placeholder="Search wall touches"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined"
                                      Class="mt-2" />

                        <MudStack Spacing="1" Class="scroll-list tall-list mt-2">
                            @if (FilteredThermostatChanges.Any())
                            {
                                @foreach (var change in FilteredThermostatChanges)
                                {
                                    <MudPaper Class="touch-row" Outlined="true">
                                        <MudText Typo="Typo.subtitle2">@($"{change.PreviousSetPointCelsius:0.0} C -> {change.NewSetPointCelsius:0.0} C")</MudText>
                                        <MudText Typo="Typo.caption">@DateTimeText(change.Timestamp)</MudText>
                                        <MudText Typo="Typo.caption">@($"{Temp(change.RoomTemperatureCelsius)} room / {Temp(change.OutdoorTemperatureCelsius)} outdoor / {change.WeatherCondition ?? "weather --"}")</MudText>
                                    </MudPaper>
                                }
                            }
                            else
                            {
                                <MudText Class="helper-text">No external thermostat changes match.</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="6">
                    <MudPaper Class="panel-card">
                        <MudText Typo="Typo.overline">Activity</MudText>
                        <MudText Typo="Typo.body2" Class="helper-text">Search the story of what the defender has been doing.</MudText>
                        <MudTextField T="string"
                                      @bind-Value="_eventSearch"
                                      Immediate="true"
                                      Clearable="true"
                                      Placeholder="Search activity"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined"
                                      Class="mt-2" />

                        <MudStack Spacing="1" Class="scroll-list tall-list mt-2">
                            @if (FilteredEvents.Any())
                            {
                                @foreach (var item in FilteredEvents)
                                {
                                    <MudAlert Severity="@EventSeverity(item.Level)" Variant="Variant.Outlined" Dense="true">
                                        <MudText Typo="Typo.caption">@DateTimeText(item.Timestamp)</MudText>
                                        <MudText Typo="Typo.body2">@item.Message</MudText>
                                    </MudAlert>
                                }
                            }
                            else
                            {
                                <MudText Class="helper-text">No activity matches.</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Controls">
            <MudPaper Class="panel-card">
                <MudText Typo="Typo.overline">Real Thermostat Controls</MudText>
                <MudText Typo="Typo.h5">Dining room climate</MudText>
                <MudText Typo="Typo.body2" Class="helper-text">These controls send real Home Assistant service calls.</MudText>

                <MudGrid Spacing="2" Class="mt-2">
                    <MudItem xs="12" md="6">
                        <MudNumericField T="double"
                                         Value="_targetInput"
                                         ValueChanged="OnTargetInputChanged"
                                         Label="Set target"
                                         HelperText="Type the temperature you want, like picking a number on a toy dial."
                                         Variant="Variant.Outlined"
                                         Min="10"
                                         Max="35"
                                         Step="0.1"
                                         Adornment="Adornment.End"
                                         AdornmentText="C" />
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ApplyTarget" StartIcon="@Icons.Material.Filled.Check">Apply</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Sends the number to the defender.</MudText>
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateTarget" StartIcon="@Icons.Material.Filled.AutoAwesome">Generate</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Lets the website pick a comfy number.</MudText>
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudSelect T="string" @bind-Value="_fanMode" Label="Fan mode" HelperText="Pick how the fan should blow air." Variant="Variant.Outlined">
                            @foreach (var mode in FanModes)
                            {
                                <MudSelectItem T="string" Value="@mode">@mode</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ApplyFanMode" StartIcon="@Icons.Material.Filled.Air">Set fan</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Sends the fan choice to the thermostat.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshReal" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Asks Home Assistant for the newest thermostat reading.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ForceTarget" StartIcon="@Icons.Material.Filled.TrackChanges">Force target</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Sets the thermostat to the exact target now.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ForceBoost" StartIcon="@Icons.Material.Filled.AcUnit">Force cooling</MudButton>
                        <MudText Typo="Typo.caption" Class="helper-text">Sets the thermostat one degree below current room temp when cooling is needed.</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
</MudStack>

@code {
    private PeriodicTimer? timer;
    private CancellationTokenSource? timerCancellation;
    private DefenderSnapshot? Snapshot { get; set; }
    private UsageLiveSnapshot? Usage { get; set; }
    private UsageHistorySnapshot? UsageHistory { get; set; }
    private DateTimeOffset? UsageHistoryUpdatedAt { get; set; }
    private string? UsageError { get; set; }
    private string? UsageHistoryError { get; set; }
    private DateTimeOffset _nextUsageRefresh = DateTimeOffset.MinValue;
    private DateTimeOffset _nextUsageHistoryRefresh = DateTimeOffset.MinValue;
    private double _targetInput = 22.0;
    private bool _targetDirty;
    private string? _fanMode;
    private string _defenseSearch = "";
    private string _touchSearch = "";
    private string _eventSearch = "";

    private string TargetText => Snapshot is null ? "-- C" : $"{Snapshot.TargetTemperatureCelsius:0.0} C";
    private string EntityText => Snapshot?.HomeAssistantEntityId ?? "No entity";
    private string ConnectionText => Snapshot?.ConnectionState ?? "--";
    private string CooldownText => Snapshot?.CooldownSeconds > 0 ? $"{Snapshot.CooldownSeconds}s" : "Ready";
    private string NextActionText => Snapshot?.NextAction ?? "Waiting for defender status.";
    private string NaturalRecoveryText => Snapshot?.NaturalRecovery.Status ?? "Comfort sync is waiting for status.";
    private string NaturalWalkbackText => Snapshot?.NaturalWalkback.Status ?? "Natural walkback is watching.";
    private string NaturalWalkbackScoreText => Snapshot?.NaturalWalkback.Enabled == true ? $"{Snapshot.NaturalWalkback.SuspicionScore}/100" : "Off";
    private string NaturalWalkbackStepText => Snapshot?.NaturalWalkback.Enabled == true ? $"{Snapshot.NaturalWalkback.StepCelsius:0.0} C" : "Off";
    private string TouchSignatureText => Snapshot?.TouchSignature.Status ?? "Touch signature is watching.";
    private string TouchSignatureStepText => Snapshot?.TouchSignature.LearnedStepCelsius is { } step ? $"{step:0.0} C" : Snapshot?.TouchSignature.Enabled == true ? "--" : "Off";
    private string TouchSignatureSamplesText => Snapshot?.TouchSignature.Enabled == true ? Snapshot.TouchSignature.SampleCount.ToString() : "Off";
    private string VisibilityGuardText => Snapshot?.VisibilityGuard.Status ?? "Visibility guard is watching.";
    private string VisibilityGuardWaitText => Snapshot?.VisibilityGuard.Active == true ? $"{Snapshot.VisibilityGuard.SecondsRemaining}s" : "Ready";
    private string VisibilityGuardPressureText => Snapshot?.VisibilityGuard.Enabled == true ? $"{Snapshot.VisibilityGuard.Pressure}/100" : "Off";
    private string RoutineTimingText => Snapshot?.RoutineTiming.Status ?? "Routine timing is watching.";
    private string RoutineTimingWaitText => Snapshot?.RoutineTiming.Waiting == true ? $"{Snapshot.RoutineTiming.SecondsRemaining}s" : "Ready";
    private string RoutineTimingRhythmText => Snapshot?.RoutineTiming.Enabled == true ? $"{Snapshot.RoutineTiming.IntervalMinutes}+{Snapshot.RoutineTiming.JitterMinutes} min" : "Off";
    private string ComfortBudgetText => Snapshot?.ComfortBudget.Status ?? "Comfort budget is watching.";
    private string ComfortBudgetWaitText => Snapshot?.ComfortBudget.Holding == true ? $"{Snapshot.ComfortBudget.SecondsRemaining}s" : "Ready";
    private string ComfortBudgetUsedText => Snapshot?.ComfortBudget.Enabled == true ? $"{Snapshot.ComfortBudget.RecentCommandCount}/{Snapshot.ComfortBudget.MaxCommands}" : "Off";
    private string NaturalCadenceText => Snapshot?.NaturalCadence.Status ?? "Natural cadence is watching.";
    private string NaturalCadenceWaitText => Snapshot?.NaturalCadence.Waiting == true ? $"{Snapshot.NaturalCadence.SecondsRemaining}s" : "Ready";
    private string NaturalCadencePressureText => Snapshot?.NaturalCadence.Enabled == true ? $"{Snapshot.NaturalCadence.TouchPressure}/100" : "Off";
    private string ComfortCompromiseText => Snapshot?.ComfortCompromise.Status ?? "Comfort compromise is watching.";
    private string ComfortCompromiseTargetText => Snapshot?.ComfortCompromise.EffectiveTargetCelsius is { } target ? $"{target:0.0} C" : "Ready";
    private string ComfortCompromiseWaitText => Snapshot?.ComfortCompromise.Active == true ? $"{Snapshot.ComfortCompromise.SecondsRemaining}s" : "Ready";
    private string ComfortMemoryText => Snapshot?.ComfortMemory.Status ?? "Comfort memory is watching.";
    private string ComfortMemoryOffsetText => Snapshot?.ComfortMemory.LearnedOffsetCelsius is { } offset ? $"{offset:+0.0;-0.0;0.0} C" : "Ready";
    private string ComfortMemoryTargetText => Snapshot?.ComfortMemory.EffectiveTargetCelsius is { } target ? $"{target:0.0} C" : "Ready";
    private string CoolModeRestoreText => Snapshot?.CoolModeRestore.Status ?? "Cool mode restore is watching.";
    private string CoolModeRestoreWaitText => Snapshot?.CoolModeRestore.Waiting == true ? $"{Snapshot.CoolModeRestore.SecondsRemaining}s" : "Ready";
    private string QuietLevelText => Snapshot?.NaturalRecovery.Enabled == true ? Snapshot.NaturalRecovery.QuietLevel : "Off";
    private string NaturalWaitText => Snapshot?.NaturalRecovery.Waiting == true ? $"{Snapshot.NaturalRecovery.SecondsRemaining}s" : "Ready";
    private string RecentTouchText => (Snapshot?.NaturalRecovery.RecentTouchCount ?? 0).ToString();
    private string NaturalStepText => Snapshot?.NaturalRecovery.Enabled == true ? $"{Snapshot.NaturalRecovery.EffectiveStepCelsius:0.0} C" : "Off";
    private string HoldChanceText => Snapshot?.NaturalRecovery.Enabled == true ? $"{Snapshot.NaturalRecovery.EffectiveHoldChancePercent}%" : "Off";
    private string CommandGapText => Snapshot?.NaturalRecovery.Enabled == true ? $"{Snapshot.NaturalRecovery.EffectiveCommandGapSeconds}s" : "Off";
    private string ConflictQuietText => Snapshot?.ConflictQuiet.Status ?? "Conflict quiet is watching.";
    private string ConflictQuietWaitText => Snapshot?.ConflictQuiet.Active == true ? $"{Snapshot.ConflictQuiet.SecondsRemaining}s" : "Ready";
    private string ManualGraceText => Snapshot?.ManualComfortGrace.Status ?? "No wall-change grace active.";
    private string ManualGraceWaitText => Snapshot?.ManualComfortGrace.Active == true ? $"{Snapshot.ManualComfortGrace.SecondsRemaining}s" : "Ready";
    private string TouchIntentText => Snapshot?.TouchIntent.Status ?? "Touch intent is watching.";
    private string TouchIntentDirectionText => Snapshot?.TouchIntent.Enabled == true ? Snapshot.TouchIntent.Direction : "Off";
    private string TouchIntentGraceText => Snapshot?.TouchIntent.Enabled == true ? $"+{Snapshot.TouchIntent.ExtraGraceMinutes} min" : "Off";
    private string CoolerIntentText => Snapshot?.CoolerIntent.Status ?? "Cooler intent fast lane is watching.";
    private string CoolerIntentWaitText => Snapshot?.CoolerIntent.Active == true ? $"{Snapshot.CoolerIntent.SecondsRemaining}s" : Snapshot?.CoolerIntent.Enabled == true ? "Ready" : "Off";
    private string CoolerIntentNetText => Snapshot?.CoolerIntent.Enabled == true ? $"{Snapshot.CoolerIntent.NetChangeCelsius:+0.0;-0.0;0.0} C" : "Off";
    private string SetpointEchoText => Snapshot?.SetpointEcho.Status ?? "Setpoint echo is watching.";
    private string SetpointEchoWaitText => Snapshot?.SetpointEcho.Waiting == true ? $"{Snapshot.SetpointEcho.SecondsRemaining}s" : "Ready";
    private string SetpointEchoTargetText => Snapshot?.SetpointEcho.PendingSetPointCelsius is { } target ? $"{target:0.0} C" : "Ready";
    private string RepeatCommandText => Snapshot?.RepeatCommand.Status ?? "Repeat quiet is watching for identical follow-up commands.";
    private string RepeatCommandWaitText => Snapshot?.RepeatCommand.Holding == true ? $"{Snapshot.RepeatCommand.SecondsRemaining}s" : "Ready";
    private string RepeatCommandPressureText => Snapshot?.RepeatCommand.Enabled == true ? $"{Snapshot.RepeatCommand.Pressure}/100" : "Off";
    private string SensorRhythmText => Snapshot?.SensorRhythm.Status ?? "Sensor rhythm is watching.";
    private string SensorRhythmWaitText => Snapshot?.SensorRhythm.Waiting == true ? $"{Snapshot.SensorRhythm.SecondsRemaining}s" : "Ready";
    private string SensorRhythmBeatText => Snapshot?.SensorRhythm.Enabled == true && Snapshot.SensorRhythm.MedianIntervalSeconds > 0
        ? $"{Snapshot.SensorRhythm.MedianIntervalSeconds}s"
        : Snapshot?.SensorRhythm.Enabled == true ? "--" : "Off";
    private string CoolingRunwayText => Snapshot?.CoolingRunway.Status ?? "Cooling runway is watching for a fresh cooling start.";
    private string CoolingRunwayWaitText => Snapshot?.CoolingRunway.Holding == true ? $"{Snapshot.CoolingRunway.SecondsRemaining}s" : "Ready";
    private string CoolingRunwayPressureText => Snapshot?.CoolingRunway.Enabled == true ? $"{Snapshot.CoolingRunway.Pressure}/100" : "Off";
    private string RoomTrendText => Snapshot?.RoomTrend.Status ?? "Room trend guard is watching.";
    private string RoomTrendDirectionText => Snapshot?.RoomTrend.Enabled == true
        ? $"{Snapshot.RoomTrend.Direction} {TrendDeltaText}"
        : "Off";
    private string RoomTrendHoldText => Snapshot?.RoomTrend.Holding == true ? $"{Snapshot.RoomTrend.SecondsRemaining}s" : "Ready";
    private string ThermalMomentumText => Snapshot?.ThermalMomentum.Status ?? "Thermal momentum guard is watching.";
