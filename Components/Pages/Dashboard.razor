    protected override void OnInitialized()
    {
        RefreshSnapshot(updateInputs: true);
        _ = RefreshUsageAsync();
        _ = RefreshUsageHistoryAsync();
        timerCancellation = new CancellationTokenSource();
        timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = PollAsync(timerCancellation.Token);
    }

    private async Task PollAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (timer is not null && await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    RefreshSnapshot(updateInputs: !_targetDirty);
                    await RefreshUsageIfDueAsync();
                    await RefreshUsageHistoryIfDueAsync();
                    ShowCoolingFailureSnackbarIfDue();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void ShowCoolingFailureSnackbarIfDue()
    {
        if (Snapshot?.CoolingFailure.Alerting != true)
        {
            _lastCoolingFailureSnackbarAt = null;
            return;
        }

        var now = DateTimeOffset.UtcNow;
        if (_lastCoolingFailureSnackbarAt is { } last && now - last < TimeSpan.FromSeconds(60))
        {
            return;
        }

        _lastCoolingFailureSnackbarAt = now;
        Snackbar.Add(Snapshot.CoolingFailure.Status, Severity.Error, options =>
        {
            options.RequireInteraction = true;
            options.VisibleStateDuration = 15000;
        });
    }

    private void RefreshSnapshot(bool updateInputs)
    {
        Snapshot = StateStore.GetSnapshot();
        if (updateInputs)
        {
            _targetInput = Snapshot.TargetTemperatureCelsius;
        }

        var currentFan = Snapshot.HomeAssistantThermostat?.FanMode;
        if (!string.IsNullOrWhiteSpace(currentFan) && string.IsNullOrWhiteSpace(_fanMode))
        {
            _fanMode = currentFan;
        }
        else if (string.IsNullOrWhiteSpace(_fanMode))
        {
            _fanMode = FanModes.FirstOrDefault();
        }
    }

    private async Task RefreshUsageNow()
    {
        await RefreshUsageAsync();
        await RefreshUsageHistoryAsync();
        StateHasChanged();
    }

    private async Task RefreshUsageIfDueAsync()
    {
        if (DateTimeOffset.UtcNow < _nextUsageRefresh)
        {
            return;
        }

        await RefreshUsageAsync();
    }

    private async Task RefreshUsageHistoryIfDueAsync()
    {
        if (DateTimeOffset.UtcNow < _nextUsageHistoryRefresh)
        {
            return;
        }

        await RefreshUsageHistoryAsync();
    }

    private async Task RefreshUsageAsync()
    {
        try
        {
            _nextUsageRefresh = DateTimeOffset.UtcNow.AddSeconds(30);
            Usage = await HomeAssistant.GetLiveUsageAsync(CancellationToken.None);
            UsageError = null;
        }
        catch (Exception ex)
        {
            _nextUsageRefresh = DateTimeOffset.UtcNow.AddSeconds(30);
            UsageError = $"Usage sensor error: {ex.Message}";
        }
    }

    private async Task RefreshUsageHistoryAsync()
    {
        try
        {
            var end = DateTimeOffset.UtcNow;
            _nextUsageHistoryRefresh = end.AddMinutes(10);
            UsageHistory = await HomeAssistant.GetUsageHistoryAsync(null, end.AddHours(-24), end, CancellationToken.None);
            UsageHistoryUpdatedAt = end;
            UsageHistoryError = null;
        }
        catch (Exception ex)
        {
            _nextUsageHistoryRefresh = DateTimeOffset.UtcNow.AddMinutes(10);
            UsageHistoryError = $"Usage history error: {ex.Message}";
        }
    }

    private void OnTargetInputChanged(double value)
    {
        _targetInput = value;
        _targetDirty = true;
    }

    private void GenerateTarget()
    {
        if (!TryBeginWebsiteCommand("generate target"))
        {
            return;
        }

        Snapshot = StateStore.GenerateTarget();
        _targetInput = Snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
        Snackbar.Add("Generated a new target.", Severity.Success);
    }

    private void ApplyTarget()
    {
        if (!TryBeginWebsiteCommand("set target"))
        {
            return;
        }

        Snapshot = StateStore.SetTarget(_targetInput);
        _targetInput = Snapshot.TargetTemperatureCelsius;
        _targetDirty = false;
        Snackbar.Add("Target saved.", Severity.Success);
    }

    private async Task SetDefenderEnabled(bool enabled)
    {
        if (!TryBeginWebsiteCommand(enabled ? "turn defender on" : "pause defender"))
        {
            return;
        }

        Snapshot = StateStore.SetDefenderEnabled(enabled);
        Snackbar.Add(enabled ? "Defender turned on." : "Defender paused.", Severity.Info);

        if (enabled)
        {
            return;
        }

        var turnOffThermostat = await DialogService.ShowMessageBoxAsync(
            "Turn off the real thermostat too?",
            "The defender is paused now. Do you also want to send a real Home Assistant command to turn the thermostat off?",
            yesText: "Turn thermostat off",
            cancelText: "Leave thermostat on");

        if (turnOffThermostat == true)
        {
            await TurnThermostatOff(bypassDebounce: true);
        }
    }

    private async Task RefreshReal() => await RunThermostatAction(
        () => Defender.RefreshRealThermostatAsync(CancellationToken.None),
        "Thermostat refreshed.",
        "refresh thermostat");

    private async Task ForceTarget() => await RunThermostatAction(
        () => Defender.ForceTargetAsync(CancellationToken.None),
        "Exact target sent.",
        "force exact target");

    private async Task ForceBoost() => await RunThermostatAction(
        () => Defender.ForceCoolingBoostAsync(CancellationToken.None),
        "Cooling boost sent.",
        "force cooling");

    private async Task RunEmergencyProtocol() => await RunThermostatAction(
        () => Defender.ApplyEmergencyProtocolAsync(_emergencyProtocol, CancellationToken.None),
        "Emergency protocol started.",
        $"emergency {_emergencyProtocol}",
        bypassDebounce: true);

    private async Task TurnThermostatOff(bool bypassDebounce = false) => await RunThermostatAction(
        () => Defender.TurnThermostatOffAsync(CancellationToken.None),
        "Thermostat turned off.",
        "turn thermostat off",
        bypassDebounce);

    private async Task ApplyFanMode()
    {
        if (string.IsNullOrWhiteSpace(_fanMode))
        {
            Snackbar.Add("Pick a fan mode first.", Severity.Warning);
            return;
        }

        await RunThermostatAction(
            () => Defender.ForceFanModeAsync(_fanMode, CancellationToken.None),
            "Fan mode sent.",
            $"set fan to {_fanMode}");
    }

    private bool TryBeginWebsiteCommand(string actionName, bool bypassDebounce = false)
    {
        var gate = StateStore.TryBeginWebsiteCommand(actionName, bypassDebounce);
        Snapshot = gate.Snapshot;
        if (gate.Accepted)
        {
            return true;
        }

        Snackbar.Add(gate.Message, Severity.Warning);
        return false;
    }

    private async Task RunThermostatAction(Func<Task> action, string successMessage, string actionName, bool bypassDebounce = false)
    {
        if (!TryBeginWebsiteCommand(actionName, bypassDebounce))
        {
            return;
        }

        try
        {
            await action();
            RefreshSnapshot(updateInputs: !_targetDirty);
            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception ex)
        {
            Snapshot = StateStore.RecordHomeAssistantUnavailable($"Home Assistant error: {ex.Message}");
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void SelectTouchLog(ThermostatChangeAudit change)
    {
        _selectedLogTitle = $"Wall touch {DateTimeText(change.Timestamp)}";
        _selectedLogJson = JsonSerializer.Serialize(new
        {
            Type = "thermostat-change",
            Change = change,
            Latest = BuildLogContext()
        }, LogJsonOptions);
    }

    private void SelectEventLog(DefenderEvent item)
    {
        _selectedLogTitle = $"Activity {DateTimeText(item.Timestamp)}";
        _selectedLogJson = JsonSerializer.Serialize(new
        {
            Type = "activity",
            Event = item,
            Latest = BuildLogContext()
        }, LogJsonOptions);
    }

    private void ClearSelectedLog()
    {
        _selectedLogTitle = "";
        _selectedLogJson = "";
    }

    private object BuildLogContext()
    {
        return new
        {
            Snapshot?.HomeAssistantEntityId,
            Snapshot?.HomeAssistantThermostat,
            Snapshot?.Weather,
            Snapshot?.NextAction,
            Snapshot?.LastCommand,
            Snapshot?.Emergency,
            Snapshot?.CoolingFailure
        };
    }

    private static string Temp(double? value) => value is null ? "--" : $"{value.Value:0.0} C";

    private static string UsageValue(UsageEntityReading? reading)
    {
        if (reading is null)
        {
            return "--";
        }

        if (reading.Value is null)
        {
            return string.IsNullOrWhiteSpace(reading.State) ? "--" : reading.State;
        }

        return string.IsNullOrWhiteSpace(reading.Unit)
            ? $"{reading.Value.Value:0.###}"
            : $"{reading.Value.Value:0.###} {reading.Unit}";
    }

    private static string UsageHelp(UsageEntityReading? reading)
    {
        return reading is null
            ? "Usage entity is not configured or was not found."
            : $"{reading.Name} / {reading.EntityId}";
    }

    private static string UsageHistoryValue(double? value, string? unit)
    {
        return value is null
            ? "--"
            : string.IsNullOrWhiteSpace(unit) ? $"{value.Value:0.###}" : $"{value.Value:0.###} {unit}";
    }

    private static string ShortTime(DateTimeOffset? value) => value is null ? "--" : ToTorontoTime(value.Value).ToString("HH:mm:ss");

    private static string DateTimeText(DateTimeOffset value) => ToTorontoTime(value).ToString("yyyy-MM-dd HH:mm:ss");

    private static DateTimeOffset ToTorontoTime(DateTimeOffset value)
    {
        return TimeZoneInfo.ConvertTime(value, TorontoTimeZone);
    }

    private static TimeZoneInfo ResolveTorontoTimeZone()
    {
        try
        {
            return TimeZoneInfo.FindSystemTimeZoneById("America/Toronto");
        }
        catch (TimeZoneNotFoundException)
        {
            return TimeZoneInfo.FindSystemTimeZoneById("Eastern Standard Time");
        }
    }

    private static string SensorValue(TemperatureSensorReading sensor)
    {
        return sensor.TemperatureCelsius is null ? sensor.State : $"{sensor.TemperatureCelsius.Value:0.0} C";
    }

    private static Severity EventSeverity(string level)
    {
        return level.ToLowerInvariant() switch
        {
            "warning" => Severity.Warning,
            "error" => Severity.Error,
            _ => Severity.Info
        };
    }

    private static bool MatchesSearch(string search, params string?[] values)
    {
        var terms = (search ?? string.Empty)
            .Split(' ', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        return terms.Length == 0
            || terms.All(term => values.Any(value => value?.Contains(term, StringComparison.OrdinalIgnoreCase) == true));
    }

    private sealed record MetricItem(string Label, string Value, string Help);

    private sealed record StatusItem(string Name, string Status, string Help, Severity Severity);

    public void Dispose()
    {
        timerCancellation?.Cancel();
        timer?.Dispose();
        timerCancellation?.Dispose();
    }
}
