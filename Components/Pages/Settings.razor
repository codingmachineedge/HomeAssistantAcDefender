@page "/settings"
@inject DefenderStateStore StateStore
@inject ISnackbar Snackbar

<PageTitle>Settings - Home Assistant AC Defender</PageTitle>

<MudStack Spacing="3">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="panel-card">
                <MudText Typo="Typo.overline">Automation</MudText>
                <MudText Typo="Typo.body2" Class="helper-text">Rules for when the helper works.</MudText>

                <MudSwitch T="bool"
                           Value="_scheduleEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _scheduleEnabled = v))"
                           Label="Use custom schedule"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">Turns time rules on.</MudText>

                <MudSelect T="string"
                           Value="_weatherActivationMode"
                           ValueChanged="@((string value) => SetDirty(value, v => _weatherActivationMode = v))"
                           Label="Weather activation"
                           HelperText="Weather can allow or block fixing."
                           Variant="Variant.Outlined"
                           Class="mt-3">
                    @foreach (var option in WeatherOptions)
                    {
                        <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
                    }
                </MudSelect>

                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="int"
                                         Value="_baseCooldownSeconds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _baseCooldownSeconds = v))"
                                         Label="Base cooldown seconds"
                                         HelperText="First wait after a touch."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="3600" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="int"
                                         Value="_maxCooldownSeconds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _maxCooldownSeconds = v))"
                                         Label="Max cooldown seconds"
                                         HelperText="Longest wait allowed."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="7200" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="int"
                                         Value="_touchFrequencyWindowMinutes"
                                         ValueChanged="@((int value) => SetDirty(value, v => _touchFrequencyWindowMinutes = v))"
                                         Label="Touch window minutes"
                                         HelperText="How long touches count."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="1440" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />
                <MudSwitch T="bool"
                           Value="_coolModeRestoreDelayEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _coolModeRestoreDelayEnabled = v))"
                           Label="Delay cool restore"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">Waits a little before switching mode back to cool.</MudText>

                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="int"
                                         Value="_coolModeRestoreMinimumDelaySeconds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _coolModeRestoreMinimumDelaySeconds = value))"
                                         Label="Min mode wait seconds"
                                         HelperText="Shortest wait before cool returns."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="3600" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="int"
                                         Value="_coolModeRestoreMaximumDelaySeconds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _coolModeRestoreMaximumDelaySeconds = value))"
                                         Label="Max mode wait seconds"
                                         HelperText="Longest wait before cool returns."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="7200" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="double"
                                         Value="_coolModeRestoreComfortBandCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _coolModeRestoreComfortBandCelsius = value))"
                                         Label="Mode safe band C"
                                         HelperText="Skip wait if room gets this warm."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />
                <MudSwitch T="bool"
                           Value="_conflictQuietModeEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _conflictQuietModeEnabled = v))"
                           Label="Conflict quiet mode"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">Stands down when wall touches keep happening.</MudText>

                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="int"
                                         Value="_conflictQuietTouchThreshold"
                                         ValueChanged="@((int value) => SetDirty(value, v => _conflictQuietTouchThreshold = value))"
                                         Label="Touches to stand down"
                                         HelperText="How many touches feel like a tug-of-war."
                                         Variant="Variant.Outlined"
                                         Min="2"
                                         Max="20" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="int"
                                         Value="_conflictQuietMinutes"
                                         ValueChanged="@((int value) => SetDirty(value, v => _conflictQuietMinutes = value))"
                                         Label="Stand-down minutes"
                                         HelperText="How long to stop fighting back."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="240" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="double"
                                         Value="_conflictQuietComfortBandCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _conflictQuietComfortBandCelsius = value))"
                                         Label="Safe room band C"
                                         HelperText="Extra warmth allowed while waiting."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="panel-card">
                <MudText Typo="Typo.overline">Comfort Sync</MudText>
                <MudText Typo="Typo.body2" Class="helper-text">Makes fixes look like calm little adjustments.</MudText>

                <MudSwitch T="bool"
                           Value="_naturalRecoveryEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _naturalRecoveryEnabled = v))"
                           Label="Use quiet recovery"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">On means the helper waits and nudges instead of jumping fast.</MudText>

                <MudSwitch T="bool"
                           Value="_adaptiveQuietnessEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _adaptiveQuietnessEnabled = v))"
                           Label="Auto quiet level"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">Lets repeated wall touches make the helper slower and softer by itself.</MudText>

                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_adaptiveQuietTouchThreshold"
                                         ValueChanged="@((int value) => SetDirty(value, v => _adaptiveQuietTouchThreshold = value))"
                                         Label="Touches to quiet"
                                         HelperText="How many wall changes start auto quiet."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="20" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_maximumAdaptiveDelaySeconds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _maximumAdaptiveDelaySeconds = value))"
                                         Label="Max auto wait"
                                         HelperText="Longest wait during repeated touches."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="7200" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_minimumAdaptiveStepCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _minimumAdaptiveStepCelsius = value))"
                                         Label="Smallest auto nudge C"
                                         HelperText="Softest move when touches keep happening."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_maximumAdaptiveHoldChancePercent"
                                         ValueChanged="@((int value) => SetDirty(value, v => _maximumAdaptiveHoldChancePercent = value))"
                                         Label="Max auto hold %"
                                         HelperText="Highest chance to wait again."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="100" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_maximumAdaptiveCommandGapSeconds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _maximumAdaptiveCommandGapSeconds = value))"
                                         Label="Max auto gap"
                                         HelperText="Longest space between nudges."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="7200" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_minimumNaturalDelaySeconds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _minimumNaturalDelaySeconds = value))"
                                         Label="Min quiet wait"
                                         HelperText="Smallest wait after a wall change."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="3600" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_maximumNaturalDelaySeconds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _maximumNaturalDelaySeconds = value))"
                                         Label="Max quiet wait"
                                         HelperText="Biggest random wait."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="7200" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_naturalStepCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _naturalStepCelsius = value))"
                                         Label="Nudge size C"
                                         HelperText="Warm room starts 1 C below room temp; this caps other moves."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_naturalHoldChancePercent"
                                         ValueChanged="@((int value) => SetDirty(value, v => _naturalHoldChancePercent = value))"
                                         Label="Hold chance %"
                                         HelperText="Chance to wait one more beat."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="100" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_maxNaturalHolds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _maxNaturalHolds = value))"
                                         Label="Max holds"
                                         HelperText="How many extra waits are allowed."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="10" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_minimumCommandGapSeconds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _minimumCommandGapSeconds = value))"
                                         Label="Command gap seconds"
                                         HelperText="Space between thermostat nudges."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="3600" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_naturalSafetyOverrideCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _naturalSafetyOverrideCelsius = value))"
                                         Label="Too-hot override C"
                                         HelperText="Skip quiet waits if room is this high."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="10"
                                         Step="0.1" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />
                <MudSwitch T="bool"
                           Value="_naturalWalkbackEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _naturalWalkbackEnabled = v))"
                           Label="Natural walkback"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">Moves safe corrections back in small steps when wall touches keep happening.</MudText>

                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_naturalWalkbackTriggerTouches"
                                         ValueChanged="@((int value) => SetDirty(value, v => _naturalWalkbackTriggerTouches = value))"
                                         Label="Walkback touches"
                                         HelperText="How many touches make nudges extra subtle."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="20" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_naturalWalkbackStepCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _naturalWalkbackStepCelsius = value))"
                                         Label="Walkback step C"
                                         HelperText="Small safe-band nudge size."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_naturalWalkbackJitterCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _naturalWalkbackJitterCelsius = value))"
                                         Label="Tiny variation C"
                                         HelperText="Small random change so nudges do not all match."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="0.5"
                                         Step="0.1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_naturalWalkbackSafetyBandCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _naturalWalkbackSafetyBandCelsius = value))"
                                         Label="Walkback safe band C"
                                         HelperText="Stop subtle nudges if room gets this warm."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />
                <MudSwitch T="bool"
                           Value="_touchSignatureEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _touchSignatureEnabled = v))"
                           Label="Touch signature"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">Learns wall-step size and shapes safe nudges to match.</MudText>

                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_touchSignatureTriggerTouches"
                                         ValueChanged="@((int value) => SetDirty(value, v => _touchSignatureTriggerTouches = value))"
                                         Label="Signature touches"
                                         HelperText="How many wall steps it needs to learn."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="20" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_touchSignatureRetentionMinutes"
                                         ValueChanged="@((int value) => SetDirty(value, v => _touchSignatureRetentionMinutes = value))"
                                         Label="Signature memory minutes"
                                         HelperText="How long wall steps stay useful."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="1440" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_touchSignatureMinimumStepCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _touchSignatureMinimumStepCelsius = value))"
                                         Label="Small signature step C"
                                         HelperText="Smallest learned nudge size."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_touchSignatureMaximumStepCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _touchSignatureMaximumStepCelsius = value))"
                                         Label="Large signature step C"
                                         HelperText="Biggest learned nudge size."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_touchSignatureSafetyBandCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _touchSignatureSafetyBandCelsius = value))"
                                         Label="Signature safe band C"
                                         HelperText="Skip the signature if room gets this warm."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />
                <MudSwitch T="bool"
                           Value="_visibilityGuardEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _visibilityGuardEnabled = v))"
                           Label="Visibility guard"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">Slows only safe corrections when a wall touch happens right after a helper command.</MudText>

                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_visibilityGuardTriggerNotices"
                                         ValueChanged="@((int value) => SetDirty(value, v => _visibilityGuardTriggerNotices = value))"
                                         Label="Notice trigger"
                                         HelperText="How many noticed touches start the hold."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="20" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_visibilityGuardNoticeWindowMinutes"
                                         ValueChanged="@((int value) => SetDirty(value, v => _visibilityGuardNoticeWindowMinutes = value))"
                                         Label="Notice window minutes"
                                         HelperText="How long noticed touches count."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="1440" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_visibilityGuardAfterCommandSeconds"
                                         ValueChanged="@((int value) => SetDirty(value, v => _visibilityGuardAfterCommandSeconds = value))"
                                         Label="After-command seconds"
                                         HelperText="How soon after a helper command a wall touch counts."
                                         Variant="Variant.Outlined"
                                         Min="15"
                                         Max="3600" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_visibilityGuardMinimumHoldMinutes"
                                         ValueChanged="@((int value) => SetDirty(value, v => _visibilityGuardMinimumHoldMinutes = value))"
                                         Label="Min visibility hold"
                                         HelperText="Shortest quiet hold after noticed activity."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="240" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_visibilityGuardMaximumHoldMinutes"
                                         ValueChanged="@((int value) => SetDirty(value, v => _visibilityGuardMaximumHoldMinutes = value))"
                                         Label="Max visibility hold"
                                         HelperText="Longest quiet hold after noticed activity."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="480" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_visibilityGuardSafetyBandCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _visibilityGuardSafetyBandCelsius = value))"
                                         Label="Visibility safe band C"
                                         HelperText="Skip visibility holds if room gets this warm."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />
                <MudSwitch T="bool"
                           Value="_routineTimingEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _routineTimingEnabled = v))"
                           Label="Routine timing"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">Waits for a normal comfort-check rhythm after repeated wall changes.</MudText>

                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_routineTimingTriggerTouches"
                                         ValueChanged="@((int value) => SetDirty(value, v => _routineTimingTriggerTouches = value))"
                                         Label="Routine touches"
                                         HelperText="How many wall changes start routine timing."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="20" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_routineTimingIntervalMinutes"
                                         ValueChanged="@((int value) => SetDirty(value, v => _routineTimingIntervalMinutes = value))"
                                         Label="Routine minutes"
                                         HelperText="Normal minute rhythm for safe corrections."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="60" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_routineTimingJitterMinutes"
                                         ValueChanged="@((int value) => SetDirty(value, v => _routineTimingJitterMinutes = value))"
                                         Label="Routine wiggle minutes"
                                         HelperText="Small extra time so it does not hit exactly."
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="30" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_routineTimingMaxDelayMinutes"
                                         ValueChanged="@((int value) => SetDirty(value, v => _routineTimingMaxDelayMinutes = value))"
                                         Label="Max routine wait"
                                         HelperText="Longest safe routine timing hold."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="180" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_routineTimingSafetyBandCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _routineTimingSafetyBandCelsius = value))"
                                         Label="Routine safe band C"
                                         HelperText="Skip routine timing if room gets this warm."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />
                <MudSwitch T="bool"
                           Value="_comfortBudgetEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _comfortBudgetEnabled = v))"
                           Label="Comfort budget"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">Limits repeated safe adjustments so the room can settle.</MudText>

                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_comfortBudgetWindowMinutes"
                                         ValueChanged="@((int value) => SetDirty(value, v => _comfortBudgetWindowMinutes = value))"
                                         Label="Budget window minutes"
                                         HelperText="How long recent safe adjustments count."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="240" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_comfortBudgetMaxCommands"
                                         ValueChanged="@((int value) => SetDirty(value, v => _comfortBudgetMaxCommands = value))"
                                         Label="Budget adjustments"
                                         HelperText="Safe adjustments allowed in the window."
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="30" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double"
                                         Value="_comfortBudgetSafetyBandCelsius"
                                         ValueChanged="@((double value) => SetDirty(value, v => _comfortBudgetSafetyBandCelsius = value))"
                                         Label="Budget safe band C"
                                         HelperText="Skip the budget if room gets this warm."
                                         Variant="Variant.Outlined"
                                         Min="0.1"
                                         Max="5"
                                         Step="0.1" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />
                <MudSwitch T="bool"
                           Value="_naturalCadenceEnabled"
                           ValueChanged="@((bool value) => SetDirty(value, v => _naturalCadenceEnabled = v))"
                           Label="Natural cadence"
                           Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="helper-text">Picks a quiet future slot for safe nudges when wall touches keep happening.</MudText>

                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_naturalCadenceTriggerTouches"
                                         ValueChanged="@((int value) => SetDirty(value, v => _naturalCadenceTriggerTouches = value))"
