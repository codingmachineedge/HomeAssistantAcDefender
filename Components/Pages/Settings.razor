    @* ───────────── Schedule editor ───────────── *@
    <SectionCard Title="Custom schedule"
                 Subtitle="Temperature rules"
                 Help="Add target-temperature rules for days and times. Each rule has its own weather gate.">
        <Actions>
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@ScheduleResultText</MudChip>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddSchedule" StartIcon="@Icons.Material.Filled.Add">Add rule</MudButton>
        </Actions>
        <ChildContent>
            <MudTextField @bind-Value="_scheduleSearch" Immediate="true" Clearable="true" Margin="Margin.Dense"
                          Placeholder="Search schedule rules" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Class="mb-2" />

            @if (!FilteredSchedule.Any())
            {
                <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">@(_schedule.Count == 0 ? "No rules yet. Add one to start a custom schedule." : "No rule matches that search.")</MudAlert>
            }

            <MudStack Spacing="2">
                @foreach (var entry in FilteredSchedule)
                {
                    <MudPaper Class="schedule-card" Elevation="0" @key="entry.Id">
                        <MudGrid Spacing="2" Class="align-center">
                            <MudItem xs="12" sm="6">
                                <MudTextField T="string" Value="entry.Name" ValueChanged="@(v => UpdateSchedule(entry, e => e.Name = v))" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudSwitch T="bool" Value="entry.Enabled" ValueChanged="@(v => UpdateSchedule(entry, e => e.Enabled = v))" Color="Color.Success" Label="On" />
                            </MudItem>
                            <MudItem xs="6" sm="3" Class="d-flex justify-end">
                                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => RemoveSchedule(entry))" StartIcon="@Icons.Material.Filled.Delete">Remove</MudButton>
                            </MudItem>

                            <MudItem xs="12">
                                <div class="day-button-row">
                                    @foreach (var day in Days)
                                    {
                                        <MudButton Size="Size.Small" Variant="@DayVariant(entry, day)" Color="@DayColor(entry, day)" OnClick="@(() => ToggleDay(entry, day))">@day</MudButton>
                                    }
                                </div>
                            </MudItem>

                            <MudItem xs="6" sm="3">
                                <MudTextField T="string" Value="entry.StartTime" ValueChanged="@(v => UpdateSchedule(entry, e => e.StartTime = v))" Label="Start" InputType="InputType.Time" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudTextField T="string" Value="entry.EndTime" ValueChanged="@(v => UpdateSchedule(entry, e => e.EndTime = v))" Label="End" InputType="InputType.Time" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="double" Value="entry.TargetTemperatureCelsius" ValueChanged="@(v => UpdateSchedule(entry, e => e.TargetTemperatureCelsius = v))" Label="Target" Variant="Variant.Outlined" Margin="Margin.Dense" Min="10" Max="35" Step="0.1" Adornment="Adornment.End" AdornmentText="C" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudSelect T="string" Value="entry.WeatherActivationMode" ValueChanged="@(v => UpdateSchedule(entry, e => e.WeatherActivationMode = v))" Label="Weather rule" Variant="Variant.Outlined" Margin="Margin.Dense">
                                    @foreach (var option in ScheduleWeatherOptions)
                                    {
                                        <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">@Summary(entry)</MudAlert>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                }
            </MudStack>
        </ChildContent>
    </SectionCard>

    <div class="save-bar">
        <MudText Typo="Typo.caption" Class="helper-text">@StatusText</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings" StartIcon="@Icons.Material.Filled.Save">Save settings</MudButton>
    </div>
</MudStack>

