    private void SetDirty<T>(T value, Action<T> assign)
    {
        assign(value);
        _dirty = true;
    }

    private void UpdateSchedule(ScheduleEntry entry, Action<ScheduleEntry> update)
    {
        update(entry);
        _dirty = true;
    }

    private void AddSchedule()
    {
        _schedule.Add(new ScheduleEntry
        {
            Name = "Comfort",
            Days = string.Join(",", Days),
            StartTime = "18:00",
            EndTime = "23:00",
            TargetTemperatureCelsius = 22,
            WeatherActivationMode = "always",
            Enabled = true
        });
        _dirty = true;
    }

    private void RemoveSchedule(ScheduleEntry entry)
    {
        _schedule.Remove(entry);
        _dirty = true;
    }

    private void ToggleDay(ScheduleEntry entry, string day)
    {
        var days = DaySet(entry);
        if (!days.Add(day))
        {
            days.Remove(day);
        }

        entry.Days = string.Join(",", Days.Where(days.Contains));
        _dirty = true;
    }

    private Variant DayVariant(ScheduleEntry entry, string day)
    {
        return DaySet(entry).Contains(day) ? Variant.Filled : Variant.Outlined;
    }

    private Color DayColor(ScheduleEntry entry, string day)
    {
        return DaySet(entry).Contains(day) ? Color.Primary : Color.Default;
    }

    private void SaveSettings()
    {
        var gate = StateStore.TryBeginWebsiteCommand("save settings", bypassDebounce: true);
        if (!gate.Accepted)
        {
            _settingsStatus = $"Wait {gate.Snapshot.WebsiteCommandDebounce.SecondsRemaining}s";
            Snackbar.Add(gate.Message, Severity.Warning);
            return;
        }

        var request = new SettingsRequest(
            _scheduleEnabled,
            _weatherActivationMode,
            _baseCooldownSeconds,
            _maxCooldownSeconds,
            _touchFrequencyWindowMinutes,
            _coolModeRestoreDelayEnabled,
            _coolModeRestoreMinimumDelaySeconds,
            _coolModeRestoreMaximumDelaySeconds,
            _coolModeRestoreComfortBandCelsius,
            _conflictQuietModeEnabled,
            _conflictQuietTouchThreshold,
            _conflictQuietMinutes,
            _conflictQuietComfortBandCelsius,
            _tugOfWarTruceEnabled,
            _tugOfWarTruceMinimumFlips,
            _tugOfWarTruceWindowMinutes,
            _tugOfWarTruceHoldMinutes,
            _tugOfWarTruceSafetyBandCelsius,
            _wallSettlingGuardEnabled,
            _wallSettlingMinimumTouches,
            _wallSettlingWindowMinutes,
            _wallSettlingBaseSeconds,
            _wallSettlingPressureExtraSeconds,
            _wallSettlingSafetyBandCelsius,
            _naturalRecoveryEnabled,
            _adaptiveQuietnessEnabled,
            _adaptiveQuietTouchThreshold,
            _maximumAdaptiveDelaySeconds,
            _minimumAdaptiveStepCelsius,
            _maximumAdaptiveHoldChancePercent,
            _maximumAdaptiveCommandGapSeconds,
            _minimumNaturalDelaySeconds,
            _maximumNaturalDelaySeconds,
            _naturalStepCelsius,
            _naturalHoldChancePercent,
            _maxNaturalHolds,
            _minimumCommandGapSeconds,
            _naturalSafetyOverrideCelsius,
            _naturalWalkbackEnabled,
            _naturalWalkbackTriggerTouches,
            _naturalWalkbackStepCelsius,
