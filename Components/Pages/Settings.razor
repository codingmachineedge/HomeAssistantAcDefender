@page "/settings"
@inject DefenderStateStore StateStore
@inject ISnackbar Snackbar
@inject TwoFactorAuth TwoFactorAuth

<PageTitle>Settings - AC Defender</PageTitle>

<MudStack Spacing="3" Class="settings-shell">
    <SectionCard Title="Settings"
                 Subtitle="Tune the defender"
                 Help="Adjust timing, comfort, and safety. Type to filter controls. Changes apply when you save.">
        <Actions>
            <MudChip T="string" Size="Size.Small" Color="@(_dirty ? Color.Warning : Color.Default)" Variant="Variant.Outlined">@StatusText</MudChip>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings" StartIcon="@Icons.Material.Filled.Save">Save</MudButton>
        </Actions>
        <ChildContent>
            <MudTextField @bind-Value="_settingsSearch" Immediate="true" Clearable="true" Margin="Margin.Dense"
                          Placeholder="Search settings (cooldown, walkback, upstairs, weather…)"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Class="mt-1" />
        </ChildContent>
    </SectionCard>

    @* ───────────── Accounts ───────────── *@
    <SectionCard Title="Accounts" Help="Login is account-based: the first sign-up becomes the owner, and everyone else needs the registration code you set here.">
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    @TwoFactorAuth.AccountCount account(s)@(TwoFactorAuth.AccountCount > 0 ? $": {string.Join(", ", TwoFactorAuth.AccountUsernames)}" : "")
                </MudAlert>
            </MudItem>
            <MudItem xs="12">
                <MudAlert Severity="@(TwoFactorAuth.HasRegistrationCode ? Severity.Success : Severity.Warning)" Variant="Variant.Outlined" Dense="true">
                    @(TwoFactorAuth.HasRegistrationCode
                        ? "A registration code is set — share it with people you want to let sign up."
                        : "No registration code set, so additional sign-ups are closed. Set one below to let others register.")
                </MudAlert>
            </MudItem>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_registrationCode" Label="Registration code" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Immediate="true" Placeholder="A code you give to people you want to allow" />
            </MudItem>
            <MudItem xs="12" Class="d-flex flex-wrap gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveRegistrationCode" StartIcon="@Icons.Material.Filled.Key">Save registration code</MudButton>
                @if (TwoFactorAuth.HasRegistrationCode)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CloseSignups" StartIcon="@Icons.Material.Filled.Block">Close sign-ups</MudButton>
                }
            </MudItem>
        </MudGrid>
    </SectionCard>

    @* ───────────── Automation ───────────── *@
    <SectionCard Title="Automation" Help="Schedule, weather activation, cooldown, cool restore, conflict quiet, and weather drift.">
        <MudExpansionPanels MultiExpansion="true" Class="setting-panels">
            @if (Show("peace offering app phone concede up gift madness")) {
                <MudExpansionPanel Text="Peace offering" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Concede when the app raises the temp" Value="_peaceOfferingEnabled" ValueChanged="@(v => SetDirty(v, x => _peaceOfferingEnabled = x))" Help="When someone raises the setpoint from the phone/Home Assistant app, immediately go a little HIGHER than they asked and stand down for the hold window — they see the system agreeing, not fighting. A genuinely hot room cancels the hold." />
                        <SettingDouble Label="Extra step up (C)" Value="_peaceOfferingStepCelsius" ValueChanged="@(v => SetDirty(v, x => _peaceOfferingStepCelsius = x))" Min="0.1" Max="2" Step="0.1" Help="How much above their number the gift goes." />
                        <SettingInt Label="Stand-down after the gift (minutes)" Value="_peaceOfferingHoldMinutes" ValueChanged="@(v => SetDirty(v, x => _peaceOfferingHoldMinutes = x))" Min="1" Max="240" Help="How long the defender leaves their choice alone." />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("gentle stepping pace walk step gap fight slow")) {
                <MudExpansionPanel Text="Gentle stepping" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingInt Label="Anti-flap: minimum seconds between steps" Value="_coolingStepMinimumGapSeconds" ValueChanged="@(v => SetDirty(v, x => _coolingStepMinimumGapSeconds = x))" Min="0" Max="3600" Help="Steps are driven by the room temperature actually dropping, never by a schedule. This spacing only prevents command bursts and compressor short-cycling." />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("night shutdown off overnight sleep window outdoor cheap power")) {
                <MudExpansionPanel Text="Night shutdown" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Turn the AC off overnight" Value="_nightShutdownEnabled" ValueChanged="@(v => SetDirty(v, x => _nightShutdownEnabled = x))" Help="During the window below, if it is cool outside, the defender turns the AC off once and stands down completely. Turning it back on manually is respected." />
                        <MudItem xs="6" sm="3">
                            <MudTextField T="string" Value="_nightShutdownStartTime" ValueChanged="@(v => SetDirty(v, x => _nightShutdownStartTime = x))" Label="From (HH:mm)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudTextField T="string" Value="_nightShutdownEndTime" ValueChanged="@(v => SetDirty(v, x => _nightShutdownEndTime = x))" Label="Until (HH:mm)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <SettingDouble Label="Only when outdoor below (C)" Value="_nightShutdownOutdoorBelowCelsius" ValueChanged="@(v => SetDirty(v, x => _nightShutdownOutdoorBelowCelsius = x))" Min="0" Max="40" Step="0.5" Help="Safety valve: on a hot night the AC keeps running. Unknown outdoor also keeps it running." />
                        <SettingDouble Label="Night minimum setpoint (C)" Value="_nightMinimumSetPointCelsius" ValueChanged="@(v => SetDirty(v, x => _nightMinimumSetPointCelsius = x))" Min="0" Max="30" Step="0.5" Help="During the night window the defender never commands below this — even if the daytime target is lower. Set 0 to disable." />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("website debounce buttons rest command spam")) {
                <MudExpansionPanel Text="Website debounce" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Website command debounce" Value="_websiteCommandDebounceEnabled" ValueChanged="@(v => SetDirty(v, x => _websiteCommandDebounceEnabled = x))" Help="Off by default. When on, website thermostat buttons rest 120 seconds after each command. Adjusting targets and saving settings is never debounced." />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("schedule weather activation always automation")) {
                <MudExpansionPanel Text="Schedule & weather" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Use custom schedule" Value="_scheduleEnabled" ValueChanged="@(v => SetDirty(v, x => _scheduleEnabled = x))" Help="Turn on the time-of-day target rules edited at the bottom of this page." />
                        <MudItem xs="12" sm="8">
                            <MudSelect T="string" Value="_weatherActivationMode" ValueChanged="@(v => SetDirty(v, x => _weatherActivationMode = x))" Label="Weather activation" Variant="Variant.Outlined" Margin="Margin.Dense">
                                @foreach (var option in WeatherOptions)
                                {
                                    <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("base cooldown max touch frequency window")) {
                <MudExpansionPanel Text="Cooldown" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingInt Label="Base cooldown" Unit="s" Value="_baseCooldownSeconds" ValueChanged="@(v => SetDirty(v, x => _baseCooldownSeconds = x))" Min="0" Max="3600" Help="Quiet period after a manual change." />
                        <SettingInt Label="Max cooldown" Unit="s" Value="_maxCooldownSeconds" ValueChanged="@(v => SetDirty(v, x => _maxCooldownSeconds = x))" Min="0" Max="7200" Help="Longest cooldown after many touches." />
                        <SettingInt Label="Touch window" Unit="min" Value="_touchFrequencyWindowMinutes" ValueChanged="@(v => SetDirty(v, x => _touchFrequencyWindowMinutes = x))" Min="1" Max="1440" Help="How far back touches are counted." />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("cool mode restore delay band")) {
                <MudExpansionPanel Text="Cool mode restore" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Delay cool restore" Value="_coolModeRestoreDelayEnabled" ValueChanged="@(v => SetDirty(v, x => _coolModeRestoreDelayEnabled = x))" Help="Wait briefly before forcing cool mode back." />
                        <SettingInt Label="Min wait" Unit="s" Value="_coolModeRestoreMinimumDelaySeconds" ValueChanged="@(v => SetDirty(v, x => _coolModeRestoreMinimumDelaySeconds = x))" Min="0" Max="3600" />
                        <SettingInt Label="Max wait" Unit="s" Value="_coolModeRestoreMaximumDelaySeconds" ValueChanged="@(v => SetDirty(v, x => _coolModeRestoreMaximumDelaySeconds = x))" Min="0" Max="7200" />
                        <SettingDouble Label="Safe band" Value="_coolModeRestoreComfortBandCelsius" ValueChanged="@(v => SetDirty(v, x => _coolModeRestoreComfortBandCelsius = x))" Min="0.1" Max="5" Help="Warmth allowed before restoring now." />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("conflict quiet tug of war stand down")) {
                <MudExpansionPanel Text="Conflict quiet" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Conflict quiet mode" Value="_conflictQuietModeEnabled" ValueChanged="@(v => SetDirty(v, x => _conflictQuietModeEnabled = x))" Help="Stand down during an obvious thermostat fight." />
                        <SettingInt Label="Touches to stand down" Value="_conflictQuietTouchThreshold" ValueChanged="@(v => SetDirty(v, x => _conflictQuietTouchThreshold = x))" Min="2" Max="20" />
                        <SettingInt Label="Stand-down" Unit="min" Value="_conflictQuietMinutes" ValueChanged="@(v => SetDirty(v, x => _conflictQuietMinutes = x))" Min="1" Max="240" />
                        <SettingDouble Label="Safe band" Value="_conflictQuietComfortBandCelsius" ValueChanged="@(v => SetDirty(v, x => _conflictQuietComfortBandCelsius = x))" Min="0.1" Max="5" />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("weather drift outdoor timing")) {
                <MudExpansionPanel Text="Weather drift timing" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Weather drift timing" Value="_weatherDriftGuardEnabled" ValueChanged="@(v => SetDirty(v, x => _weatherDriftGuardEnabled = x))" Help="Time safe corrections to real outdoor movement." />
                        <SettingInt Label="Window" Unit="min" Value="_weatherDriftWindowMinutes" ValueChanged="@(v => SetDirty(v, x => _weatherDriftWindowMinutes = x))" Min="5" Max="1440" />
                        <SettingDouble Label="Min change" Value="_weatherDriftMinimumChangeCelsius" ValueChanged="@(v => SetDirty(v, x => _weatherDriftMinimumChangeCelsius = x))" Min="0.1" Max="5" />
                        <SettingInt Label="Hold" Unit="min" Value="_weatherDriftHoldMinutes" ValueChanged="@(v => SetDirty(v, x => _weatherDriftHoldMinutes = x))" Min="1" Max="120" />
                        <SettingDouble Label="Safe band" Value="_weatherDriftSafetyBandCelsius" ValueChanged="@(v => SetDirty(v, x => _weatherDriftSafetyBandCelsius = x))" Min="0.1" Max="5" />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("super defender phone home assistant remote wifi lockdown strict")) {
                <MudExpansionPanel Text="Super Defender" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Super Defender" Value="_superDefenderModeEnabled" ValueChanged="@(v => SetDirty(v, x => _superDefenderModeEnabled = x))" Help="Watch repeated phone or Home Assistant changes and tighten response." />
                        <SettingSwitch Label="Bypass quiet waits" Value="_superDefenderBypassQuietTiming" ValueChanged="@(v => SetDirty(v, x => _superDefenderBypassQuietTiming = x))" Help="Skip subtle timing holds while Super Defender is active and cooling is needed." />
                        <SettingInt Label="Remote changes" Value="_superDefenderRemoteChangeThreshold" ValueChanged="@(v => SetDirty(v, x => _superDefenderRemoteChangeThreshold = x))" Min="1" Max="20" Help="How many phone/Home Assistant-style changes arm it." />
                        <SettingInt Label="Remote window" Unit="min" Value="_superDefenderWindowMinutes" ValueChanged="@(v => SetDirty(v, x => _superDefenderWindowMinutes = x))" Min="1" Max="1440" />
                        <SettingInt Label="Strict hold" Unit="min" Value="_superDefenderHoldMinutes" ValueChanged="@(v => SetDirty(v, x => _superDefenderHoldMinutes = x))" Min="0" Max="240" />
                        <SettingDouble Label="Strict safe band" Value="_superDefenderSafetyBandCelsius" ValueChanged="@(v => SetDirty(v, x => _superDefenderSafetyBandCelsius = x))" Min="0.1" Max="10" />
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">Wi-Fi blocking is not automated here. Use router/MAC controls manually only if you accept the risk of losing thermostat monitoring and recovery.</MudAlert>
                        </MudItem>
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("remote settling home assistant phone automation quiet source")) {
                <MudExpansionPanel Text="Remote settling" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Remote settling" Value="_remoteSettlingGuardEnabled" ValueChanged="@(v => SetDirty(v, x => _remoteSettlingGuardEnabled = x))" Help="Wait quietly after repeated Home Assistant phone or automation changes." />
                        <SettingInt Label="Remote trigger" Value="_remoteSettlingTriggerChanges" ValueChanged="@(v => SetDirty(v, x => _remoteSettlingTriggerChanges = x))" Min="1" Max="20" Help="Home Assistant-side changes needed before the quiet hold starts." />
                        <SettingInt Label="Remote window" Unit="min" Value="_remoteSettlingWindowMinutes" ValueChanged="@(v => SetDirty(v, x => _remoteSettlingWindowMinutes = x))" Min="1" Max="1440" Help="How long phone/automation changes remain part of the pattern." />
                        <SettingInt Label="Quiet hold" Unit="min" Value="_remoteSettlingHoldMinutes" ValueChanged="@(v => SetDirty(v, x => _remoteSettlingHoldMinutes = x))" Min="0" Max="240" Help="How long safe corrections wait after the remote pattern." />
                        <SettingDouble Label="Safe band" Value="_remoteSettlingSafetyBandCelsius" ValueChanged="@(v => SetDirty(v, x => _remoteSettlingSafetyBandCelsius = x))" Min="0.1" Max="10" Help="Warmth allowed before remote settling stops waiting." />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("desired state enforcer owner exact target win automatically off setpoint escalate override interference notify schedule presence stealth")) {
                <MudExpansionPanel Text="Desired-State Enforcer" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">Makes your chosen AC state win automatically. If someone else turns it off or raises the setpoint, it restores your state. Owner changes (by Home Assistant user_id) are respected. Off by default.</MudAlert>
                        </MudItem>
                        <SettingSwitch Label="Enforcer mode" Value="_enforcerModeEnabled" ValueChanged="@(v => SetDirty(v, x => _enforcerModeEnabled = x))" Help="Master switch. When off, the existing stealth pipeline runs unchanged." />
                        <SettingDouble Label="Exact target" Unit="C" Value="_enforcerTargetTemperatureCelsius" ValueChanged="@(v => SetDirty(v, x => _enforcerTargetTemperatureCelsius = x))" Min="0" Max="35" Help="The exact temperature to hold. 0 = follow the website target." />
                        <SettingSwitch Label="Restore mode (turn back on)" Value="_enforcerEnforceMode" ValueChanged="@(v => SetDirty(v, x => _enforcerEnforceMode = x))" Help="Bring the unit back to cool if someone switches it off/heat/auto." />
                        <SettingSwitch Label="Restore setpoint" Value="_enforcerEnforceSetpoint" ValueChanged="@(v => SetDirty(v, x => _enforcerEnforceSetpoint = x))" Help="Restore the target when the setpoint is moved away." />
                        <SettingSwitch Label="Smart-stealth shaping" Value="_enforcerStealthShaping" ValueChanged="@(v => SetDirty(v, x => _enforcerStealthShaping = x))" Help="Ease the setpoint back through the human-like pipeline so it is less noticeable. Off = snap to the exact target." />
                        <SettingSwitch Label="Respect owner changes" Value="_enforcerRespectOwner" ValueChanged="@(v => SetDirty(v, x => _enforcerRespectOwner = x))" Help="Do not fight changes made by the owner user ids below." />
                        <MudItem xs="12">
                            <MudTextField T="string" Value="_enforcerOwnerUserIds" ValueChanged="@(v => SetDirty(v, x => _enforcerOwnerUserIds = x))" Label="Owner Home Assistant user ids" Placeholder="abc123def456, ..." HelperText="Your own Home Assistant user_id(s), comma-separated. Changes from these are respected; everyone else is counteracted." Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <SettingInt Label="Debounce" Unit="s" Value="_enforcerDebounceSeconds" ValueChanged="@(v => SetDirty(v, x => _enforcerDebounceSeconds = x))" Min="2" Max="120" Help="A deviation must persist this long before enforcing." />
                        <SettingInt Label="Cooldown" Unit="s" Value="_enforcerCooldownSeconds" ValueChanged="@(v => SetDirty(v, x => _enforcerCooldownSeconds = x))" Min="10" Max="600" Help="Minimum gap between re-asserts (also waits out the Home Assistant echo)." />
                        <SettingInt Label="Rate window" Unit="min" Value="_enforcerRateWindowMinutes" ValueChanged="@(v => SetDirty(v, x => _enforcerRateWindowMinutes = x))" Min="1" Max="240" Help="Window for the rate limit and override counting." />
                        <SettingInt Label="Max asserts / window" Value="_enforcerMaxAssertsPerWindow" ValueChanged="@(v => SetDirty(v, x => _enforcerMaxAssertsPerWindow = x))" Min="1" Max="60" Help="Hold and escalate instead of thrashing past this many asserts." />
                        <SettingInt Label="Escalate after overrides" Value="_enforcerEscalateAfterOverrides" ValueChanged="@(v => SetDirty(v, x => _enforcerEscalateAfterOverrides = x))" Min="1" Max="20" Help="Switch to firm mode after this many unwanted overrides in the window." />
                        <SettingInt Label="Backoff base" Unit="s" Value="_enforcerBackoffBaseSeconds" ValueChanged="@(v => SetDirty(v, x => _enforcerBackoffBaseSeconds = x))" Min="5" Max="300" Help="Exponential backoff base when the device does not confirm commands." />
                        <SettingInt Label="Backoff max" Unit="s" Value="_enforcerBackoffMaxSeconds" ValueChanged="@(v => SetDirty(v, x => _enforcerBackoffMaxSeconds = x))" Min="30" Max="3600" Help="Cap for the backoff wait." />
                        <SettingSwitch Label="Schedule window" Value="_enforcerScheduleEnabled" ValueChanged="@(v => SetDirty(v, x => _enforcerScheduleEnabled = x))" Help="Only enforce inside the time window below." />
                        <MudItem xs="6">
                            <MudTextField T="string" Value="_enforcerStartTime" ValueChanged="@(v => SetDirty(v, x => _enforcerStartTime = x))" Label="Start (HH:mm)" Placeholder="00:00" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField T="string" Value="_enforcerEndTime" ValueChanged="@(v => SetDirty(v, x => _enforcerEndTime = x))" Label="End (HH:mm)" Placeholder="23:59" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <SettingSwitch Label="Only when home" Value="_enforcerRequirePresence" ValueChanged="@(v => SetDirty(v, x => _enforcerRequirePresence = x))" Help="Only enforce while presence shows someone home." />
                        <SettingSwitch Label="Notify on defend/interference" Value="_enforcerNotifyEnabled" ValueChanged="@(v => SetDirty(v, x => _enforcerNotifyEnabled = x))" Help="Send a Home Assistant notification (needs HomeAssistant:NotifyService configured)." />
                        <SettingSwitch Label="Use trained models" Value="_enforcerUseLearning" ValueChanged="@(v => SetDirty(v, x => _enforcerUseLearning = x))" Help="Pace enforcement with the learned interference/cadence models once trained." />
                    </MudGrid>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    </SectionCard>

    @* ───────────── Recovery ───────────── *@
    <SectionCard Title="Recovery" Help="Comfort Sync quiet recovery and natural walkback.">
        <MudExpansionPanels MultiExpansion="true" Class="setting-panels">
            @if (Show("comfort sync quiet recovery adaptive nudge hold command gap")) {
                <MudExpansionPanel Text="Comfort Sync (quiet recovery)" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Use quiet recovery" Value="_naturalRecoveryEnabled" ValueChanged="@(v => SetDirty(v, x => _naturalRecoveryEnabled = x))" Help="Space out and soften corrections." />
                        <SettingSwitch Label="Auto quiet level" Value="_adaptiveQuietnessEnabled" ValueChanged="@(v => SetDirty(v, x => _adaptiveQuietnessEnabled = x))" Help="Let repeated touches raise the quiet level." />
                        <SettingInt Label="Touches to quiet" Value="_adaptiveQuietTouchThreshold" ValueChanged="@(v => SetDirty(v, x => _adaptiveQuietTouchThreshold = x))" Min="1" Max="20" />
                        <SettingInt Label="Max auto wait" Unit="s" Value="_maximumAdaptiveDelaySeconds" ValueChanged="@(v => SetDirty(v, x => _maximumAdaptiveDelaySeconds = x))" Min="0" Max="7200" />
                        <SettingDouble Label="Smallest auto nudge" Value="_minimumAdaptiveStepCelsius" ValueChanged="@(v => SetDirty(v, x => _minimumAdaptiveStepCelsius = x))" Min="0.1" Max="5" />
                        <SettingInt Label="Max auto hold" Unit="%" Value="_maximumAdaptiveHoldChancePercent" ValueChanged="@(v => SetDirty(v, x => _maximumAdaptiveHoldChancePercent = x))" Min="0" Max="100" />
                        <SettingInt Label="Max auto gap" Unit="s" Value="_maximumAdaptiveCommandGapSeconds" ValueChanged="@(v => SetDirty(v, x => _maximumAdaptiveCommandGapSeconds = x))" Min="0" Max="7200" />
                        <SettingInt Label="Min quiet wait" Unit="s" Value="_minimumNaturalDelaySeconds" ValueChanged="@(v => SetDirty(v, x => _minimumNaturalDelaySeconds = x))" Min="0" Max="3600" />
                        <SettingInt Label="Max quiet wait" Unit="s" Value="_maximumNaturalDelaySeconds" ValueChanged="@(v => SetDirty(v, x => _maximumNaturalDelaySeconds = x))" Min="0" Max="7200" />
                        <SettingDouble Label="Nudge size" Value="_naturalStepCelsius" ValueChanged="@(v => SetDirty(v, x => _naturalStepCelsius = x))" Min="0.1" Max="5" />
                        <SettingInt Label="Hold chance" Unit="%" Value="_naturalHoldChancePercent" ValueChanged="@(v => SetDirty(v, x => _naturalHoldChancePercent = x))" Min="0" Max="100" />
                        <SettingInt Label="Max holds" Value="_maxNaturalHolds" ValueChanged="@(v => SetDirty(v, x => _maxNaturalHolds = x))" Min="0" Max="10" />
                        <SettingInt Label="Command gap" Unit="s" Value="_minimumCommandGapSeconds" ValueChanged="@(v => SetDirty(v, x => _minimumCommandGapSeconds = x))" Min="0" Max="3600" />
                        <SettingDouble Label="Too-hot override" Value="_naturalSafetyOverrideCelsius" ValueChanged="@(v => SetDirty(v, x => _naturalSafetyOverrideCelsius = x))" Min="0.1" Max="10" Help="Warmth above target that skips all quiet waits." />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("natural walkback step jitter")) {
                <MudExpansionPanel Text="Natural walkback" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Natural walkback" Value="_naturalWalkbackEnabled" ValueChanged="@(v => SetDirty(v, x => _naturalWalkbackEnabled = x))" Help="Walk corrections back in small, varied steps." />
                        <SettingInt Label="Walkback touches" Value="_naturalWalkbackTriggerTouches" ValueChanged="@(v => SetDirty(v, x => _naturalWalkbackTriggerTouches = x))" Min="1" Max="20" />
                        <SettingDouble Label="Walkback step" Value="_naturalWalkbackStepCelsius" ValueChanged="@(v => SetDirty(v, x => _naturalWalkbackStepCelsius = x))" Min="0.1" Max="5" />
                        <SettingDouble Label="Tiny variation" Value="_naturalWalkbackJitterCelsius" ValueChanged="@(v => SetDirty(v, x => _naturalWalkbackJitterCelsius = x))" Min="0" Max="0.5" />
                        <SettingDouble Label="Safe band" Value="_naturalWalkbackSafetyBandCelsius" ValueChanged="@(v => SetDirty(v, x => _naturalWalkbackSafetyBandCelsius = x))" Min="0.1" Max="5" />
                    </MudGrid>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    </SectionCard>

    @* ───────────── Wall touch ───────────── *@
    <SectionCard Title="Wall touch" Help="How the defender reacts to people changing the wall thermostat.">
        <MudExpansionPanels MultiExpansion="true" Class="setting-panels">
            @if (Show("wall settling tapping")) {
                <MudExpansionPanel Text="Wall settling" Expanded="@IsSettingsSearchActive">
                    <MudGrid Spacing="2">
                        <SettingSwitch Label="Wall settling guard" Value="_wallSettlingGuardEnabled" ValueChanged="@(v => SetDirty(v, x => _wallSettlingGuardEnabled = x))" Help="Wait for tapping to stop before correcting." />
                        <SettingInt Label="Settle touches" Value="_wallSettlingMinimumTouches" ValueChanged="@(v => SetDirty(v, x => _wallSettlingMinimumTouches = x))" Min="1" Max="20" />
                        <SettingInt Label="Window" Unit="min" Value="_wallSettlingWindowMinutes" ValueChanged="@(v => SetDirty(v, x => _wallSettlingWindowMinutes = x))" Min="1" Max="1440" />
                        <SettingInt Label="Base settle" Unit="s" Value="_wallSettlingBaseSeconds" ValueChanged="@(v => SetDirty(v, x => _wallSettlingBaseSeconds = x))" Min="0" Max="1800" />
                        <SettingInt Label="Pressure extra" Unit="s" Value="_wallSettlingPressureExtraSeconds" ValueChanged="@(v => SetDirty(v, x => _wallSettlingPressureExtraSeconds = x))" Min="0" Max="3600" />
                        <SettingDouble Label="Safe band" Value="_wallSettlingSafetyBandCelsius" ValueChanged="@(v => SetDirty(v, x => _wallSettlingSafetyBandCelsius = x))" Min="0.1" Max="5" />
                    </MudGrid>
                </MudExpansionPanel>
            }
            @if (Show("tug war truce alternating thermostat fight flips up down suspicion"))
