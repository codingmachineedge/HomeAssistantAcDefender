    protected override void OnInitialized()
    {
        LoadFromSnapshot(StateStore.GetSnapshot());
    }

    private void SaveRegistrationCode()
    {
        if (string.IsNullOrWhiteSpace(_registrationCode) || _registrationCode.Trim().Length < 4)
        {
            Snackbar.Add("Enter a registration code of at least 4 characters.", Severity.Error);
            return;
        }

        TwoFactorAuth.SetRegistrationCode(_registrationCode.Trim());
        _registrationCode = "";
        Snackbar.Add("Registration code saved. Share it with people you want to let sign up.", Severity.Success);
    }

    private void CloseSignups()
    {
        TwoFactorAuth.SetRegistrationCode(null);
        _registrationCode = "";
        Snackbar.Add("Sign-ups closed. Only existing accounts can sign in.", Severity.Success);
    }

