@page "/logs"
@implements IDisposable
@using System.Text.Json
@inject DefenderStateProvider State
@inject HomeAssistantClient HomeAssistant
@inject WikiContentService WikiContent

<PageTitle>Field Reports — SCP AC Defender</PageTitle>

<div class="ops-dash-stack">

    @if (State.Snapshot?.AdjustmentStatistics is { } stats)
    {
        <div class="ops-panel ops-panel--pad">
            <h2 class="ops-panel__label">ADJUSTMENT STATISTICS — @stats.TotalAdjustments ANALYSED</h2>
            <div class="helper-text" style="margin-bottom: 12px;">@stats.Insight</div>
            <div class="ops-stat-scroll" role="region" aria-label="Adjustment statistics table" tabindex="0">
                <div class="ops-stat-grid">
                    @foreach (var head in new[] { "GROUP", "COUNT", "AVG SET", "AVG ROOM", "AVG OUT" })
                    {
                        <div class="ops-stat-grid__cell ops-stat-grid__cell--head">@head</div>
                    }
                    @foreach (var row in new[] { stats.PersonHome, stats.PersonAway, stats.BedroomOccupied, stats.BedroomEmpty })
                    {
                        <div class="ops-stat-grid__cell ops-stat-grid__cell--label">@row.Label</div>
                        <div class="ops-stat-grid__cell">@row.Count</div>
                        <div class="ops-stat-grid__cell">@Format.TempDeg(row.AverageSetPointCelsius)</div>
                        <div class="ops-stat-grid__cell">@Format.TempDeg(row.AverageRoomTemperatureCelsius)</div>
                        <div class="ops-stat-grid__cell">@Format.TempDeg(row.AverageOutdoorTemperatureCelsius)</div>
                    }
                    <div class="ops-stat-grid__cell ops-stat-grid__cell--total">OVERALL</div>
                    <div class="ops-stat-grid__cell ops-stat-grid__cell--total">@stats.TotalAdjustments</div>
                    <div class="ops-stat-grid__cell ops-stat-grid__cell--total">@Format.TempDeg(stats.AverageSetPointCelsius)</div>
                    <div class="ops-stat-grid__cell ops-stat-grid__cell--total">@Format.TempDeg(stats.AverageRoomTemperatureCelsius)</div>
                    <div class="ops-stat-grid__cell ops-stat-grid__cell--total">@Format.TempDeg(stats.AverageOutdoorTemperatureCelsius)</div>
                </div>
            </div>
        </div>
    }

    @if (_historyLoading)
    {
        <div class="ops-panel ops-panel--pad" role="status">
            <h2 class="ops-panel__label">RECORDER HISTORY — LOADING</h2>
            <div class="helper-text">Reading the real Home Assistant climate archive…</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_historyError))
    {
        <div class="ops-panel ops-panel--pad" role="alert">
            <h2 class="ops-panel__label">RECORDER HISTORY — UNAVAILABLE</h2>
            <div class="helper-text" style="margin-bottom: 10px;">@_historyError</div>
            <button class="ops-btn ops-btn--outline" @onclick="RetryHistory">↻ RETRY REAL HISTORY</button>
        </div>
    }

    @* ---------- Histogram + derived algorithm (auto-loaded from the recorder archive) ---------- *@
    @if (_history is { Count: > 1 })
    {
        <div class="ops-panel ops-panel--pad">
            <h2 class="ops-panel__label">SETPOINT CHANGES BY HOUR OF DAY (TORONTO)</h2>
            <div class="ops-usage-bars" style="height: 70px; margin-bottom: 4px;" role="img" aria-label="@HistogramAccessibleLabel">
                @foreach (var (hour, count) in HourHistogram)
                {
                    <div class="ops-usage-bars__bar @(count >= HistogramHotThreshold && HistogramMax > 0 ? "ops-usage-bars__bar--hot" : "")"
                         style="height: @(HistogramMax == 0 ? 4 : Math.Max(4, count * 100 / HistogramMax))%; border-radius: 2px 2px 0 0;"
                         title="@($"{hour:00}:00 — {count} changes")"></div>
                }
            </div>
            <div class="ops-usage-scale"><span>00</span><span>06</span><span>12</span><span>18</span><span>23</span></div>

            <div class="ops-learned">
                <h3 class="ops-learned__label">THE ALGORITHM — WHAT THE DEFENDER LEARNED</h3>
                @foreach (var line in AlgorithmLines)
                {
                    <div class="ops-learned__line">▸ @line</div>
                }
            </div>
        </div>
    }

    @* ---------- Two-column log grid ---------- *@
    <div class="ops-logs-grid">
        <div class="ops-panel ops-panel--pad" style="min-width: 0;">
            <h2 class="ops-panel__label">THERMOSTAT CHANGE LOG — EXTERNAL TOUCHES</h2>
            <input class="ops-input" style="width: 100%; box-sizing: border-box; margin: 0 0 10px 0;"
                   value="@_touchSearch" @oninput="OnTouchSearchChanged"
                   placeholder="SEARCH CHANGES…" aria-label="Search thermostat changes" />
            <div class="ops-logs-list">
                @if (FilteredThermostatChanges.Any())
                {
                    @foreach (var change in FilteredThermostatChanges)
                    {
                        <button class="ops-log-row" @onclick="@(() => SelectTouchLog(change))">
                            <span class="ops-log-row__change">@($"{change.PreviousSetPointCelsius:0.0} → {change.NewSetPointCelsius:0.0}°C")</span>
                            <span class="ops-log-row__source">@SourceLabel(change)</span>
                            <span class="ops-log-row__context">@($"{Format.TempDeg(change.RoomTemperatureCelsius)} room · {Format.TempDeg(change.OutdoorTemperatureCelsius)} outdoor · {change.WeatherCondition ?? "weather --"}")</span>
                            <span class="ops-log-row__time">@Format.ShortTime(change.Timestamp)</span>
                        </button>
                    }
                }
                else
                {
                    <div class="helper-text">No external thermostat changes match.</div>
                }
            </div>
        </div>

        <div class="ops-panel ops-panel--pad" style="min-width: 0;">
            <h2 class="ops-panel__label">ACTIVITY — WHAT THE DEFENDER HAS BEEN DOING</h2>
            <input class="ops-input" style="width: 100%; box-sizing: border-box; margin: 0 0 10px 0;"
                   value="@_eventSearch" @oninput="OnEventSearchChanged"
                   placeholder="SEARCH ACTIVITY…" aria-label="Search defender activity" />
            <div class="ops-log-filterbar" role="group" aria-label="Filter defender activity">
                @foreach (var option in EventFilterOptions)
                {
                    <button type="button" class="@EventFilterClass(option.Value)" @onclick="@(() => SetEventFilter(option.Value))" title="@option.Help">
                        <span>@option.Label</span>
                        <span class="ops-log-filterbar__count">@EventFilterCount(option.Value)</span>
                    </button>
                }
                @if (HasActivityFilter)
                {
                    <button type="button" class="ops-log-filterbar__clear" @onclick="ClearActivityFilters">CLEAR</button>
                }
            </div>
            <div class="ops-log-filterbar__summary">
                SHOWING @FilteredEvents.Count OF @Events.Count ACTIVITY EVENT@(Events.Count == 1 ? "" : "S")
            </div>
            <div class="ops-logs-list ops-logs-list--tall">
                @if (FilteredEvents.Any())
                {
                    @foreach (var item in FilteredEvents)
                    {
                        var meta = EventTagFor(item);
                        <div class="ops-event clickable-row" style="border-left-color: @EventColor(item.Level);" role="button" tabindex="0"
                             @onclick="@(() => SelectEventLog(item))" @onkeydown="@(args => OnEventKeyDown(args, item))">
                            <div class="ops-event__top">
                                <span class="ops-event__time">@Format.ShortTime(item.Timestamp)</span>
                                <span class="ops-event__tag" style="border-color: @EventColor(item.Level); color: @EventColor(item.Level);">@meta.Tag</span>
                                <span class="ops-event__spacer"></span>
                                @if (meta.PageName is { } pageName)
                                {
                                    <a class="ops-event__wiki" href="@($"/wiki/{pageName}")" title="Read the wiki article for this procedure"
                                       @onclick:stopPropagation="true" @onkeydown:stopPropagation="true">⎘ WIKI</a>
                                }
                            </div>
                            <div class="ops-event__msg">@item.Message</div>
                        </div>
                    }
                }
                else
                {
                    <div class="helper-text">No activity matches.</div>
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_selectedLogJson))
    {
        <div class="ops-logs-detail">
            <div class="ops-logs-detail__head">
                <span class="ops-logs-detail__label">SELECTED LOG DETAIL — @_selectedLogTitle</span>
                <button class="ops-logs-detail__clear" @onclick="ClearSelectedLog">✕ CLEAR</button>
            </div>
            <pre class="json-detail" style="max-height: 320px; color: #c6d2d8;">@_selectedLogJson</pre>
            <div class="helper-text">The log item plus the latest thermostat and weather JSON the website has.</div>
        </div>
    }
</div>

@code {
    private const string AllEventFilter = "all";

    private string _touchSearch = "";
    private string _eventSearch = "";
    private string _eventFilter = AllEventFilter;
    private string _selectedLogTitle = "";
    private string _selectedLogJson = "";

    private static readonly (string Value, string Label, string Help)[] EventFilterOptions =
    [
        (AllEventFilter, "ALL", "Show every defender activity event."),
        ("report", "REPORTS", "Routine informational activity."),
        ("notice", "NOTICES", "Warnings and quiet-timing holds that need attention."),
        ("alert", "ALERTS", "Error-level activity such as Home Assistant or cooling-failure problems."),
        ("success", "SUCCESS", "Success or OK activity."),
        ("wiki", "WIKI", "Events linked to a guard wiki article.")
    ];

    private static readonly JsonSerializerOptions LogJsonOptions = new(JsonSerializerDefaults.Web) { WriteIndented = true };

    // Guard names → real wiki page names, so punctuation such as "&" cannot produce a dead link.
    private IReadOnlyList<(string Name, string PageName)> _guardWikiPages = [];

    private DefenderSnapshot Snapshot => State.Snapshot;

    private IReadOnlyList<DefenderEvent> Events => Snapshot?.Events ?? Array.Empty<DefenderEvent>();

    // ---------- history archive (auto-loaded once for the histogram + learned lines) ----------

    private IReadOnlyList<ClimateHistorySample>? _history;
    private string? _historyEntityId;
    private bool _historyLoading;
    private string? _historyError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var entityId = Snapshot?.HomeAssistantEntityId;
        if (_historyLoading
            || string.IsNullOrWhiteSpace(entityId)
            || string.Equals(_historyEntityId, entityId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await LoadHistory(entityId);
    }

    private async Task RetryHistory()
    {
        var entityId = Snapshot?.HomeAssistantEntityId;
        if (string.IsNullOrWhiteSpace(entityId))
        {
            _historyError = "Waiting for Home Assistant to report the real climate entity.";
            return;
        }

        await LoadHistory(entityId, force: true);
    }

    private async Task LoadHistory(string entityId, bool force = false)
    {
        if (_historyLoading
            || (!force && string.Equals(_historyEntityId, entityId, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        _historyEntityId = entityId;
        _historyLoading = true;
        _historyError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var to = DateTimeOffset.UtcNow;
            _history = (await HomeAssistant.GetClimateHistoryAsync(entityId, to.AddDays(-31), to, CancellationToken.None))
                .OrderBy(s => s.Timestamp)
                .ToList();
        }
        catch (Exception ex)
        {
            _history = null;
            _historyError = $"Home Assistant recorder history failed: {ex.Message}";
        }
        finally
        {
            _historyLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private IReadOnlyList<ClimateHistorySample> SetpointChanges =>
        _history is null
            ? Array.Empty<ClimateHistorySample>()
            : _history.Zip(_history.Skip(1), (a, b) => (a, b))
                .Where(p => p.a.SetPointCelsius is { } sa && p.b.SetPointCelsius is { } sb && Math.Abs(sa - sb) > 0.05)
                .Select(p => p.b)
                .ToList();

    private int AppChangeCount => SetpointChanges.Count(s => !string.IsNullOrWhiteSpace(s.ContextUserId));

    private IReadOnlyList<(int Hour, int Count)> HourHistogram
    {
        get
        {
            var counts = new int[24];
            foreach (var change in SetpointChanges)
            {
                counts[Format.ToToronto(change.Timestamp).Hour]++;
            }

            return Enumerable.Range(0, 24).Select(h => (h, counts[h])).ToList();
        }
    }

    private int HistogramMax => HourHistogram.Count == 0 ? 0 : HourHistogram.Max(h => h.Count);
    private int HistogramHotThreshold => Math.Max(1, (int)(HistogramMax * 0.7));

    private string HistogramAccessibleLabel
    {
        get
        {
            var populatedHours = HourHistogram.Where(item => item.Count > 0).ToArray();
            if (populatedHours.Length == 0)
            {
                return "Setpoint changes by hour of day in Toronto. No setpoint changes were recorded.";
            }

            var values = string.Join(", ", populatedHours.Select(item =>
                $"{item.Hour:00}:00, {item.Count} change{(item.Count == 1 ? string.Empty : "s")}"));
            return $"Setpoint changes by hour of day in Toronto. {values}.";
        }
    }

    private string BusiestHoursText => string.Join(" · ",
        HourHistogram.Where(h => h.Count > 0).OrderByDescending(h => h.Count).Take(3).Select(h => $"{h.Hour:00}:00"));

    private IReadOnlyList<string> AlgorithmLines
    {
        get
        {
            var lines = new List<string>();
            var changes = SetpointChanges;
            if (_history is { Count: > 1 } h)
            {
                var span = h[^1].Timestamp - h[0].Timestamp;
                lines.Add($"Across {span.TotalDays:0.0} days Home Assistant recorded {h.Count} climate states and {changes.Count} setpoint changes ({AppChangeCount} from app users, the rest wall/device/defender).");

                var setpoints = h.Where(s => s.SetPointCelsius is not null).Select(s => s.SetPointCelsius!.Value).ToList();
                var rooms = h.Where(s => s.CurrentTemperatureCelsius is not null).Select(s => s.CurrentTemperatureCelsius!.Value).ToList();
                if (setpoints.Count > 0 && rooms.Count > 0)
                {
                    lines.Add($"Setpoint lived between {setpoints.Min():0.0} and {setpoints.Max():0.0} °C (average {setpoints.Average():0.0}); the room lived between {rooms.Min():0.0} and {rooms.Max():0.0} °C (average {rooms.Average():0.0}).");
                }

                if (BusiestHoursText.Length > 0)
                {
                    lines.Add($"The thermostat war peaks around {BusiestHoursText} — the defenders treat these hours as sensitive and act extra slowly there.");
                }
            }

            if (Snapshot?.HistoryLearning is { MedianTouchIntervalMinutes: { } median })
            {
                lines.Add($"Humans in this house touch the thermostat roughly every {median:0} minutes when active — corrections are paced to blend under that rhythm.");
            }

            lines.Add("Standing rules regardless of history: \"the temp I want\" is a hard floor, every command is one 0.5 °C step, raises earn a peace offering, and 3 h of fruitless cooling forces a rest.");
            return lines;
        }
    }

    private void OnTouchSearchChanged(ChangeEventArgs e) => _touchSearch = e.Value?.ToString() ?? "";

    private void OnEventSearchChanged(ChangeEventArgs e) => _eventSearch = e.Value?.ToString() ?? "";

    private bool HasActivityFilter =>
        !string.Equals(_eventFilter, AllEventFilter, StringComparison.Ordinal)
        || !string.IsNullOrWhiteSpace(_eventSearch);

    private void SetEventFilter(string filter) => _eventFilter = filter;

    private void ClearActivityFilters()
    {
        _eventSearch = "";
        _eventFilter = AllEventFilter;
    }

    private string EventFilterClass(string filter) =>
        string.Equals(_eventFilter, filter, StringComparison.Ordinal) ? "ops-log-filter active" : "ops-log-filter";

    private int EventFilterCount(string filter) => Events.Count(item => MatchesEventFilter(item, filter));

    private IEnumerable<ThermostatChangeAudit> FilteredThermostatChanges =>
        (Snapshot?.ThermostatChanges ?? Array.Empty<ThermostatChangeAudit>())
            .Where(change => Format.MatchesSearch(
                _touchSearch,
                $"{change.PreviousSetPointCelsius:0.0}",
                $"{change.NewSetPointCelsius:0.0}",
                Format.ShortTime(change.Timestamp),
                Format.TempDeg(change.RoomTemperatureCelsius),
                Format.TempDeg(change.OutdoorTemperatureCelsius),
                change.WeatherCondition,
                SourceLabel(change),
                change.ChangeSource,
                change.SourceDetail,
                change.ContextUserId));

    private IReadOnlyList<DefenderEvent> FilteredEvents =>
        Events
            .Where(item => MatchesEventFilter(item, _eventFilter))
            .Where(item => Format.MatchesSearch(
                _eventSearch,
                item.Level,
                item.Message,
                Format.DateTimeText(item.Timestamp),
                EventTagFor(item).Tag))
            .ToList();

    private bool MatchesEventFilter(DefenderEvent item, string filter)
    {
        if (string.Equals(filter, AllEventFilter, StringComparison.Ordinal))
        {
            return true;
        }

        var level = (item.Level ?? "").ToLowerInvariant();
        return filter switch
        {
            "alert" => level == "error",
            "notice" => level == "warning",
            "success" => level is "success" or "ok",
            "wiki" => EventTagFor(item).PageName is not null,
            "report" => level is not ("error" or "warning" or "success" or "ok"),
            _ => true
        };
    }

    private void SelectTouchLog(ThermostatChangeAudit change)
    {
        _selectedLogTitle = $"THERMOSTAT CHANGE {Format.ShortTime(change.Timestamp)}";
        _selectedLogJson = JsonSerializer.Serialize(new { Type = "thermostat-change", Change = change, Latest = BuildLogContext() }, LogJsonOptions);
    }

    private void SelectEventLog(DefenderEvent item)
    {
        _selectedLogTitle = $"ACTIVITY {Format.ShortTime(item.Timestamp)}";
        _selectedLogJson = JsonSerializer.Serialize(new { Type = "activity", Event = item, Latest = BuildLogContext() }, LogJsonOptions);
    }

    private void OnEventKeyDown(KeyboardEventArgs args, DefenderEvent item)
    {
        if (args.Key is "Enter" or " ")
        {
            SelectEventLog(item);
        }
    }

    private static string SourceLabel(ThermostatChangeAudit change) => (change.ChangeSource ?? "").ToLowerInvariant() switch
    {
        "" => "UNKNOWN",
        "thermostat-device" => "WALL",
        "home-assistant-user" => "APP USER",
        "rival-schedule" => "SCHEDULE",
        var other => other.Replace("thermostat-device", "wall").ToUpperInvariant()
    };

    private static string EventColor(string level) => level.ToLowerInvariant() switch
    {
        "warning" => "var(--warn)",
        "error" => "var(--bad)",
        "success" or "ok" => "var(--good)",
        _ => "var(--info)"
    };

    private (string Tag, string? PageName) EventTagFor(DefenderEvent ev)
    {
        var msg = ev.Message ?? "";
        foreach (var (name, pageName) in _guardWikiPages)
        {
            if (msg.Contains(name, StringComparison.OrdinalIgnoreCase))
            {
                return (name.ToUpperInvariant(), pageName);
            }
        }

        return ((ev.Level ?? "info").ToLowerInvariant() switch
        {
            "warning" => "NOTICE",
            "error" => "ALERT",
            _ => "REPORT"
        }, null);
    }

    private void ClearSelectedLog()
    {
        _selectedLogTitle = "";
        _selectedLogJson = "";
    }

    private object BuildLogContext() => new
    {
        Snapshot?.HomeAssistantEntityId,
        Snapshot?.HomeAssistantThermostat,
        Snapshot?.Weather,
        Snapshot?.NextAction,
        Snapshot?.LastCommand,
        Snapshot?.Emergency,
        Snapshot?.SuperDefender,
        Snapshot?.CoolingFailure
    };

    protected override void OnInitialized()
    {
        _guardWikiPages = GuardCatalog.All
            .Select(guard =>
            {
                var article = WikiContent.Articles.FirstOrDefault(candidate =>
                    string.Equals(candidate.Title, guard.Name, StringComparison.OrdinalIgnoreCase));
                return (guard.Name, article?.Name ?? $"Algorithm-{Format.Slugify(guard.Name)}");
            })
            .ToList();
        State.Changed += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnStateChanged;
}
