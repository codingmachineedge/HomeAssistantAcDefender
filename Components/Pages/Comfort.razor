@page "/comfort"
@implements IDisposable
@inject DefenderStateProvider State

<PageTitle>Comfort Watch — SCP AC Defender</PageTitle>

<div class="ops-dash-stack">

    <div class="ops-comfort-metrics">
        <div class="ops-panel" style="padding: 14px 16px;">
            <h2 class="ops-panel__label">GUARD</h2>
            <div class="ops-comfort-metric__value" style="color: @GuardColor;">@GuardText</div>
            <div class="helper-text">@GuardHelp</div>
        </div>
        <div class="ops-panel" style="padding: 14px 16px;">
            <h2 class="ops-panel__label">HOTTEST UPSTAIRS</h2>
            <div class="ops-comfort-metric__value" style="color: var(--warn);">@HottestUpstairsText</div>
            <div class="helper-text">@HottestUpstairsHelp</div>
        </div>
        <div class="ops-panel" style="padding: 14px 16px;">
            <h2 class="ops-panel__label">PRESENCE</h2>
            <div class="ops-comfort-metric__value">@PresenceText</div>
            <div class="helper-text">@PresenceHelp</div>
        </div>
        <div class="ops-panel" style="padding: 14px 16px;">
            <h2 class="ops-panel__label">SENSORS</h2>
            <div class="ops-comfort-metric__value">@SensorCountText</div>
            <div class="helper-text">@SensorCountHelp</div>
        </div>
    </div>

    <div class="ops-comfort-grid">
        <div class="ops-panel ops-panel--pad">
            <h2 class="ops-panel__label">@SensorArrayLabel</h2>
            <div class="ops-sensor-list">
                @if (!HomeAssistantOnline)
                {
                    <div class="helper-text">Home Assistant is offline. Live Site-UP sensor readings are unavailable until a fresh real snapshot arrives.</div>
                }
                else if (Up?.UpstairsSensors?.Count > 0)
                {
                    @foreach (var sensor in Up.UpstairsSensors.OrderByDescending(s => s.TemperatureCelsius ?? double.MinValue))
                    {
                        var temp = sensor.TemperatureCelsius;
                        <div>
                            <div class="ops-sensor-row__top">
                                <span class="ops-sensor-row__name">@sensor.Name.ToUpperInvariant()</span>
                                <span class="ops-sensor-row__val" style="color: @BarColor(temp);">@Format.SensorValue(sensor)</span>
                            </div>
                            <div class="ops-bar"><div class="ops-bar__fill" style="width: @BarWidth(temp); background: @BarColor(temp);"></div></div>
                        </div>
                    }
                }
                else
                {
                    <div class="helper-text">No Site-UP sensors found or configured.</div>
                }
            </div>
        </div>

        <div class="ops-panel ops-panel--pad">
            <h2 class="ops-panel__label">@PresenceArrayLabel</h2>
            <div class="ops-dash-stack" style="gap: 6px;">
                @if (!HomeAssistantOnline)
                {
                    <div class="helper-text">Home Assistant is offline. Live presence values are unavailable until a fresh real snapshot arrives.</div>
                }
                else if (Up?.Presence?.Count > 0)
                {
                    @foreach (var person in Up.Presence)
                    {
                        <div class="ops-presence-row">
                            <span class="ops-presence-row__dot" style="background: @(person.IsHome ? "var(--good)" : "var(--sub)");" aria-hidden="true"></span>
                            <span class="ops-presence-row__name">@person.Name.ToUpperInvariant()</span>
                            <span class="ops-presence-row__state" style="color: @(person.IsHome ? "var(--good)" : "var(--sub)");">@person.State.ToUpperInvariant()</span>
                        </div>
                    }
                }
                else
                {
                    <div class="helper-text">No presence entities found or configured.</div>
                }
            </div>
            <div class="helper-text" style="margin-top: 12px;">Site-UP priority only fires while a human is home to feel the heat. The containment team does not cool empty chambers out of principle.</div>
        </div>
    </div>
</div>

@code {
    private ComfortSnapshot? Up => State.Snapshot?.Comfort;
    private bool DefenderEnabled => State.Snapshot?.DefenderEnabled == true;

    private bool HomeAssistantOnline =>
        string.Equals(State.Snapshot.ConnectionState, "home-assistant", StringComparison.OrdinalIgnoreCase);

    private bool HasUsableUpstairsReading =>
        HomeAssistantOnline
        && Up?.UpstairsSensors?.Any(sensor => sensor.TemperatureCelsius is not null) == true;

    private bool GuardOff => HomeAssistantOnline
        && Up is not null
        && (!DefenderEnabled || Up.UpstairsComfortEnabled != true);

    private bool GuardWaiting => HomeAssistantOnline
        && !GuardOff
        && (Up is null || !HasUsableUpstairsReading);

    private string GuardText => !HomeAssistantOnline
        ? "UNAVAILABLE"
        : GuardOff
            ? "OFF"
            : GuardWaiting
                ? "WAITING"
                : Up?.UpstairsTooHot == true
                    ? "COOLING"
                    : "WATCHING";

    private string GuardColor => !HomeAssistantOnline || GuardOff || GuardWaiting
        ? "var(--sub)"
        : Up?.UpstairsTooHot == true
            ? "var(--warn)"
            : "var(--good)";

    private string GuardHelp => !HomeAssistantOnline
        ? "Home Assistant is offline. Retained comfort-guard state is hidden while the worker waits for fresh readings."
        : Up is null
            ? "Waiting for upstairs readings."
            : !DefenderEnabled
                ? "Comfort guard stood down; the worker still refreshes real Home Assistant state 24/7."
                : Up.UpstairsComfortEnabled != true
                    ? "Upstairs Comfort Guard is disabled."
                    : !HasUsableUpstairsReading
                        ? "Waiting for a real upstairs temperature reading."
                        : Up.UpstairsTooHot == true
                            ? "Site-UP is too hot — priority cooling engaged."
                            : "Upstairs within comfort. Observing with quiet approval.";

    private string HottestUpstairsText => HomeAssistantOnline
        ? Format.TempDeg(Up?.HottestUpstairsTemperatureCelsius)
        : "--";

    private string HottestUpstairsHelp => HomeAssistantOnline
        ? "The warmest Site-UP sensor right now."
        : "Live Site-UP temperature unavailable while Home Assistant is offline.";

    private string PresenceText => !HomeAssistantOnline || Up is null
        ? "--"
        : Up.HomePresenceRequired
            ? "REQUIRED"
            : "OPTIONAL";

    private string PresenceHelp => !HomeAssistantOnline
        ? "Live Home Assistant presence state unavailable."
        : Up is null
            ? "Waiting for real Home Assistant presence state."
            : !Up.HomePresenceRequired
                ? "Presence is optional for upstairs comfort."
                : Up.Presence.Count > 0
                    ? Up.IsHome ? "Someone is home to feel the heat." : "Nobody home right now."
                    : "Waiting for a configured presence reading.";

    private string SensorCountText => HomeAssistantOnline
        ? (Up?.UpstairsSensors?.Count ?? 0).ToString()
        : "--";

    private string SensorCountHelp => HomeAssistantOnline
        ? "Site-UP thermometers found."
        : "Live sensor inventory unavailable while Home Assistant is offline.";

    private string SensorArrayLabel => HomeAssistantOnline
        ? "SITE-UP SENSOR ARRAY — LIVE"
        : "SITE-UP SENSOR ARRAY — OFFLINE";

    private string PresenceArrayLabel => HomeAssistantOnline
        ? "PRESENCE TRACKING — PERSONNEL ON SITE"
        : "PRESENCE TRACKING — OFFLINE";

    private static string BarWidth(double? temp) => temp is { } t
        ? $"{Math.Clamp((t - 20) / 8 * 100, 6, 100).ToString("0", System.Globalization.CultureInfo.InvariantCulture)}%"
        : "6%";

    private static string BarColor(double? temp) => temp switch
    {
        >= 25 => "var(--bad)",
        >= 24 => "var(--warn)",
        _ => "var(--good)"
    };

    protected override void OnInitialized() => State.Changed += OnStateChanged;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnStateChanged;
}
