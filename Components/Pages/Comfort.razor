@page "/comfort"
@implements IDisposable
@inject DefenderStateProvider State

<PageTitle>Comfort - AC Defender</PageTitle>

<div class="ops-dash-stack">

    <div class="ops-comfort-metrics">
        <div class="ops-panel" style="padding: 14px 16px;">
            <div class="ops-panel__label">GUARD</div>
            <div class="ops-comfort-metric__value" style="color: var(--accent);">@GuardText</div>
            <div class="helper-text">@(Up?.Status ?? "Waiting for upstairs readings.")</div>
        </div>
        <div class="ops-panel" style="padding: 14px 16px;">
            <div class="ops-panel__label">HOTTEST UPSTAIRS</div>
            <div class="ops-comfort-metric__value" style="color: var(--warn);">@Format.Temp(Up?.HottestUpstairsTemperatureCelsius)</div>
            <div class="helper-text">The warmest upstairs sensor right now.</div>
        </div>
        <div class="ops-panel" style="padding: 14px 16px;">
            <div class="ops-panel__label">PRESENCE</div>
            <div class="ops-comfort-metric__value">@PresenceText</div>
            <div class="helper-text">@(Up?.IsHome == true ? "Someone is home to feel the heat." : "Nobody home right now.")</div>
        </div>
        <div class="ops-panel" style="padding: 14px 16px;">
            <div class="ops-panel__label">SENSORS</div>
            <div class="ops-comfort-metric__value">@(Up?.UpstairsSensors?.Count ?? 0)</div>
            <div class="helper-text">Upstairs thermometers found.</div>
        </div>
    </div>

    <div class="ops-comfort-grid">
        <div class="ops-panel ops-panel--pad">
            <div class="ops-panel__label">UPSTAIRS SENSOR ARRAY</div>
            <div class="ops-sensor-list">
                @if (Up?.UpstairsSensors?.Count > 0)
                {
                    @foreach (var sensor in Up.UpstairsSensors.OrderByDescending(s => s.TemperatureCelsius ?? double.MinValue))
                    {
                        var temp = sensor.TemperatureCelsius;
                        <div>
                            <div class="ops-sensor-row__top">
                                <span class="ops-sensor-row__name">@sensor.Name</span>
                                <span class="ops-sensor-row__val" style="color: @BarColor(temp);">@Format.SensorValue(sensor)</span>
                            </div>
                            <div class="ops-bar"><div class="ops-bar__fill" style="width: @BarWidth(temp); background: @BarColor(temp);"></div></div>
                        </div>
                    }
                }
                else
                {
                    <div class="helper-text">No upstairs sensors found or configured.</div>
                }
            </div>
        </div>

        <div class="ops-panel ops-panel--pad">
            <div class="ops-panel__label">PRESENCE TRACKING</div>
            <div class="ops-dash-stack" style="gap: 6px;">
                @if (Up?.Presence?.Count > 0)
                {
                    @foreach (var person in Up.Presence)
                    {
                        <div class="ops-presence-row">
                            <span class="ops-presence-row__dot" style="background: @(person.IsHome ? "var(--good)" : "var(--sub)");" aria-hidden="true"></span>
                            <span class="ops-presence-row__name">@person.Name.ToUpperInvariant()</span>
                            <span class="ops-presence-row__state" style="color: @(person.IsHome ? "var(--good)" : "var(--sub)");">@person.State.ToUpperInvariant()</span>
                        </div>
                    }
                }
                else
                {
                    <div class="helper-text">No presence entities found or configured.</div>
                }
            </div>
            <div class="helper-text" style="margin-top: 12px;">Upstairs priority only fires while a human is home to feel the heat. The defenders don't cool empty rooms out of principle.</div>
        </div>
    </div>
</div>

@code {
    private ComfortSnapshot? Up => State.Snapshot?.Comfort;

    private string GuardText => Up?.UpstairsTooHot == true ? "COOLING" : Up?.UpstairsComfortEnabled == true ? "WATCHING" : "OFF";
    private string PresenceText => Up?.HomePresenceRequired == true ? "REQUIRED" : "OPTIONAL";

    private static string BarWidth(double? temp) => temp is { } t
        ? $"{Math.Clamp((t - 20) / 8 * 100, 6, 100).ToString("0", System.Globalization.CultureInfo.InvariantCulture)}%"
        : "6%";

    private static string BarColor(double? temp) => temp switch
    {
        >= 25 => "var(--bad)",
        >= 24 => "var(--warn)",
        _ => "var(--good)"
    };

    protected override void OnInitialized() => State.Changed += OnStateChanged;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnStateChanged;
}
