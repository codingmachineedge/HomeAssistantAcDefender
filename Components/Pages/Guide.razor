@page "/guide"

<PageTitle>Field Manual — SCP AC Defender</PageTitle>

<div class="ops-dash-stack">

    <div class="ops-roster-tools ops-roster-tools--sticky">
        <input class="ops-input" value="@_search" @oninput="OnSearchChanged" placeholder="SEARCH THE MANUAL…" aria-label="Search procedures" />
        <a class="ops-chip" href="/wiki">⎘ FULL WIKI</a>
    </div>

    @foreach (var group in Groups)
    {
        var entries = Filtered(group.Category).ToList();
        if (entries.Count == 0)
        {
            continue;
        }

        <div class="ops-roster-group">
            <div class="ops-roster-group__head">
                <span class="ops-roster-group__title">@group.Title</span>
                <span class="ops-roster-group__rule"></span>
                <span class="ops-roster-group__count">@entries.Count ENTR@(entries.Count == 1 ? "Y" : "IES")</span>
            </div>
            <div class="guide-grid">
                @foreach (var guard in entries)
                {
                    var live = guard.Project is not null;
                    <div class="guide-entry guide-entry--v2">
                        <div class="guide-entry__head">
                            <span class="guide-entry__name">@guard.Name</span>
                            <span class="@(live ? "guide-pill guide-pill--live" : "guide-pill guide-pill--manual")">@(live ? "LIVE CARD" : "MANUAL ONLY")</span>
                        </div>
                        <div class="guide-entry__summary">@guard.Summary</div>
                        <p class="guide-entry__does"><span class="guard-help__tag">Does</span> @guard.Output</p>
                    </div>
                }
            </div>
        </div>
    }

    @if (!AnyShown)
    {
        <div class="ops-alert-row">
            <span class="ops-alert-row__glyph" aria-hidden="true">∅</span>
            <span class="ops-alert-row__tag">NO MATCH</span>
            <span class="ops-alert-row__text">No procedure matches that search. It may be [DATA EXPUNGED].</span>
        </div>
    }
</div>

@code {
    private string _search = "";

    private static readonly (GuardCategory Category, string Title)[] Groups =
    [
        (GuardCategory.Core, "Core cooling"),
        (GuardCategory.WallTouch, "Wall-touch response"),
        (GuardCategory.Sensor, "Sensor timing"),
        (GuardCategory.System, "Safety & system"),
    ];

    private void OnSearchChanged(ChangeEventArgs e) => _search = e.Value?.ToString() ?? "";

    private IEnumerable<GuardInfo> Filtered(GuardCategory category) =>
        GuardCatalog.All.Where(g => g.Category == category && Matches(g));

    private bool Matches(GuardInfo guard) =>
        Format.MatchesSearch(_search, guard.Name, guard.Summary, guard.Output, guard.Watches, guard.Logic);

    private bool AnyShown => Groups.SelectMany(g => Filtered(g.Category)).Any();
}
