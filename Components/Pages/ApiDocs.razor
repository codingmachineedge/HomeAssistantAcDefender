    private static readonly NullabilityInfoContext Nullability = new();
    private static readonly IReadOnlyList<SchemaDoc> SchemaDocs = BuildSchemaDocs();
    private static IReadOnlyList<SchemaDoc> RequestSchemas => SchemaDocs.Where(s => s.Group == "Request payloads").ToList();
    private static IReadOnlyList<SchemaDoc> ResponseSchemas => SchemaDocs.Where(s => s.Group != "Request payloads").ToList();
    private static int RequestSchemaCount => RequestSchemas.Count;
    private static int ResponseSchemaCount => ResponseSchemas.Count;

    private IEnumerable<ApiEndpoint> FilteredEndpoints => Endpoints.Where(MatchesEndpoint);

    private void OnSearchChanged(ChangeEventArgs e) => _search = e.Value?.ToString() ?? "";

    private void SetFilter(string filter) => _filter = filter;

    private string FilterChipClass(string filter) =>
        string.Equals(_filter, filter, StringComparison.OrdinalIgnoreCase) ? "ops-chip active" : "ops-chip";

    private bool MatchesEndpoint(ApiEndpoint endpoint)
    {
        var filterMatches = string.Equals(_filter, AllFilter, StringComparison.OrdinalIgnoreCase)
            || endpoint.Tags.Any(tag => string.Equals(tag, _filter, StringComparison.OrdinalIgnoreCase));

        if (!filterMatches)
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return Format.MatchesSearch(
            _search,
            endpoint.Method,
            endpoint.Path,
            endpoint.Group,
            endpoint.Summary,
            endpoint.Body,
            endpoint.Response,
            endpoint.Query ?? "",
            endpoint.Safety,
            string.Join(" ", endpoint.Notes));
    }

    private static string MethodClass(string method) => $"api-method api-method--{method.ToLowerInvariant()}";

    private static string Slug(string value)
    {
        var chars = value.ToLowerInvariant()
            .Select(ch => char.IsLetterOrDigit(ch) ? ch : '-')
            .ToArray();
        return string.Join("", new string(chars).Split('-', StringSplitOptions.RemoveEmptyEntries));
    }

    private static IReadOnlyList<SchemaDoc> BuildSchemaDocs()
    {
        var models = typeof(DefenderSnapshot).Assembly.GetTypes()
            .Where(IncludeApiModel)
            .Select(type => new SchemaDoc(type.Name, SchemaGroup(type), SchemaFields(type), EnumValues(type)))
            .OrderBy(doc => SchemaSort(doc.Group))
            .ThenBy(doc => doc.Name, StringComparer.Ordinal)
            .ToList();

        return models;
    }

    private static bool IncludeApiModel(Type type)
    {
        if (type.Namespace != "HomeAssistantAcDefender.Models" || !type.IsPublic)
        {
            return false;
        }

        if (type == typeof(WebsiteCommandGateResult) || type == typeof(ScheduleEntry))
        {
            return true;
        }

        return type.IsEnum
            || type.Name.EndsWith("Request", StringComparison.Ordinal)
            || type.Name.EndsWith("Snapshot", StringComparison.Ordinal)
            || type.Name.EndsWith("Reading", StringComparison.Ordinal)
            || type.Name.EndsWith("Entry", StringComparison.Ordinal)
            || type.Name.EndsWith("Audit", StringComparison.Ordinal)
            || type.Name.EndsWith("Event", StringComparison.Ordinal)
            || type.Name.EndsWith("Settings", StringComparison.Ordinal)
            || type.Name.EndsWith("Sample", StringComparison.Ordinal)
            || type.Name.EndsWith("State", StringComparison.Ordinal)
            || type.Name.EndsWith("Result", StringComparison.Ordinal)
            || type.Name.EndsWith("Usage", StringComparison.Ordinal)
            || type.Name == nameof(EntityActivation);
    }

    private static string SchemaGroup(Type type)
    {
        if (type.Name.EndsWith("Request", StringComparison.Ordinal))
        {
            return "Request payloads";
        }

        if (type.Name.EndsWith("Snapshot", StringComparison.Ordinal) || type.Name.EndsWith("Settings", StringComparison.Ordinal))
        {
            return "State responses";
        }

        if (type.Name.Contains("Usage", StringComparison.Ordinal) || type.Name.Contains("Alectra", StringComparison.Ordinal))
        {
            return "Usage responses";
        }

        return "Shared models";
    }

    private static int SchemaSort(string group) => group switch
    {
        "Request payloads" => 0,
        "State responses" => 1,
        "Usage responses" => 2,
        _ => 3
    };

    private static IReadOnlyList<string> EnumValues(Type type) =>
        type.IsEnum ? Enum.GetNames(type) : Array.Empty<string>();

    private static IReadOnlyList<SchemaField> SchemaFields(Type type)
    {
        if (type.IsEnum)
        {
            return Array.Empty<SchemaField>();
        }

        var ctor = type.GetConstructors()
            .OrderByDescending(c => c.GetParameters().Length)
            .FirstOrDefault(c => c.GetParameters().Length > 0);

        if (ctor is not null)
        {
            return ctor.GetParameters()
                .Select(p => new SchemaField(ToJsonName(p.Name ?? ""), DisplayType(p.ParameterType, IsNullable(p)), FieldState(p)))
                .ToList();
        }

        return type.GetProperties(BindingFlags.Instance | BindingFlags.Public)
            .Where(p => p.GetMethod is not null)
            .Select(p => new SchemaField(ToJsonName(p.Name), DisplayType(p.PropertyType, IsNullable(p)), FieldState(p)))
            .ToList();
    }

    private static bool IsNullable(ParameterInfo parameter) =>
        Nullable.GetUnderlyingType(parameter.ParameterType) is not null
        || Nullability.Create(parameter).ReadState == NullabilityState.Nullable;

    private static bool IsNullable(PropertyInfo property) =>
        Nullable.GetUnderlyingType(property.PropertyType) is not null
        || Nullability.Create(property).ReadState == NullabilityState.Nullable;

    private static string FieldState(ParameterInfo parameter) =>
        parameter.HasDefaultValue ? "optional" : IsNullable(parameter) ? "nullable" : "required";

    private static string FieldState(PropertyInfo property) => IsNullable(property) ? "nullable" : "required";

    private static string DisplayType(Type type, bool nullable)
    {
        var name = DisplayTypeCore(Nullable.GetUnderlyingType(type) ?? type);
        return nullable && !name.EndsWith('?') ? $"{name}?" : name;
    }

    private static string DisplayTypeCore(Type type)
    {
        if (type == typeof(string))
        {
            return "string";
        }

        if (type == typeof(bool))
        {
            return "boolean";
        }

        if (type == typeof(int) || type == typeof(long))
        {
            return "integer";
        }

        if (type == typeof(double) || type == typeof(float) || type == typeof(decimal))
        {
            return "number";
        }

        if (type == typeof(DateTimeOffset) || type == typeof(DateTime))
        {
            return "string(date-time)";
        }

        if (type.IsArray)
        {
            return $"{DisplayTypeCore(type.GetElementType() ?? typeof(object))}[]";
        }

        if (type.IsGenericType)
        {
            var definition = type.GetGenericTypeDefinition();
            if (definition == typeof(IReadOnlyList<>) || definition == typeof(List<>) || definition == typeof(IEnumerable<>))
            {
                return $"{DisplayTypeCore(type.GetGenericArguments()[0])}[]";
            }
        }

        return type.Name;
    }

    private static string ToJsonName(string name) =>
        string.IsNullOrEmpty(name) ? name : char.ToLowerInvariant(name[0]) + name[1..];

    private sealed record ApiEndpoint(
        string Method,
        string Path,
        string Group,
        string Summary,
        string Auth,
        string Body,
        string Response,
        string? Query,
        string Safety,
        IReadOnlyList<string> Statuses,
        IReadOnlyList<string> Tags,
        string Example,
        IReadOnlyList<string> Notes)
    {
        public string Anchor => $"api-{Method.ToLowerInvariant()}-{Slug(Path)}";
    }

    private sealed record SchemaDoc(string Name, string Group, IReadOnlyList<SchemaField> Fields, IReadOnlyList<string> EnumValues);

    private sealed record SchemaField(string Name, string Type, string State);
}
