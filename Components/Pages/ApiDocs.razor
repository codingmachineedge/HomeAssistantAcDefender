@page "/api-docs"
@using System.Reflection

<PageTitle>API Documentation - SCP AC Defender</PageTitle>

<div class="ops-dash-stack api-docs">
    <section class="api-hero">
        <div class="api-hero__main">
            <div class="api-hero__eyebrow">AUTHENTICATED MINIMAL API</div>
            <h2 class="api-hero__title">AC Defender API</h2>
            <p class="api-hero__copy">
                Every private endpoint below is mapped under <code>/api</code> in the running app and requires the same signed-in session as the dashboard.
                Command routes use the real defender state store and, where noted, the real configured Home Assistant climate entity.
            </p>
        </div>
        <div class="api-hero__stats">
            <div class="api-stat">
                <span class="api-stat__value">@Endpoints.Count</span>
                <span class="api-stat__label">ENDPOINTS</span>
            </div>
            <div class="api-stat">
                <span class="api-stat__value">@SchemaDocs.Count</span>
                <span class="api-stat__label">SCHEMAS</span>
            </div>
            <div class="api-stat">
                <span class="api-stat__value">1</span>
                <span class="api-stat__label">PUBLIC GET</span>
            </div>
        </div>
    </section>

    <section class="api-info-grid">
        <div class="api-info-card">
            <h2 class="ops-panel__label">AUTHENTICATION</h2>
            <p>Private routes use the app's cookie-auth session. Same-origin JavaScript calls should include credentials; external callers need to sign in first and preserve the session cookie.</p>
        </div>
        <div class="api-info-card api-info-card--warn">
            <h2 class="ops-panel__label">THERMOSTAT SAFETY</h2>
            <p>Thermostat endpoints do not mock HVAC. They call Home Assistant or return a real error. Repeated thermostat-affecting commands can return <code>429</code> with the current snapshot.</p>
        </div>
        <div class="api-info-card">
            <h2 class="ops-panel__label">CONTENT TYPE</h2>
            <p>JSON endpoints accept and return <code>application/json</code>. <code>/api/status/stream</code> returns Server-Sent Events, and <code>/api/camera/webrtc</code> exchanges SDP strings.</p>
        </div>
    </section>

    <div class="ops-roster-tools ops-roster-tools--sticky api-tools">
        <input class="ops-input" value="@_search" @oninput="OnSearchChanged" placeholder="SEARCH ENDPOINTS OR MODELS..." aria-label="Search API docs" />
        @foreach (var filter in Filters)
        {
            <button class="@FilterChipClass(filter)" @onclick="@(() => SetFilter(filter))">@filter.ToUpperInvariant()</button>
        }
    </div>

    <div class="api-docs-grid">
        <aside class="api-toc">
            <h2 class="ops-panel__label">ENDPOINT GROUPS</h2>
            @foreach (var group in EndpointGroups)
            {
                var count = FilteredEndpoints.Count(e => e.Group == group);
                if (count == 0)
                {
                    continue;
                }

                <a href="@($"#{Slug(group)}")" class="api-toc__link">
                    <span>@group</span>
                    <span>@count</span>
                </a>
            }

            <h2 class="ops-panel__label api-toc__schema-label">SCHEMAS</h2>
            <a href="#request-schemas" class="api-toc__link"><span>Request payloads</span><span>@RequestSchemaCount</span></a>
            <a href="#model-schemas" class="api-toc__link"><span>Response models</span><span>@ResponseSchemaCount</span></a>
        </aside>

        <div class="api-main">
            @if (!FilteredEndpoints.Any())
            {
                <div class="ops-alert-row">
                    <span class="ops-alert-row__glyph" aria-hidden="true">0</span>
                    <span class="ops-alert-row__tag">NO MATCH</span>
                    <span class="ops-alert-row__text">No endpoint matches that API search.</span>
                </div>
            }

            @foreach (var group in EndpointGroups)
            {
                var endpoints = FilteredEndpoints.Where(e => e.Group == group).ToList();
                if (endpoints.Count == 0)
                {
                    continue;
                }

                <section class="api-group" id="@Slug(group)">
                    <div class="ops-roster-group__head">
                        <h2 class="ops-roster-group__title">@group</h2>
                        <span class="ops-roster-group__rule"></span>
                        <span class="ops-roster-group__count">@endpoints.Count ROUTE@(endpoints.Count == 1 ? "" : "S")</span>
                    </div>

                    <div class="api-endpoint-list">
                        @foreach (var endpoint in endpoints)
                        {
                            <article class="api-endpoint-card" id="@endpoint.Anchor">
                                <header class="api-endpoint-card__head">
                                    <span class="@MethodClass(endpoint.Method)">@endpoint.Method</span>
                                    <h3 class="api-path"><code>@endpoint.Path</code></h3>
                                    <span class="api-endpoint-card__auth">@endpoint.Auth</span>
                                </header>

                                <p class="api-endpoint-card__summary">@endpoint.Summary</p>

                                <div class="api-meta-grid">
                                    <div>
                                        <div class="api-meta__label">BODY</div>
                                        <div class="api-meta__value">@endpoint.Body</div>
                                    </div>
                                    <div>
                                        <div class="api-meta__label">RESPONSE</div>
                                        <div class="api-meta__value">@endpoint.Response</div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(endpoint.Query))
                                    {
                                        <div>
                                            <div class="api-meta__label">QUERY</div>
                                            <div class="api-meta__value">@endpoint.Query</div>
                                        </div>
                                    }
                                    <div>
                                        <div class="api-meta__label">SAFETY</div>
                                        <div class="api-meta__value">@endpoint.Safety</div>
                                    </div>
                                </div>

                                <div class="api-status-row">
                                    @foreach (var status in endpoint.Statuses)
                                    {
                                        <span class="api-status">@status</span>
                                    }
                                </div>

                                @if (endpoint.Notes.Count > 0)
                                {
                                    <ul class="api-notes">
                                        @foreach (var note in endpoint.Notes)
                                        {
                                            <li>@note</li>
                                        }
                                    </ul>
                                }

                                <pre class="api-example" tabindex="0" aria-label="@($"{endpoint.Method} {endpoint.Path} example")"><code>@endpoint.Example</code></pre>
                            </article>
                        }
                    </div>
                </section>
            }

            <section class="api-group" id="request-schemas">
                <div class="ops-roster-group__head">
                    <h2 class="ops-roster-group__title">Request Payloads</h2>
                    <span class="ops-roster-group__rule"></span>
                    <span class="ops-roster-group__count">@RequestSchemaCount MODELS</span>
                </div>
                <div class="api-schema-grid">
                    @foreach (var doc in RequestSchemas)
                    {
                        <details class="api-schema-card">
                            <summary>
                                <span class="api-schema-card__name">@doc.Name</span>
                                <span class="api-schema-card__group">@doc.Group</span>
                            </summary>
                            @if (doc.EnumValues.Count > 0)
                            {
                                <div class="api-enum-values">@string.Join(", ", doc.EnumValues)</div>
                            }
                            else
                            {
                                <table class="api-field-table">
                                    <thead>
                                        <tr><th>JSON field</th><th>Type</th><th>State</th></tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var field in doc.Fields)
                                        {
                                            <tr><td><code>@field.Name</code></td><td>@field.Type</td><td>@field.State</td></tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </details>
                    }
                </div>
            </section>

            <section class="api-group" id="model-schemas">
                <div class="ops-roster-group__head">
                    <h2 class="ops-roster-group__title">Response And State Models</h2>
                    <span class="ops-roster-group__rule"></span>
                    <span class="ops-roster-group__count">@ResponseSchemaCount MODELS</span>
                </div>
                <div class="api-schema-grid">
                    @foreach (var doc in ResponseSchemas)
                    {
                        <details class="api-schema-card">
                            <summary>
                                <span class="api-schema-card__name">@doc.Name</span>
                                <span class="api-schema-card__group">@doc.Group</span>
                            </summary>
                            @if (doc.EnumValues.Count > 0)
                            {
                                <div class="api-enum-values">@string.Join(", ", doc.EnumValues)</div>
                            }
                            else
                            {
                                <table class="api-field-table">
                                    <thead>
                                        <tr><th>JSON field</th><th>Type</th><th>State</th></tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var field in doc.Fields)
                                        {
                                            <tr><td><code>@field.Name</code></td><td>@field.Type</td><td>@field.State</td></tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </details>
                    }
                </div>
            </section>
        </div>
    </div>
</div>

