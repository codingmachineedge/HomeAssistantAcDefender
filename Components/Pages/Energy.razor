    private static string PercentStyle(double percent) =>
        $"width: {percent.ToString("0.##", CultureInfo.InvariantCulture)}%;";

    private static string BlankDash(string? value) => string.IsNullOrWhiteSpace(value) || value == "--" ? "--" : value;

