    // ---------- calendar ----------

    private Dictionary<string, AcDailyUsage> _dailyUsage = new();
    private DateTime _calMonth = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private string? _selectedDayKey;

    private sealed record CalendarCell(int Day, string Key, bool IsToday, bool IsFuture, AcDailyUsage? Usage, int HeatTier);

    private void ReloadLedger() => _dailyUsage = Store.GetAcDailyUsage().ToDictionary(item => item.Date, StringComparer.Ordinal);

    private bool IsCurrentCalendarMonth => _calMonth.Year == DateTime.Today.Year && _calMonth.Month == DateTime.Today.Month;
    private void PrevMonth() => _calMonth = _calMonth.AddMonths(-1);
    private void NextMonth() => _calMonth = _calMonth.AddMonths(1);
    private void GoToThisMonth() => _calMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private void SelectDay(CalendarCell cell) => _selectedDayKey = _selectedDayKey == cell.Key ? null : cell.Key;

    private AcDailyUsage? SelectedUsage =>
        _selectedDayKey is { } key && _dailyUsage.TryGetValue(key, out var usage) ? usage : null;

    private IEnumerable<AcDailyUsage> MonthUsage()
    {
        var prefix = _calMonth.ToString("yyyy-MM", CultureInfo.InvariantCulture);
        return _dailyUsage.Values.Where(item => item.Date.StartsWith(prefix, StringComparison.Ordinal));
    }

    private IEnumerable<CalendarCell?> CalendarCells
    {
        get
        {
            var maxCost = MonthUsage().Select(item => item.CostDollars).DefaultIfEmpty(0).Max();
            var first = _calMonth;
            var today = DateTime.Today;
            for (var i = 0; i < (int)first.DayOfWeek; i++)
            {
                yield return null;
            }

            for (var day = 1; day <= DateTime.DaysInMonth(first.Year, first.Month); day++)
            {
                var date = new DateTime(first.Year, first.Month, day);
                var key = date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
                _dailyUsage.TryGetValue(key, out var usage);
                var tier = usage is null || usage.CostDollars <= 0 || maxCost <= 0
                    ? 0
                    : Math.Clamp((int)Math.Ceiling(usage.CostDollars / maxCost * 4), 1, 4);
                yield return new CalendarCell(day, key, date == today, date > today, usage, tier);
            }
        }
    }

    private string CellCss(CalendarCell cell)
    {
        var css = cell.HeatTier > 0 ? $"cal-heat-{cell.HeatTier}" : string.Empty;
        if (cell.IsToday) css += " cal-cell--today";
        if (cell.IsFuture) css += " cal-cell--future";
        if (cell.Key == _selectedDayKey) css += " cal-cell--selected";
        return css;
    }

    private string MonthSummary
    {
        get
        {
            var days = MonthUsage().Where(item => item.Hours > 0 || item.CostDollars > 0).ToList();
            var hours = days.Sum(item => item.Hours);
            var cost = days.Sum(item => item.CostDollars);
            return days.Count == 0
                ? "No AC usage recorded in this month."
                : $"Month so far: {ShortHours(hours)} cooling ≈ ${cost:0.00} across {days.Count} active day(s).";
        }
    }

    private static string ShortHours(double hours) => hours >= 10 ? $"{hours:0.0}h" : $"{(int)hours}h{(Math.Round(hours % 1 * 60) is var m and > 0 ? $"{(int)m}m" : "")}";

    private static string FormatDayLong(string key) =>
        DateTime.TryParseExact(key, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var date)
            ? date.ToString("MMMM d, yyyy", CultureInfo.InvariantCulture)
            : key;

    // ---------- lifecycle ----------

    protected override void OnInitialized()
    {
        State.Changed += OnStateChanged;
        ReloadLedger();
        _ = RefreshUsageAsync();
        _ = RefreshUsageHistoryAsync();
    }

    private async void OnStateChanged()
    {
        var refreshed = false;
        if (DateTimeOffset.UtcNow >= _nextUsageRefresh)
        {
            await RefreshUsageAsync();
            refreshed = true;
        }

        if (DateTimeOffset.UtcNow >= _nextUsageHistoryRefresh)
        {
            await RefreshUsageHistoryAsync();
            refreshed = true;
        }

        if (refreshed)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshUsageAsync()
    {
        try
        {
            _nextUsageRefresh = DateTimeOffset.UtcNow.AddSeconds(30);
            _usage = await HomeAssistant.GetLiveUsageAsync(CancellationToken.None);
            _usageError = null;
        }
        catch (Exception ex)
        {
            _nextUsageRefresh = DateTimeOffset.UtcNow.AddSeconds(30);
            _usage = null;
            _usageError = $"Usage sensor error: {ex.Message}";
        }
    }

    private async Task RefreshNow()
    {
        await RefreshUsageAsync();
        await RefreshUsageHistoryAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshUsageHistoryAsync()
    {
        try
        {
            var end = DateTimeOffset.UtcNow;
            _nextUsageHistoryRefresh = end.AddMinutes(10);
            _usageHistory = await HomeAssistant.GetUsagePowerHistoryAsync(end.AddHours(-24), end, CancellationToken.None);
            _usageHistoryUpdatedAt = end;
            _usageHistoryError = null;
        }
        catch (Exception ex)
        {
            _nextUsageHistoryRefresh = DateTimeOffset.UtcNow.AddMinutes(10);
            _usageHistoryError = $"Power history error: {ex.Message}";
        }
    }

    public void Dispose() => State.Changed -= OnStateChanged;
}
