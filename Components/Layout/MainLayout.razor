@inherits LayoutComponentBase
@implements IDisposable
@inject DefenderStateStore StateStore
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="@(_isDarkMode ? "app-dark" : "app-light")">
    <MudAppBar Class="top-bar" Color="Color.Default" Elevation="1" Fixed="false">
        <MudText Typo="Typo.h6" Class="brand-text">AC Defender</MudText>
        <MudSpacer />
        <MudButton Href="/" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.SpaceDashboard">Dashboard</MudButton>
        <MudButton Href="/settings" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Tune">Settings</MudButton>
        <MudTooltip Text="@ThemeTooltip">
            <MudIconButton Color="Color.Inherit" Icon="@ThemeIcon" OnClick="ToggleTheme" aria-label="@ThemeTooltip" />
        </MudTooltip>
        <MudChip T="string" Class="status-chip" Color="@HeaderColor" Variant="Variant.Filled">@HeaderStatus</MudChip>
    </MudAppBar>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="page-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private PeriodicTimer? timer;
    private CancellationTokenSource? timerCancellation;
    private DefenderSnapshot? snapshot;
    private bool _isDarkMode;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0f7d67",
            Secondary = "#166da8",
            Tertiary = "#b94a2f",
            AppbarBackground = "#ffffff",
            AppbarText = "#17211c",
            Background = "#f4f6f5",
            Surface = "#ffffff",
            TextPrimary = "#17211c",
            TextSecondary = "#64716b"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#46c1a7",
            Secondary = "#6fb7e9",
            Tertiary = "#e07a5f",
            AppbarBackground = "#17211c",
            AppbarText = "#e7f6ef",
            Background = "#111815",
            Surface = "#17211c",
            TextPrimary = "#e7f6ef",
            TextSecondary = "#a8b8b0",
            DrawerBackground = "#17211c"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px"
        }
    };

    private string ThemeIcon => _isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode;

    private string ThemeTooltip => _isDarkMode ? "Switch to light theme" : "Switch to dark theme";

    private string HeaderStatus => snapshot switch
    {
        null => "Starting",
        { DefenderEnabled: false } => "Paused",
        { ConnectionState: "home-assistant" } => "Defender active",
        _ => "Home Assistant unavailable"
    };

    private Color HeaderColor => snapshot switch
    {
        null => Color.Default,
        { DefenderEnabled: false } => Color.Warning,
        { ConnectionState: "home-assistant" } => Color.Success,
        _ => Color.Error
    };

    protected override void OnInitialized()
    {
        snapshot = StateStore.GetSnapshot();
        timerCancellation = new CancellationTokenSource();
        timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = PollAsync(timerCancellation.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var savedTheme = await JS.InvokeAsync<string?>("localStorage.getItem", "ac-defender-theme");
            _isDarkMode = string.Equals(savedTheme, "dark", StringComparison.OrdinalIgnoreCase);
            StateHasChanged();
        }
        catch
        {
        }
    }

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "ac-defender-theme", _isDarkMode ? "dark" : "light");
        }
        catch
        {
        }
    }

    private async Task PollAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (timer is not null && await timer.WaitForNextTickAsync(cancellationToken))
            {
                snapshot = StateStore.GetSnapshot();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    public void Dispose()
    {
        timerCancellation?.Cancel();
        timer?.Dispose();
        timerCancellation?.Dispose();
    }
}
