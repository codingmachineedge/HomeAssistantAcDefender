@inherits LayoutComponentBase
@implements IDisposable
@inject DefenderStateProvider State
@inject DefenderStateStore StateStore
@inject AcDefenderService Defender
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="_langMode" Name="LangMode">
<div class="@RootClass">

    @* ═════════ COMMAND BAR ═════════ *@
    <header class="ops-header">
        <div class="ops-brand">
            <div class="ops-brand__mark" aria-hidden="true">
                SCP
                <span class="ops-brand__ping"></span>
            </div>
            <div>
                <div class="ops-brand__name">SCP AC DEFENDER</div>
                <div class="ops-brand__sub">SECURE · CONTAIN · PROTECT THE COOL</div>
            </div>
        </div>

        <div class="ops-header__spacer"></div>

        <a class="ops-want" href="/" title="The temp you want — the defenders hold this number until you change it">
            <span class="ops-want__label">TEMP I WANT</span>
            <span class="ops-want__value">@WantText</span>
        </a>

        <div class="ops-mood" role="status">
            <span class="ops-mood__dot"></span>
            <span class="ops-mood__label">@L(MoodLabel)</span>
        </div>

        <div class="ops-clock">
            <div class="ops-clock__time">@_clockText</div>
            <div class="ops-clock__label">SITE CLOCK · TORONTO</div>
        </div>

        <div class="ops-lang" role="group" aria-label="Language">
            <button class="@LangBtnClass(Lang.English)" @onclick="@(() => SetLangMode(Lang.English))" title="English">EN</button>
            <button class="@LangBtnClass(Lang.Cantonese)" @onclick="@(() => SetLangMode(Lang.Cantonese))" title="口語廣東話">粵</button>
            <button class="@LangBtnClass(Lang.Both)" @onclick="@(() => SetLangMode(Lang.Both))" title="English + 廣東話">EN+粵</button>
        </div>

        <button class="ops-icon-btn" @onclick="SignOut" aria-label="Sign out" title="Sign out">⏻</button>
        <button class="ops-icon-btn" @onclick="ToggleTheme" aria-label="@ThemeTooltip" title="@ThemeTooltip">@ThemeGlyph</button>
    </header>

    @* ═════════ CLASSIFICATION STRIP (per-page hazard ribbon) ═════════ *@
    <div class="ops-classified" role="note">@PageStrip</div>

    <div class="ops-body">

        @* ═════════ NAV RAIL ═════════ *@
        <nav class="ops-rail" aria-label="Primary">
            <div class="ops-rail__title">@L("SITE AREAS")</div>
            @foreach (var item in Stations)
            {
                var tag = StationTag(item);
                <a href="@item.Href" class="@RailClass(item)">
                    <span class="ops-rail__glyph" aria-hidden="true">@item.Glyph</span>
                    <span class="i18n-both">@L(item.Label)</span>
                    <span class="ops-rail__spacer"></span>
                    <span class="@(tag.EndsWith('!') ? "ops-rail__tag ops-rail__tag--hot" : "ops-rail__tag")">@tag</span>
                </a>
            }

            <div class="ops-rail__flex"></div>

            <div class="ops-master">
                <div class="ops-master__label">@L("CONTAINMENT MASTER")</div>
                <button class="@MasterBtnClass" @onclick="ToggleDefender">@L(MasterText)</button>
                <div class="ops-master__help i18n-both">@L(MasterHelp)</div>
            </div>
        </nav>

        @* ═════════ MAIN ═════════ *@
        <main class="ops-main">

            @if (BannerVisible)
            {
                <div class="@BannerClass" role="alert">
                    <div class="ops-alert-banner__strip"></div>
                    <div class="ops-alert-banner__body">
                        <span class="ops-alert-banner__glyph" aria-hidden="true">⚠</span>
                        <div class="ops-alert-banner__main">
                            <div class="ops-alert-banner__title">@BannerTitle</div>
                            <div class="ops-alert-banner__sub">@BannerSub</div>
                        </div>
                        <div class="ops-alert-banner__timerbox">
                            <div class="ops-alert-banner__timer">@BannerTimer</div>
                            <div class="ops-alert-banner__timer-label">UNRESOLVED</div>
                        </div>
                        <button class="ops-alert-banner__ack" @onclick="AcknowledgeAlert">ACKNOWLEDGE</button>
                        <a class="ops-alert-banner__controls" href="/controls">OPEN CONTROLS</a>
                    </div>
                    <div class="ops-alert-banner__strip ops-alert-banner__strip--bottom"></div>
                </div>
            }

            <div class="ops-page-head">
                <span class="ops-page-head__caret" aria-hidden="true">▸</span>
                <h1 class="i18n-both">@L(PageTitle)</h1>
                <span class="ops-page-head__code">@PageCode</span>
            </div>

            @Body
        </main>
    </div>

    @* ═════════ MOBILE BOTTOM NAV ═════════ *@
    <nav class="ops-mobile-nav" aria-label="Primary mobile">
        @foreach (var item in Stations.Where(s => s.Mobile))
        {
            <a href="@item.Href" class="@MobileClass(item)">
                <div class="ops-mobile-nav__glyph" aria-hidden="true">@item.Glyph</div>
                <div class="ops-mobile-nav__label">@(_langMode == Lang.Cantonese ? L(item.Label) : item.Label)</div>
            </a>
        }
        <button class="@MobileMasterClass" @onclick="ToggleDefender" aria-label="@(DefenderIsEnabled ? "Stand down" : "Re-contain")">
            <div class="ops-mobile-nav__glyph" aria-hidden="true">@(DefenderIsEnabled ? "⛨" : "⏻")</div>
            <div class="ops-mobile-nav__label">@(DefenderIsEnabled ? "ON DUTY" : "PAUSED")</div>
        </button>
    </nav>

    @* atmosphere overlays *@
    <div class="ops-scanlines" aria-hidden="true"></div>
    <div class="ops-vignette" aria-hidden="true"></div>
    @if (IsAlertMood)
    {
        <div class="ops-alert-breathe" aria-hidden="true"></div>
    }
    @if (Mood == "omega")
    {
        <div class="ops-omega-sweep" aria-hidden="true"></div>
    }

    @* boot sequence *@
    @if (_bootStarted && _bootStep < BootDoneStep)
    {
        <div class="ops-boot" aria-hidden="true">
            <div class="ops-boot__box">
                <div class="ops-boot__title">AC DEFENDER <span>// BOOT SEQUENCE</span></div>
                @foreach (var (text, ok) in BootLines.Take(Math.Min(_bootStep, BootLines.Length)))
                {
                    <div class="@(ok ? "ops-boot__line ops-boot__line--ok" : "ops-boot__line")">@text</div>
                }
                <span class="ops-boot__cursor"></span>
                <div class="ops-boot__track">
                    <div class="ops-boot__progress" style="width: @(Math.Min(100, _bootStep * 100 / BootDoneStep))%"></div>
                </div>
            </div>
        </div>
    }
</div>
</CascadingValue>

@code {
    private bool _isDarkMode = true;
    private string _clockText = "--:--:--";
    private System.Threading.Timer? _clock;
    private int _bootStep;
    private bool _bootStarted;
    private string _langMode = Lang.English;

    // ---------- language (EN / 粵 / EN+粵) ----------

    private string L(string? english) => Lang.T(_langMode, english);

    private string LangBtnClass(string mode) =>
        _langMode == mode ? "ops-lang__btn ops-lang__btn--active" : "ops-lang__btn";

    private async Task SetLangMode(string mode)
    {
        _langMode = Lang.NormalizeMode(mode);
        StateHasChanged();
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "ac-defender-lang", _langMode);
        }
        catch
        {
        }
    }

    private const int BootDoneStep = 14;

    private static readonly (string Text, bool Ok)[] BootLines =
    [
        ("> INITIALIZING GUARD POST KERNEL", false),
        ("> CONNECTING TO HOME ASSISTANT ............ OK", true),
        ("> CLIMATE.DINING_ROOM ..................... LOCKED", true),
        ("> ROSTER: GUARD UNITS ..................... ONLINE", true),
        ("> ALECTRA HUI INTEL LINK .................. OK", true),
        ("> FRONT-DOOR KILL SWITCH .................. ARMED", true),
        ("> SNACK INVENTORY ......................... ADEQUATE", true),
        ("> ALL SECTORS NOMINAL — GUARD POST AWAKE", false),
    ];

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0e7a52",
            Secondary = "#68737b",
            Info = "#0e7a52",
            Success = "#0e7a52",
            Warning = "#9a6605",
            Error = "#c22c18",
            AppbarBackground = "#f7f5ef",
            AppbarText = "#1c2429",
            Background = "#eceae3",
            Surface = "#f7f5ef",
            DrawerBackground = "#f7f5ef",
            DrawerText = "#1c2429",
            TextPrimary = "#1c2429",
            TextSecondary = "#68737b",
            ActionDefault = "#68737b",
            LinesDefault = "#c9c3b2"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#3ddc97",
            Secondary = "#6d7c86",
            Info = "#4fc3ff",
            Success = "#3ddc97",
            Warning = "#ffb347",
            Error = "#ff5c47",
            AppbarBackground = "#0d1116",
            AppbarText = "#d9e2e6",
            Background = "#07090c",
            Surface = "#0d1116",
            DrawerBackground = "#0d1116",
            DrawerText = "#d9e2e6",
            TextPrimary = "#d9e2e6",
            TextSecondary = "#6d7c86",
            ActionDefault = "#6d7c86",
            LinesDefault = "#2a3742"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = ["JetBrains Mono", "Consolas", "monospace"] }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "0px"
        }
    };

    private DefenderSnapshot? Snapshot => State.Snapshot;

    private string WantText => Snapshot is null ? "--" : $"{Snapshot.TargetTemperatureCelsius:0.0}°C";

    // ---------- mood (drives the accent colour of the whole shell) ----------

    private string Mood => Snapshot switch
    {
        null => "standby",
        { CoolingFailure.OmegaAlerting: true } => "omega",
        { CoolingFailure.Alerting: true } => "alert",
        { FrontDoorKillSwitch.Active: true } or { FrontDoorKillSwitch.PersonDetected: true } => "alert",
        { DefenderEnabled: false } => "standby",
        _ => BusyGuardCount > 0 ? "acting" : "watching"
    };

    private string MoodLabel => Mood switch
    {
        "standby" => "SITE STANDBY",
        "acting" => "PROCEDURES ACTIVE",
        "alert" => "⚠ RED ALERT",
        "omega" => "☠ OMEGA ALERT",
        _ => Snapshot?.ConnectionState == "home-assistant" ? "CONTAINMENT NOMINAL" : "HA OFFLINE"
    };

    private bool IsAlertMood => Mood is "alert" or "omega";

    private int BusyGuardCount
    {
        get
        {
            var snapshot = Snapshot;
            if (snapshot is null
                || !snapshot.DefenderEnabled
                || !string.Equals(snapshot.ConnectionState, "home-assistant", StringComparison.OrdinalIgnoreCase))
            {
                return 0;
            }

            return GuardCatalog.Live.Count(guard => guard.Project!(snapshot) is { Enabled: true, Busy: true });
        }
    }

    private string RootClass => $"ops-root {(_isDarkMode ? "theme-dark" : "theme-light")} mood-{Mood}";

    // ---------- stations ----------

    private sealed record Station(string Href, string Glyph, string Label, string Code, bool Mobile);

    private IReadOnlyList<Station> Stations =>
    [
        new("/", "⌖", "COMMAND", "AREA-01", true),
        new("/defense", "⛨", "DEFENSE", "AREA-02", true),
        new("/comfort", "☼", "COMFORT", "AREA-03", true),
        new("/energy", "↯", "ENERGY", "AREA-04", true),
        new("/logs", "≣", "LOGS", "AREA-05", true),
        new("/controls", "⌘", "CONTROLS", "AREA-06", false),
        new("/settings", "⚙", "ORDERS", "AREA-07", true),
        new("/repository", "⇄", "REPO", "AREA-08", false),
        new("/guide", "✦", "GUIDE", "AREA-09", false),
        new("/wiki", "⎘", "WIKI", "AREA-10", true),
        new("/api-docs", "{}", "API DOCS", "AREA-11", true),
    ];

    private string CurrentPath => new Uri(Nav.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant() is { Length: > 0 } p ? p : "/";

    private bool IsActive(Station s) => s.Href == "/"
        ? CurrentPath == "/"
        : CurrentPath == s.Href || CurrentPath.StartsWith($"{s.Href}/", StringComparison.Ordinal);

    private string RailClass(Station s) => IsActive(s) ? "ops-rail__item active" : "ops-rail__item";
    private string MobileClass(Station s) => IsActive(s) ? "ops-mobile-nav__item active" : "ops-mobile-nav__item";

    private string StationTag(Station s) => s.Href switch
    {
        "/defense" when IsAlertMood => $"{BusyGuardCount}!",
        "/defense" when BusyGuardCount > 0 => $"{BusyGuardCount}",
        "/logs" when Snapshot?.ThermostatChanges is { Count: > 0 } changes => $"{Math.Min(changes.Count, 99)}",
        "/repository" => "GIT",
        "/wiki" => "FULL",
        "/api-docs" => "DOC",
        _ => ""
    };

    private string MobileMasterClass => DefenderIsEnabled
        ? "ops-mobile-nav__item ops-mobile-nav__master"
        : "ops-mobile-nav__item ops-mobile-nav__master ops-mobile-nav__master--off";

    // Per-page classification ribbon under the header (SCP flavour + a hint at the page's job).
    private string PageStrip => CurrentPath switch
    {
        "/" => "Classified — Level 4 // Eyes Only // Item #: SCP-734-AC (\"The Defender\") · Object Class: THAUMIEL · Site-DR (Dining Room)",
        "/defense" => "Containment roster — every wall touch is logged, every quiet correction accounted for · handle procedures with care",
        "/comfort" => "Classified — Level 2 // Site-UP thermal surveillance // humans get courtesy, machines don't",
        "/energy" => "Alectra Hui command tent — hours become dollars, dollars become yelling · full math in the WIKI",
        "/logs" => "Incident archive — every touch, every correction, every excuse · tap a row for the raw JSON",
        "/controls" => "Direct orders send real Home Assistant service calls · handle with Level 4 gloves",
        "/settings" => "Standing orders — the numbers the containment team defends · saved orders are version-controlled",
        "/repository" or "/settings/repository" => "Standing orders are version-controlled — every settings save is a commit · blame is a feature",
        "/guide" => "Field Manual — generated from the same guard catalog that runs the live board · full articles in the WIKI",
        "/wiki" => "Foundation wiki — every algorithm, every screenshot, one search box · zero simulators",
        "/api-docs" => "API documentation — session-gated JSON routes, real thermostat commands, public reactor voucher · zero simulators",
        _ => "SECURE · CONTAIN · PROTECT THE COOL"
    };

    private string PageTitle => CurrentPath switch
    {
        "/" => "Site Command",
        "/defense" => "Defense Roster",
        "/comfort" => "Comfort Watch",
        "/energy" => "Energy Intel",
        "/logs" => "Field Reports",
        "/controls" => "Direct Controls",
        "/settings" => "Standing Orders",
        "/repository" or "/settings/repository" => "Settings Repository",
        "/guide" => "Field Manual",
        "/api-docs" => "API Documentation",
        var path when path.StartsWith("/wiki", StringComparison.Ordinal) => "Site Wiki",
        var other => other.TrimStart('/') is { Length: > 0 } name
            ? char.ToUpperInvariant(name[0]) + name[1..]
            : "AC Defender"
    };

    private string PageCode => CurrentPath switch
    {
        "/" => "AREA-01 · O5 OVERVIEW",
        "/defense" => $"AREA-02 · {GuardCatalog.Live.Count()} UNITS",
        "/comfort" => "AREA-03 · SITE-UP (UPSTAIRS)",
        "/energy" => "AREA-04 · ALECTRA HUI",
        "/logs" => "AREA-05 · INCIDENT ARCHIVE",
        "/controls" => "AREA-06 · LEVEL 4 DIRECT",
        "/settings" => "AREA-07 · CONFIG",
        "/repository" or "/settings/repository" => "AREA-08 · GIT MANAGER",
        "/guide" => $"AREA-09 · {GuardCatalog.All.Count()} PROCEDURES",
        var w when CurrentPath.StartsWith("/wiki", StringComparison.Ordinal) => "AREA-10 · FOUNDATION WIKI",
        "/api-docs" => "AREA-11 · API REFERENCE",
        _ => ""
    };

    // ---------- master switch ----------

    private bool DefenderIsEnabled => Snapshot?.DefenderEnabled == true;
    private string MasterText => DefenderIsEnabled ? "⛨ STAND DOWN" : "⏻ RE-CONTAIN";
    private string MasterBtnClass => DefenderIsEnabled ? "ops-master__btn" : "ops-master__btn ops-master__btn--off";
    private string MasterHelp => DefenderIsEnabled ? "The containment team is awake and caffeinated." : "Suspended. Tap to wake the tiny containment shift.";

    private async Task ToggleDefender()
    {
        var enable = !DefenderIsEnabled;
        var gate = StateStore.TryBeginWebsiteCommand(enable ? "turn defender on" : "pause defender", bypassDebounce: true);
        State.Refresh();
        if (!gate.Accepted)
        {
            Snackbar.Add(gate.Message, Severity.Warning);
            return;
        }

        StateStore.SetDefenderEnabled(enable);
        State.Refresh();
        Snackbar.Add(enable ? "Defender turned on." : "Defender paused. The real thermostat can be turned off from Controls.", Severity.Info);

        if (!enable)
        {
            try
            {
                if (await Defender.ParkThermostatForStandDownAsync(CancellationToken.None) is { } parked)
                {
                    State.Refresh();
                    Snackbar.Add(parked, Severity.Info);
                }
            }
            catch
            {
                // Parking is best-effort; a Home Assistant hiccup must not block standing down.
            }
        }
    }

    // ---------- dramatic alert banner ----------

    private DateTimeOffset? _alertAckUntil;

    private bool BannerVisible =>
        (Snapshot?.CoolingFailure.Alerting == true || Snapshot?.CoolingFailure.OmegaAlerting == true)
        && (_alertAckUntil is null || DateTimeOffset.UtcNow >= _alertAckUntil);

    private string BannerClass => Snapshot?.CoolingFailure.OmegaAlerting == true
        ? "ops-alert-banner ops-alert-banner--omega"
        : "ops-alert-banner";

    private string BannerTitle => Snapshot?.CoolingFailure.OmegaAlerting == true
        ? "☠ OMEGA ALERT — COOLING FAILURE CONFIRMED"
        : "⚠ MEGA ALERT — COOLING FAILURE";

    private string BannerSub => Snapshot?.CoolingFailure.Status ?? "";

    private string BannerTimer
    {
        get
        {
            var secs = Snapshot?.CoolingFailure.OmegaAlerting == true
                ? Snapshot.CoolingFailure.OmegaSecondsActive
                : Snapshot?.CoolingFailure.SecondsActive ?? 0;
            return $"{secs / 60:00}:{secs % 60:00}";
        }
    }

    private void AcknowledgeAlert() => _alertAckUntil = DateTimeOffset.UtcNow.AddSeconds(60);

    // ---------- theme ----------

    private string ThemeGlyph => _isDarkMode ? "☀" : "☾";
    private string ThemeTooltip => _isDarkMode ? "Switch to light theme" : "Switch to dark theme";

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "ac-defender-theme", _isDarkMode ? "dark" : "light");
        }
        catch
        {
        }
    }

    // ---------- lifecycle ----------

    protected override void OnInitialized()
    {
        State.Changed += OnStateChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var savedTheme = await JS.InvokeAsync<string?>("localStorage.getItem", "ac-defender-theme");
            if (!string.IsNullOrWhiteSpace(savedTheme))
            {
                _isDarkMode = string.Equals(savedTheme, "dark", StringComparison.OrdinalIgnoreCase);
            }

            var savedLang = await JS.InvokeAsync<string?>("localStorage.getItem", "ac-defender-lang");
            if (!string.IsNullOrWhiteSpace(savedLang))
            {
                _langMode = Lang.NormalizeMode(savedLang);
            }

            StateHasChanged();
        }
        catch
        {
        }

        _clock = new System.Threading.Timer(_ => InvokeAsync(TickClock), null, TimeSpan.Zero, TimeSpan.FromSeconds(1));

        // Boot cinematic runs once per browser session, not on every navigation.
        try
        {
            var bootDone = await JS.InvokeAsync<string?>("sessionStorage.getItem", "ops-boot-done");
            if (string.IsNullOrEmpty(bootDone))
            {
                await JS.InvokeVoidAsync("sessionStorage.setItem", "ops-boot-done", "1");
                _bootStarted = true;
                StateHasChanged();
                _ = RunBootSequenceAsync();
            }
        }
        catch
        {
        }
    }

    private void TickClock()
    {
        _clockText = Format.ToToronto(DateTimeOffset.UtcNow).ToString("HH:mm:ss");
        StateHasChanged();
    }

    private async Task RunBootSequenceAsync()
    {
        while (_bootStep < BootDoneStep)
        {
            await Task.Delay(170);
            _bootStep++;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ---------- cooling-failure snackbar (kept from previous shell) ----------

    private DateTimeOffset? _lastCoolingFailureSnackbarAt;

    private void OnStateChanged()
    {
        if (Snapshot?.CoolingFailure.Alerting != true && Snapshot?.CoolingFailure.OmegaAlerting != true)
        {
            _alertAckUntil = null;
        }

        ShowCoolingFailureSnackbarIfDue();
        InvokeAsync(StateHasChanged);
    }

    private void ShowCoolingFailureSnackbarIfDue()
    {
        if (Snapshot?.CoolingFailure.Alerting != true)
        {
            _lastCoolingFailureSnackbarAt = null;
            return;
        }

        var now = DateTimeOffset.UtcNow;
        if (_lastCoolingFailureSnackbarAt is { } last && now - last < TimeSpan.FromSeconds(60))
        {
            return;
        }

        _lastCoolingFailureSnackbarAt = now;
        Snackbar.Add(Snapshot.CoolingFailure.Status, Severity.Error, options =>
        {
            options.RequireInteraction = true;
            options.VisibleStateDuration = 15000;
        });
    }

    private void SignOut()
    {
        Nav.NavigateTo("/logout", forceLoad: true);
    }

    public void Dispose()
    {
        State.Changed -= OnStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
        _clock?.Dispose();
    }
}
