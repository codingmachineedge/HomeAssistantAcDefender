@inherits LayoutComponentBase
@implements IDisposable
@inject DefenderStateProvider State
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (OmegaVisible)
{
    <div class="omega-overlay">
        <div class="omega-overlay__box">
            <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Class="omega-overlay__icon" />
            <div class="omega-overlay__title">OMEGA ALERT</div>
            <div class="omega-overlay__subtitle">Cooling failure confirmed</div>
            <p class="omega-overlay__status">@Snapshot?.CoolingFailure.Status</p>
            @if (Snapshot?.CoolingFailure.RoomRiseCelsius is { } rise)
            {
                <p class="omega-overlay__rise">Room temperature is climbing: +@rise.ToString("0.0") C over the last few minutes — consistent with the AC breaker being OFF.</p>
            }
            <div class="omega-overlay__actions">
                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Large" OnClick="GoToControls" StartIcon="@Icons.Material.Filled.Power">Open controls</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Large" OnClick="DismissOmega" Class="omega-overlay__dismiss">Dismiss for 1 min</MudButton>
            </div>
            <div class="omega-overlay__meta">Confirmed @(Snapshot?.CoolingFailure.OmegaSecondsActive ?? 0)s ago · mega alert #@(Snapshot?.CoolingFailure.AlertCount ?? 0)</div>
        </div>
    </div>
}

<MudLayout Class="@(_isDarkMode ? "app-shell app-dark" : "app-shell app-light")">
    <MudAppBar Class="top-bar" Color="Color.Default" Elevation="0" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" aria-label="Toggle navigation" />
        <MudIcon Icon="@Icons.Material.Filled.AcUnit" Class="brand-icon" />
        <MudText Typo="Typo.h6" Class="brand-text">AC Defender</MudText>
        <MudSpacer />
        <MudChip T="string" Class="status-chip" Color="@HeaderColor" Variant="Variant.Filled" Size="Size.Small">@HeaderStatus</MudChip>
        <MudTooltip Text="@ThemeTooltip">
            <MudIconButton Color="Color.Inherit" Icon="@ThemeIcon" OnClick="ToggleTheme" aria-label="@ThemeTooltip" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="1" Variant="@DrawerVariant.Responsive" Class="app-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="page-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _isDarkMode = true;
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0f7d67",
            Secondary = "#5b6cd6",
            Tertiary = "#b94a2f",
            Info = "#166da8",
            Success = "#1f9d57",
            Warning = "#c98a18",
            Error = "#c0392b",
            AppbarBackground = "#ffffff",
            AppbarText = "#17211c",
            Background = "#eef1f0",
            Surface = "#ffffff",
            DrawerBackground = "#ffffff",
            DrawerText = "#36443d",
            TextPrimary = "#17211c",
            TextSecondary = "#5d6b64",
            ActionDefault = "#5d6b64",
            LinesDefault = "#dde5e1"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#46c1a7",
            Secondary = "#8a98ef",
            Tertiary = "#e07a5f",
            Info = "#6fb7e9",
            Success = "#46c178",
            Warning = "#e6b450",
            Error = "#e57368",
            AppbarBackground = "#131b18",
            AppbarText = "#e7f6ef",
            Background = "#0f1614",
            Surface = "#17211c",
            DrawerBackground = "#131b18",
            DrawerText = "#cfe0d8",
            TextPrimary = "#e7f6ef",
            TextSecondary = "#9fb0a8",
            ActionDefault = "#9fb0a8",
            LinesDefault = "#2a3832"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = ["Segoe UI", "Inter", "Roboto", "Arial", "sans-serif"] }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px",
            DrawerWidthLeft = "248px"
        }
    };

    private string ThemeIcon => _isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode;
    private string ThemeTooltip => _isDarkMode ? "Switch to light theme" : "Switch to dark theme";

    private DefenderSnapshot? Snapshot => State.Snapshot;

    private string HeaderStatus => Snapshot switch
    {
        null => "Starting",
        { DefenderEnabled: false } => "Paused",
        { ConnectionState: "home-assistant" } => "Defender active",
        _ => "Home Assistant offline"
    };

    private Color HeaderColor => Snapshot switch
    {
        null => Color.Default,
        { DefenderEnabled: false } => Color.Warning,
        { ConnectionState: "home-assistant" } => Color.Success,
        _ => Color.Error
    };

    protected override void OnInitialized()
    {
        State.Changed += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var savedTheme = await JS.InvokeAsync<string?>("localStorage.getItem", "ac-defender-theme");
            if (!string.IsNullOrWhiteSpace(savedTheme))
            {
                _isDarkMode = string.Equals(savedTheme, "dark", StringComparison.OrdinalIgnoreCase);
                StateHasChanged();
            }
        }
        catch
        {
        }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "ac-defender-theme", _isDarkMode ? "dark" : "light");
        }
        catch
        {
        }
    }

    private DateTimeOffset? _lastCoolingFailureSnackbarAt;
    private DateTimeOffset? _omegaDismissedUntil;

    private bool OmegaVisible =>
        Snapshot?.CoolingFailure.OmegaAlerting == true
        && (_omegaDismissedUntil is null || DateTimeOffset.UtcNow >= _omegaDismissedUntil);

    private void DismissOmega() => _omegaDismissedUntil = DateTimeOffset.UtcNow.AddSeconds(60);

    private void GoToControls()
    {
        DismissOmega();
        Nav.NavigateTo("/controls");
    }

    private void OnStateChanged()
    {
        if (Snapshot?.CoolingFailure.OmegaAlerting != true)
        {
            _omegaDismissedUntil = null;
        }

        ShowCoolingFailureSnackbarIfDue();
        InvokeAsync(StateHasChanged);
    }

    private void ShowCoolingFailureSnackbarIfDue()
    {
        if (Snapshot?.CoolingFailure.Alerting != true)
        {
            _lastCoolingFailureSnackbarAt = null;
            return;
        }

        var now = DateTimeOffset.UtcNow;
        if (_lastCoolingFailureSnackbarAt is { } last && now - last < TimeSpan.FromSeconds(60))
        {
            return;
        }

        _lastCoolingFailureSnackbarAt = now;
        Snackbar.Add(Snapshot.CoolingFailure.Status, Severity.Error, options =>
        {
            options.RequireInteraction = true;
            options.VisibleStateDuration = 15000;
        });
    }

    public void Dispose() => State.Changed -= OnStateChanged;
}
