@* One decimal setting field (°C etc.) as a responsive grid item. *@
<MudItem xs="6" sm="@Sm" md="@Md">
    <MudNumericField T="double" Value="Value" ValueChanged="ValueChanged" Label="@Label" HelperText="@Help"
                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="Min" Max="Max" Step="Step"
                     Adornment="@(string.IsNullOrEmpty(Unit) ? Adornment.None : Adornment.End)" AdornmentText="@Unit" />
</MudItem>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Help { get; set; }
    [Parameter] public string? Unit { get; set; } = "C";
    [Parameter] public double Value { get; set; }
    [Parameter] public EventCallback<double> ValueChanged { get; set; }
    [Parameter] public double Min { get; set; } = 0.1;
    [Parameter] public double Max { get; set; } = 10;
    [Parameter] public double Step { get; set; } = 0.1;
    [Parameter] public int Sm { get; set; } = 6;
    [Parameter] public int Md { get; set; } = 4;
}
