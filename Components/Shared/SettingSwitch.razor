@* One toggle setting; raises ValueChanged so the page can mark itself dirty. *@
<MudItem xs="12">
    <MudSwitch T="bool" Value="Value" ValueChanged="ValueChanged" Color="Color.Success" Label="@Lang.T(LangMode, Label)" />
    @if (!string.IsNullOrWhiteSpace(Help))
    {
        <MudText Typo="Typo.caption" Class="helper-text">@Lang.T(LangMode, Help)</MudText>
    }
</MudItem>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Help { get; set; }
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [CascadingParameter(Name = "LangMode")] public string? LangMode { get; set; }
}
