@* One defender guard: live state when HA is available, documentation-only while it is offline. *@
<MudPaper Class="@($"guard-card guard-card--{Tone.Css()}")" Elevation="0">
    <div class="guard-card__head">
        <div class="guard-card__title">
            <span class="@($"guard-avatar guard-avatar--{Tone.Css()}")" aria-hidden="true">@Initials</span>
            <div class="guard-card__id">
                <MudText Typo="Typo.subtitle1" HtmlTag="h3" Class="i18n-both">@L(Info.Name)</MudText>
                <span class="guard-card__rank">@RankText</span>
            </div>
        </div>
        <span class="@($"guard-badge guard-badge--{Tone.Css()}")">@LInline(view.StateLabel)</span>
    </div>

    <MudText Typo="Typo.body2" Class="guard-card__status">@view.StatusText</MudText>

    @if (!IsOffline && view.Metrics.Count > 0)
    {
        <div class="guard-card__metrics">
            @foreach (var metric in view.Metrics)
            {
                <MudTooltip Text="@LInline(metric.Help)" Disabled="@string.IsNullOrWhiteSpace(metric.Help)">
                    <div class="guard-metric">
                        <span class="guard-metric__label i18n-both">@L(metric.Label)</span>
                        <span class="guard-metric__value">@metric.Value</span>
                    </div>
                </MudTooltip>
            }
        </div>
    }

    <div class="guard-card__actions">
        <MudButton Class="guard-card__more"
                   Variant="Variant.Text"
                   Size="Size.Small"
                   id="@HowButtonId"
                   aria-label="@HowButtonLabel"
                   aria-expanded="@(_open ? "true" : "false")"
                   aria-controls="@HowPanelId"
                   OnClick="@(() => _open = !_open)"
                   EndIcon="@(_open ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)">
            @LInline("How this works")
        </MudButton>

        <MudButton Class="guard-card__more"
                   Variant="Variant.Text"
                   Color="Color.Info"
                   Size="Size.Small"
                   id="@DetailButtonId"
                   aria-label="@DetailButtonLabel"
                   aria-expanded="@(_detailOpen ? "true" : "false")"
                   aria-controls="@DetailPanelId"
                   OnClick="@(() => _detailOpen = !_detailOpen)"
                   EndIcon="@(_detailOpen ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)">
            @LInline("More extra-specific info")
        </MudButton>
    </div>

    <MudCollapse Expanded="_open">
        <div id="@HowPanelId" class="guard-help" role="region" aria-labelledby="@HowButtonId">
            <p class="guard-help__summary i18n-both">@L(Info.Summary)</p>
            <p class="i18n-both"><span class="guard-help__tag">@LInline("Watches")</span> @L(Info.Watches)</p>
            <p class="i18n-both"><span class="guard-help__tag">@LInline("Logic")</span> @L(Info.Logic)</p>
            <p class="i18n-both"><span class="guard-help__tag">@LInline("Does")</span> @L(Info.Output)</p>
            @if (Info.Settings.Count > 0)
            {
                <p class="helper-text"><span class="guard-help__tag">@LInline("Settings")</span> @string.Join(", ", Info.Settings)</p>
            }
        </div>
    </MudCollapse>

    <MudCollapse Expanded="_detailOpen">
        <div id="@DetailPanelId" class="guard-detail" role="region" aria-labelledby="@DetailButtonId">
            <div class="guard-detail__brief">
                @foreach (var item in DetailBriefItems)
                {
                    <div class="guard-detail-brief">
                        <span>@item.Label</span>
                        <strong>@item.Value</strong>
                        <small>@item.Help</small>
                    </div>
                }
            </div>

            <div class="guard-detail__row guard-detail__row--next">
                <div class="guard-detail__label">
                    <MudIcon Icon="@Icons.Material.Filled.NearMe" Size="Size.Small" />
                    Next step for this card
                </div>
                <div class="guard-detail__text">@NextStepText</div>
            </div>

            <div class="guard-detail__row">
                <div class="guard-detail__label">
                    <MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" />
                    Current trigger verdict
                </div>
                <div class="guard-detail__text">@TriggeredByText</div>
            </div>

            <div class="guard-detail__row">
                <div class="guard-detail__label">
                    <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Size="Size.Small" />
                    What triggered this evidence
                </div>
                <div class="guard-detail__text">@EvidenceSourceText</div>
            </div>

            <div class="guard-detail__row">
                <div class="guard-detail__label">
                    <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" />
                    Future trigger — what would trigger it next
                </div>
                <div class="guard-detail__text">@FutureTriggerText</div>
            </div>

            <div class="guard-detail__row">
                <div class="guard-detail__label">
                    <MudIcon Icon="@Icons.Material.Filled.Radar" Size="Size.Small" />
                    What it is waiting to see
                </div>
                <div class="guard-detail__text">@WaitingForText</div>
            </div>

            <div class="guard-detail__row">
                <div class="guard-detail__label">
                    <MudIcon Icon="@Icons.Material.Filled.GppMaybe" Size="Size.Small" />
                    What clears or skips it
                </div>
                <div class="guard-detail__text">@ClearOrBypassText</div>
            </div>

            <div class="guard-detail__row">
                <div class="guard-detail__label">
                    <MudIcon Icon="@Icons.Material.Filled.SecurityUpdateGood" Size="Size.Small" />
                    Action when this rule applies
                </div>
                <div class="guard-detail__text">@ActionIfTriggeredText</div>
            </div>

            <div class="guard-detail__row">
                <div class="guard-detail__label">
                    <MudIcon Icon="@Icons.Material.Filled.Route" Size="Size.Small" />
                    Current defender next action
                </div>
                <div class="guard-detail__text">@GlobalNextActionText</div>
            </div>

            <div class="guard-detail__row">
                <div class="guard-detail__label">
                    <MudIcon Icon="@Icons.Material.Filled.LowPriority" Size="Size.Small" />
                    Overrule and bypass rules
                </div>
                <div class="guard-detail__text">@OverrideText</div>
            </div>

            <div class="guard-detail__algorithm">
                <div class="guard-detail__label">
                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" />
                    Exact algorithm path — card scope
                </div>
                <ol>
                    @foreach (var step in AlgorithmSteps)
                    {
                        <li>@step</li>
                    }
                </ol>
            </div>

            @if (IsOffline)
            {
                <div class="guard-detail__evidence">
                    <div class="guard-detail__label">
                        <MudIcon Icon="@Icons.Material.Filled.CloudOff" Size="Size.Small" />
                        Live evidence unavailable
                    </div>
                    <div class="guard-detail__text">Home Assistant is offline. Retained readings are hidden until a fresh real snapshot arrives.</div>
                </div>
            }
            else if (view.Metrics.Count > 0)
            {
                <div class="guard-detail__evidence">
                    <div class="guard-detail__label">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Small" />
                        Live evidence on this card
                    </div>
                    <div class="guard-detail__metrics">
                        @foreach (var metric in view.Metrics)
                        {
                            <div class="guard-detail-metric">
                                <span>@metric.Label</span>
                                <strong>@metric.Value</strong>
                                @if (!string.IsNullOrWhiteSpace(metric.Help))
                                {
                                    <small>@metric.Help</small>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </MudCollapse>
</MudPaper>

@code {
    [Parameter, EditorRequired] public GuardInfo Info { get; set; } = default!;
    [Parameter, EditorRequired] public DefenderSnapshot Snapshot { get; set; } = default!;
    [CascadingParameter(Name = "LangMode")] public string? LangMode { get; set; }

    private bool _open;
    private bool _detailOpen;

    private string HowButtonId => $"guard-how-button-{GuardOrder}";
    private string HowPanelId => $"guard-how-{GuardOrder}";
    private string DetailButtonId => $"guard-detail-button-{GuardOrder}";
    private string DetailPanelId => $"guard-detail-{GuardOrder}";
    private string HowButtonLabel => $"{LInline("How this works")}: {L(Info.Name)}";
    private string DetailButtonLabel => $"{LInline("More extra-specific info")}: {L(Info.Name)}";

    private bool IsOffline =>
        !string.Equals(Snapshot.ConnectionState, "home-assistant", StringComparison.OrdinalIgnoreCase);

    // Static catalog text is translated; the composed live-evidence narratives below stay
    // English (they interpolate live server data, which is data — not chrome).
    private string L(string? english) => Lang.T(LangMode, english);
    private string LInline(string? english) => Lang.TInline(LangMode, english);

    private string Initials => string.Concat(
        Info.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => char.ToUpperInvariant(w[0])));

    private string RankText => Info.Category switch
    {
        GuardCategory.Core => "SGT · CORE COOLING",
        GuardCategory.WallTouch => "CPL · WALL-TOUCH OPS",
        GuardCategory.Sensor => "SPC · SENSOR TIMING",
        GuardCategory.System => "LT · SAFETY & SYSTEM",
        _ => Info.Category.ToString().ToUpperInvariant()
    };
    private GuardLiveView view = default!;
    private static readonly GuardLiveView OfflineView = new(
        false,
        false,
        "Unavailable",
        GuardTone.Off,
        "Home Assistant is offline. Live guard status and evidence are unavailable.",
        Array.Empty<MetricItem>());
    private static readonly IReadOnlyList<GuardInfo> LiveCards = GuardCatalog.Live.ToList();
    private GuardTone Tone => view.Tone;
    private int GuardOrder => GetGuardOrder();
    private IReadOnlyList<DetailBriefItem> DetailBriefItems =>
    [
        new("Reference", GuardOrderText, "Position in the Defense board's reading order only; it is not AcDefenderService execution order."),
        new("Lane", CategoryName, "Which part of the defender decision board this action belongs to."),
        new("Verdict", VerdictText, "The card's projected state label, plus whether it is unavailable, disabled, or currently Busy."),
        new("Worker time", IsOffline ? "unavailable" : Snapshot.NextActionAt is { } next ? Format.ShortTime(next) : "live loop", IsOffline ? "A fresh worker time cannot be reported until Home Assistant reconnects." : "Toronto 24-hour time attached to the worker's latest cycle-level plan; it is not specific to this card.")
    ];

    private string CategoryName => Info.Category switch
    {
        GuardCategory.Core => "core cooling",
        GuardCategory.WallTouch => "wall-touch response",
        GuardCategory.Sensor => "sensor timing",
        GuardCategory.System => "safety and system",
        _ => Info.Category.ToString()
    };

    private string NextStepText
    {
        get
        {
            if (IsOffline)
            {
                return $"{Info.Name} has no current verdict because Home Assistant is offline. This reference card remains available for documentation, but no guard action is reported until a fresh real snapshot arrives.";
            }

            if (!view.Enabled)
            {
                return $"{Info.Name} is disabled in this snapshot, so its documented action is not currently eligible. The worker's latest cycle-level plan is shown below.";
            }

            if (view.Busy)
            {
                return $"{Info.Name}'s live projection reports '{view.StateLabel}'. That means this card is active, holding, shaping, waiting, or alerting; it does not mean this is the only active card or the rule that stopped the worker cycle. The next pass re-evaluates the coded worker pipeline from fresh Home Assistant data.";
            }

            return $"{Info.Name}'s live projection reports '{view.StateLabel}'. It is enabled but does not currently report a Busy card state. The worker may evaluate other rules before or after this one because board order is not execution order.";
        }
    }

    private string TriggeredByText
    {
        get
        {
            if (IsOffline)
            {
                return "Unavailable while Home Assistant is offline. Retained guard state is intentionally not treated as a current trigger verdict.";
            }

            if (!view.Enabled)
            {
                return $"Disabled in the current snapshot. Related settings: {SettingsText}.";
            }

            return view.Busy
                ? $"The card projection currently reports '{view.StateLabel}'. Busy is a card-level projected state, not a sole-winner marker. Status sentence: {view.StatusText}"
                : $"The card projection currently reports '{view.StateLabel}' and is enabled but not busy. Status sentence: {view.StatusText}";
        }
    }

    private string FutureTriggerText =>
        $"Documented activation, hold, or shaping condition: {Info.Logic} Tuned by: {SettingsText}.";

    private string EvidenceSourceText => IsOffline
        ? "No current evidence is shown while Home Assistant is offline. Retained thermostat, sensor, presence, and guard values are hidden until the connection returns."
        : view.Metrics.Count == 0
            ? $"This card has no dedicated mini-metrics yet. Its evidence still comes from the real Home Assistant snapshot and defender memory described here: {Info.Watches}"
            : $"The evidence came from these live fields: {MetricEvidenceText}. Those fields are derived from: {Info.Watches}";

    private string WaitingForText
    {
        get
        {
            if (IsOffline)
            {
                return "It is waiting for Home Assistant to reconnect and provide a fresh real snapshot. No retained reading can activate this card while the connection is unavailable.";
            }

            if (!view.Enabled)
            {
                return $"It is waiting for the related setting to be enabled. Until then, this card cannot win the cycle.";
            }

            if (view.Busy)
            {
                return $"It is already active. The next meaningful change is a timer ending, a watched value leaving the trigger range, or a higher-priority comfort/safety rule taking over.";
            }

            return $"It is waiting for a future live reading where {Info.Logic} Until then, this card's projection stays quiet while the worker continues its coded decision pipeline.";
        }
    }

    private string ClearOrBypassText
    {
        get
        {
            if (IsOffline)
            {
                return "This card is unavailable until Home Assistant reconnects. Its normal clear, skip, and safety-overrule rules are documented here but are not evaluated against retained evidence.";
            }

            if (!view.Enabled)
            {
                return "Turning the related setting back on makes this step eligible again. Until then it is skipped without defining which worker rule runs next.";
            }

            return view.Busy
                ? "It will clear when its timer/condition ends, when the watched evidence no longer matches, or when a higher-priority comfort/safety guard says cooling must happen now."
                : $"It stays quiet until the watched evidence crosses its trigger. Warm-room comfort, severe upstairs heat, or explicit quiet-bypass rules can also skip this timing card so real cooling is not delayed.";
        }
    }

    private string ActionIfTriggeredText =>
        $"Documented output when this rule's worker path applies: {Info.Output} A Busy card does not prove this output is the current cycle outcome; use the worker-level next action below.";

    private string OverrideText =>
        "The card number does not define precedence. AcDefenderService's coded early-return order and method-specific bypass flags do. Front-door, peace-offering, emergency, disabled/siesta, cooling-protection, enforcer, mode, weather, and comfort gates may end or redirect a pass before the correction pipeline. Inside that pipeline, only guards coded to accept a comfort or quiet-timing bypass step aside.";

    private string GlobalNextActionText
    {
        get
        {
            if (IsOffline)
            {
                return "Unavailable while Home Assistant is offline. The last worker label is not presented as a current next action.";
            }

            var when = Snapshot.NextActionAt is null
                ? string.Empty
                : $" Planned Toronto time: {Format.ShortTime(Snapshot.NextActionAt)}.";
            return $"{Snapshot.NextAction}{when} This is the latest stored worker-level plan. It is separate from card projections, and several cards may report Busy at once.";
        }
    }

    private IReadOnlyList<string> AlgorithmSteps => IsOffline
        ?
        [
            $"Identify {Info.Name} as reference card {GuardOrderText} in the {CategoryName} lane. This is Defense-board reading order, not worker execution order.",
            "GuardCard sees that Home Assistant is offline and substitutes its documentation-only OfflineView instead of invoking the live Project function.",
            "Retained thermostat, weather, sensor, presence, metric, card-state, and worker-action values are hidden.",
            $"Keep the documented watched signals available as reference text: {Info.Watches}",
            $"Keep the documented tuning settings available as reference text: {SettingsText}.",
            $"Keep the documented card rule available as reference text: {Info.Logic}",
            "Report the current evidence, card verdict, worker time, and worker next action as unavailable until a fresh real snapshot reconnects.",
            "Do not claim or send any action from this card based on retained evidence.",
            "After reconnection, AcDefenderService refreshes real Home Assistant state and runs its coded comfort and safety gates before any thermostat command."
        ]
        :
        [
            $"Identify {Info.Name} as reference card {GuardOrderText} in the {CategoryName} lane. This is Defense-board reading order, not worker execution order.",
            "AcDefenderService refreshes the real Home Assistant reading and runs its explicit coded pipeline; GuardCatalog does not schedule that pipeline.",
            $"This card's Project function maps snapshot state documented as: {Info.Watches}",
            $"Load its user-facing tuning settings: {SettingsText}.",
            $"Apply its documented card rule: {Info.Logic}",
            $"Projection result: Enabled = {view.Enabled}; Busy = {view.Busy}; State = '{view.StateLabel}'. Busy is a normalized card state, not a sole cycle winner.",
            $"Render this card's projected live evidence: {MetricEvidenceText}",
            $"Documented effect when its worker path applies: {Info.Output}",
            $"Latest worker-level next action: {Snapshot.NextAction}",
            "AcDefenderService applies its coded comfort and safety gates before any real thermostat command."
        ];

    private string GuardOrderText => GuardOrder <= 0
        ? "unknown"
        : $"{GuardOrder}/{LiveCards.Count}";

    private string SettingsText => Info.Settings.Count == 0
        ? "no user-facing settings"
        : string.Join(", ", Info.Settings);

    private string MetricEvidenceText => IsOffline
        ? "unavailable while Home Assistant is offline"
        : view.Metrics.Count == 0
        ? "this card has no dedicated metric yet, so use the status sentence and Home Assistant snapshot."
        : string.Join("; ", view.Metrics.Select(m =>
        {
            var help = string.IsNullOrWhiteSpace(m.Help) ? string.Empty : $" ({m.Help})";
            return $"{m.Label} = {m.Value}{help}";
        }));

    private string VerdictText
    {
        get
        {
            if (IsOffline)
            {
                return "Unavailable";
            }

            if (!view.Enabled)
            {
                return "Skipped";
            }

            return view.Busy
                ? $"{view.StateLabel} now"
                : view.StateLabel;
        }
    }

    private int GetGuardOrder()
    {
        for (var i = 0; i < LiveCards.Count; i++)
        {
            if (ReferenceEquals(LiveCards[i], Info) || LiveCards[i].Name == Info.Name)
            {
                return i + 1;
            }
        }

        return 0;
    }

    protected override void OnParametersSet()
    {
        view = IsOffline
            ? OfflineView
            : Info.Project is null
            ? new GuardLiveView(false, false, "Reference", GuardTone.Off, Info.Summary, Array.Empty<MetricItem>())
            : Info.Project(Snapshot);
    }

    private sealed record DetailBriefItem(string Label, string Value, string Help);
}
