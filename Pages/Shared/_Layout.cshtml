<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Home Assistant AC Defender</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HomeAssistantAcDefender.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <a class="brand" asp-area="" asp-page="/Index">
            <span class="brand-mark">AC</span>
            <span>Home Assistant AC Defender</span>
        </a>
        <nav class="app-nav" aria-label="Primary">
            <a asp-area="" asp-page="/Index">Dashboard</a>
            <a asp-area="" asp-page="/Settings">Settings</a>
        </nav>
        <div class="header-status" id="headerStatus">Starting</div>
    </header>
    <div class="app-shell">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
