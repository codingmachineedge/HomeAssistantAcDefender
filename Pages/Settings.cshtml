@page
@model HomeAssistantAcDefender.Pages.SettingsModel
@{
    ViewData["Title"] = "Settings";
}

<section class="settings-grid" aria-label="Defender settings">
    <article class="panel">
        <div class="panel-label">Automation</div>
        <label class="switch-row">
            <input id="settingsScheduleEnabled" type="checkbox" />
            <span>Use custom schedule</span>
        </label>
        <label class="field">
            <span>Weather activation</span>
            <select id="settingsWeatherMode">
                <option value="always">Always active</option>
                <option value="room-above-outdoor">Only when room is above outdoor temp</option>
                <option value="room-below-outdoor">Only when room is below outdoor temp</option>
                <option value="outdoor-above-target">Only when outdoor is above target</option>
                <option value="outdoor-below-target">Only when outdoor is below target</option>
            </select>
        </label>
        <div class="settings-row">
            <label class="field">
                <span>Base cooldown seconds</span>
                <input id="settingsBaseCooldown" type="number" min="0" max="3600" step="1" />
            </label>
            <label class="field">
                <span>Max cooldown seconds</span>
                <input id="settingsMaxCooldown" type="number" min="0" max="7200" step="1" />
            </label>
            <label class="field">
                <span>Touch window minutes</span>
                <input id="settingsTouchWindow" type="number" min="1" max="1440" step="1" />
            </label>
        </div>
    </article>

    <article class="panel">
        <div class="panel-label">Fan Energy Saver</div>
        <label class="switch-row">
            <input id="settingsFanSaverEnabled" type="checkbox" />
            <span>Adjust fan near target</span>
        </label>
        <div class="settings-row">
            <label class="field">
                <span>Near-target threshold C</span>
                <input id="settingsFanThreshold" type="number" min="0.1" max="5" step="0.1" />
            </label>
            <label class="field">
                <span>Fan saver mode</span>
                <input id="settingsFanMode" type="text" placeholder="auto" />
            </label>
        </div>
    </article>

    <article class="panel">
        <div class="panel-label">Upstairs Comfort</div>
        <label class="switch-row">
            <input id="settingsUpstairsEnabled" type="checkbox" />
            <span>Protect upstairs comfort</span>
        </label>
        <label class="field">
            <span>Upstairs temperature entity IDs</span>
            <input id="settingsUpstairsEntities" type="text" placeholder="sensor.upstairs_temperature, sensor.primary_bedroom_temperature" />
        </label>
        <div class="settings-row">
            <label class="field">
                <span>Max upstairs comfort C</span>
                <input id="settingsUpstairsMax" type="number" min="15" max="35" step="0.1" />
            </label>
            <label class="field">
                <span>Comfort target C</span>
                <input id="settingsUpstairsTarget" type="number" min="10" max="30" step="0.1" />
            </label>
            <label class="field">
                <span>Extra boost C</span>
                <input id="settingsUpstairsBoost" type="number" min="0" max="5" step="0.1" />
            </label>
        </div>
    </article>

    <article class="panel">
        <div class="panel-label">Home Presence</div>
        <label class="switch-row">
            <input id="settingsPresenceRequired" type="checkbox" />
            <span>Only prioritize upstairs when someone is home</span>
        </label>
        <label class="field">
            <span>Presence entity IDs</span>
            <input id="settingsPresenceEntities" type="text" placeholder="person.me, device_tracker.phone" />
        </label>
    </article>
</section>

<section class="panel schedule-panel" aria-label="Schedule">
    <div class="panel-head">
        <div>
            <div class="panel-label">Custom Schedule</div>
            <h2>Temperature rules</h2>
        </div>
        <button id="addSchedule" type="button" class="primary">Add schedule</button>
    </div>
    <div id="scheduleRows" class="schedule-rows"></div>
    <div class="settings-actions">
        <button id="saveSettings" type="button" class="primary">Save settings</button>
        <span id="settingsStatus" class="command-line"></span>
    </div>
</section>

@section Scripts {
    <script src="~/js/settings.js" asp-append-version="true"></script>
}
