@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="status-grid" aria-label="Current AC state">
    <article class="panel target-panel">
        <div class="panel-label">Generated Target</div>
        <div class="temperature-readout"><span id="targetTemp">--</span><span>C</span></div>
        <div class="inline-controls">
            <label class="field">
                <span>Set target</span>
                <input id="targetInput" type="number" min="10" max="35" step="0.1" inputmode="decimal" />
            </label>
            <button id="applyTarget" type="button">Apply</button>
            <button id="generateTarget" type="button" class="primary">Generate</button>
        </div>
        <label class="switch-row">
            <input id="defenderToggle" type="checkbox" />
            <span>Defender active</span>
        </label>
    </article>

    <article class="panel climate-panel">
        <div class="panel-head">
            <div>
                <div class="panel-label">Dining Room Climate</div>
                <h2 id="haEntity">Waiting for entity</h2>
            </div>
            <span class="pill" id="connectionState">--</span>
        </div>
        <div class="metric-grid">
            <div>
                <span class="metric-label">Room</span>
                <strong id="haCurrent">--</strong>
            </div>
            <div>
                <span class="metric-label">Setpoint</span>
                <strong id="haSetpoint">--</strong>
            </div>
            <div>
                <span class="metric-label">Mode</span>
                <strong id="haMode">--</strong>
            </div>
            <div>
                <span class="metric-label">Action</span>
                <strong id="haAction">--</strong>
            </div>
        </div>
        <div class="command-line" id="lastCommand">No commands yet</div>
        <div class="error-line" id="lastError"></div>
    </article>
</section>

<section class="work-grid" aria-label="Real controls and event log">
    <article class="panel thermostat-panel">
        <div class="panel-head">
            <div>
                <div class="panel-label">Real Thermostat Controls</div>
                <h2 id="realControlTitle">Dining room climate</h2>
            </div>
        </div>
        <div class="thermostat-face">
            <div>
                <span class="metric-label">Boost</span>
                <strong id="boostOffset">--</strong>
            </div>
            <div>
                <span class="metric-label">Updated</span>
                <strong id="haUpdated">--</strong>
            </div>
            <div>
                <span class="metric-label">Entity</span>
                <strong id="realEntity">--</strong>
            </div>
        </div>
        <div class="control-group real-controls">
            <button id="refreshReal" type="button">Refresh</button>
            <button id="forceTarget" type="button">Force target</button>
            <button id="forceBoost" type="button" class="primary">Force cooling</button>
        </div>
    </article>

    <article class="panel events-panel">
        <div class="panel-label">Activity</div>
        <ol id="eventLog" class="event-log"></ol>
    </article>
</section>
